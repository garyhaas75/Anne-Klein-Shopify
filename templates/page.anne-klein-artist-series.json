    "page_ak_artist_series_mission_7nUAA6": {
      "type": "page__ak-artist-series-mission",
      "name": "AK Artist Series mission",
      "settings": {
        "artist_series_logo": "shopify://shop_images/AK_Artist_Series_Logo.png",
        "artist_series_logo_alt": "Anne Klein Artist Series",
        "artist_series_logo_max_width": 290,
        "artist_series_logo_max_width_mobile": 220,
        "heading": "Where Style & Story Connect",
        "heading_level": "h2",
        "body": "<p>Anne Klein is committed to empowering women who wear its brand by partnering with entrepreneurial women to develop a print capsule collection that connects with our consumers. Our commitment to diversity and the arts provides a platform to engage and enhance visibility.<br/><br/>Our mission is to spotlight entrepreneurial women in the arts, offering a platform for their creativity and empowering talented female print designers. This series is more than just a showcase of beautiful designs, it’s a celebration of storytelling and representation. Each piece reflects the experiences, passions, and vision of the artist behind it.  We’re proud to bring these voices to the forefront through the Anne Klein Artist Series Collection.</p>",
        "signature": "shopify://shop_images/Anne_Signature.png",
