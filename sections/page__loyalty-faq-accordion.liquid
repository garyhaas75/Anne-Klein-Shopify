<ul id="accordion" class="page-watches-wrapper">
  {% for block in section.blocks %}
  <li class="page-watches-section panel open">
 	{% case block.type %}
    
    {% when 'header' %}
    <div class="watches-anchor" id="{{ block.settings.watches_anchor }}"></div>
    <h2 class="header">{{ block.settings.header }}</h2>
    
    {% when 'faq' %}
    
    {% if block.settings.watches_anchor %}
    <div id="{{ block.settings.watches_anchor | handleize }}"></div>
    {% endif %}
    
    <div class="header link">
      <h4 class="title">{{ block.settings.watches_header }}</h4>
    </div>
    
    <div class="submenu" style="display:block">
      <div class="">{{ block.settings.paragraph }}</div>
    </div>

    <div style="height: {{ block.settings.margin }}px;"></div>

	{% endcase %}

  </li>
  
  {% endfor %}
  
</ul>

<style>
  .panel .header .title {
    position: relative;
    margin-left: 50px;
  }
  .panel h2.header {
    font-size: 16px; 
    margin-bottom: 15px;
  }
  .panel .header .title::before {
    content: '+ ';
    width: 23.5px;
    position: absolute;
    left: -25px;
    top: -5px;
  }
  .panel.open .header .title::before {
    content: '- ';
  }
.accordion {
  width: 100%;
  max-width: 360px;
  margin: 30px auto 20px;
  background: #FFF;
  -webkit-border-radius: 4px;
  -moz-border-radius: 4px;
  border-radius: 4px;
}

.accordion .link {
  cursor: pointer;
  display: block;
  padding: 15px 15px 15px 42px;
  color: #4D4D4D;
  font-size: 14px;
  font-weight: 700;
  border-bottom: 1px solid #CCC;
  position: relative;
  -webkit-transition: all 0.4s ease;
  -o-transition: all 0.4s ease;
  transition: all 0.4s ease;
  
}
#accordion .link .title {
  cursor: pointer;
}
.accordion li:last-child .link { border-bottom: 0; }

.accordion li i {
  position: absolute;
  top: 16px;
  left: 12px;
  font-size: 18px;
  color: #595959;
  -webkit-transition: all 0.4s ease;
  -o-transition: all 0.4s ease;
  transition: all 0.4s ease;
}


.accordion li.open .link { color: #b63b4d; }

.accordion li.open i { color: #b63b4d; }

.accordion li.open i.fa-chevron-down {
  -webkit-transform: rotate(180deg);
  -ms-transform: rotate(180deg);
  -o-transform: rotate(180deg);
  transform: rotate(180deg);
}


.submenu {
  display: none;
  margin-left: 50px;
  margin-bottom: 20px;

}

  @media only screen and (max-width: 798px) {
    li.page-watches-section.panel .header {
      display: block;
    }
  }
      
</style>
<script>
  $(function() {
	var Accordion = function(el, multiple) {
		this.el = el || {};
		this.multiple = multiple || false;

		// Variables privadas
		var links = this.el.find('.link');
		// Evento
		links.on('click', {el: this.el, multiple: this.multiple}, this.dropdown)
	}

	Accordion.prototype.dropdown = function(e) {
		var $el = e.data.el;
			$this = $(this),
			$next = $this.next();

		$next.slideToggle();
		$this.parent().toggleClass('open');
     
		if (!e.data.multiple) {
			$el.find('.body').not($next).slideUp().parent().removeClass('open');
		};
	}	

	var accordion = new Accordion($('#accordion'), false);
});

</script>
{% schema %}
  {
    "name": "FAQ Blocks",
    "settings": [],
	"blocks": [
	  {
		"name": "FAQ",
		"type": "faq",
		"settings": [
		  {
			"type": "text",
			"id": "watches_anchor",
			"label": "Anchor ID",
			"info": "Must match header ID to link"
		  },
		  {
			"type": "text",
			"id": "watches_header",
			"label": "Question"
		  },
		  {
			"type": "richtext",
			"id": "paragraph",
			"label": "Answer"
		  },
          {
            "type": "range",
            "id": "margin",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "px",
            "label": "Height",
            "default": 0
          }
		  
		]
	  },

	  {
		"name": "Header",
		"type": "header",
		"settings": [
		  {
			"type": "text",
			"id": "header",
			"label": "Header"
		  },
		  {
			"type": "text",
			"id": "watches_anchor",
			"label": "Anchor ID",
			"info": "Must match header ID to link"
		  }
		]
	  }
	]
  }
{% endschema %}