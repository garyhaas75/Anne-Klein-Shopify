{% comment %}
** Gallery - dynamic **
- Draggable section; uses blocks.
- **Campaign BTS 2×2:** Figma mobile `35:616`, grid cells `189:70`–`189:73` (see docs/CAMPAIGN-LANDING-PLAN.md Step 7). Preset: classic, 2/row, crop.
{% endcomment %}

{% assign _gid = section.id %}
{% assign _g_fit = section.settings.image_object_fit | default: 'cover' %}
{% assign _g_pos = section.settings.image_object_position | default: 'center' %}
{% assign _g_ar = section.settings.classic_aspect_ratio | default: 'none' %}

{% assign _g_min_d = section.settings.classic_min_height_desktop | default: 0 | plus: 0 %}
{% assign _g_min_m = section.settings.classic_min_height_mobile | default: 0 | plus: 0 %}

{% style %}
  {% comment %}
    Classic gallery sizing. Theme uses .has-image-crop .gallery__item-wrap { height: 100% } but .gallery__item
    has no defined height, so percentage height never resolves and min-height on the wrap alone does not grow cells.
    Apply min-height on .gallery__item with flex column so .gallery__item-wrap fills and cropped images scale.
  {% endcomment %}
  {% if section.settings.gallery_type == 'classic' %}
    {% if _g_ar != blank and _g_ar != 'none' %}
      #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap {
        aspect-ratio: {{ _g_ar }};
        overflow: hidden;
      }
    {% endif %}
    {% if _g_min_m > 0 %}
      @media only screen and (max-width: 798px) {
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item {
          display: flex;
          flex-direction: column;
          min-height: {{ _g_min_m }}px;
        }
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap {
          flex: 1 1 auto;
          min-height: 0;
          width: 100%;
          align-self: stretch;
          height: auto !important;
        }
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item.has-image-crop .gallery__item-wrap {
          flex: 1 1 auto;
          min-height: 100% !important;
          height: 100% !important;
        }
      }
    {% endif %}
    {% if _g_min_d > 0 %}
      @media only screen and (min-width: 799px) {
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item {
          display: flex;
          flex-direction: column;
          min-height: {{ _g_min_d }}px;
        }
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap {
          flex: 1 1 auto;
          min-height: 0;
          width: 100%;
          align-self: stretch;
          height: auto !important;
        }
        #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item.has-image-crop .gallery__item-wrap {
          flex: 1 1 auto;
          min-height: 100% !important;
          height: 100% !important;
        }
      }
    {% endif %}
    {% if section.settings.crop_images %}
      #shopify-section-{{ _gid }} .gallery-type--classic .has-image-crop img {
        object-fit: {{ _g_fit }} !important;
        object-position: {{ _g_pos }};
      }
    {% elsif _g_ar != blank and _g_ar != 'none' %}
      #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap img {
        width: 100%;
        height: 100%;
        object-fit: {{ _g_fit }};
        object-position: {{ _g_pos }};
      }
      #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap .image-element__wrap {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        max-width: none;
      }
      #shopify-section-{{ _gid }} .gallery-type--classic .gallery__item .gallery__item-wrap {
        position: relative;
      }
    {% endif %}
  {% endif %}
  {% comment %} Keep 2-column grid on mobile when images_per_row == 2 (Figma mobile shows 2x2, theme forces single-column via small-down--one-whole). {% endcomment %}
  {% if section.settings.images_per_row == 2 %}
    @media only screen and (max-width: 798px) {
      #shopify-section-{{ _gid }} .gallery__item.small-down--one-whole {
        width: 50% !important;
        max-width: 50% !important;
      }
    }
  {% endif %}
{% endstyle %}

{% include 'include-gallery' %}

{% schema %}
  {
    "name": "Gallery",
    "class": "gallery jsGallery",
    "max_blocks": 20,
    "settings": [
      {
        "type": "select",
        "id": "gallery_type",
        "label": "Gallery style",
        "default": "classic",
        "options": [
          {
            "value": "classic",
            "label": "Classic"
          },
          {
            "value": "horizontal-masonry",
            "label": "Horizontal masonry"
          },
          {
            "value": "masonry",
            "label": "Vertical masonry"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "crop_images",
        "label": "Crop images",
        "default": false,
        "info": "Applies to classic only."
      },
      {
        "type": "header",
        "content": "Image sizing (classic)"
      },
      {
        "type": "paragraph",
        "content": "Classic gallery only. Use Crop images with min cell height so each column grows; min height sets a floor on the height of each image column."
      },
      {
        "type": "select",
        "id": "image_crop_position",
        "label": "Crop focal (horizontal)",
        "default": "center",
        "info": "When Crop images is on (theme left/center/right crop).",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ]
      },
      {
        "type": "select",
        "id": "image_object_fit",
        "label": "Object fit (cropped cells)",
        "default": "cover",
        "info": "When Crop images is on. Also used with Aspect ratio when crop is off.",
        "options": [
          { "value": "cover", "label": "Cover" },
          { "value": "contain", "label": "Contain" },
          { "value": "fill", "label": "Fill (stretch)" }
        ]
      },
      {
        "type": "select",
        "id": "image_object_position",
        "label": "Focal point",
        "default": "center",
        "options": [
          { "value": "center", "label": "Center" },
          { "value": "top", "label": "Top" },
          { "value": "bottom", "label": "Bottom" },
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" },
          { "value": "center top", "label": "Center top" },
          { "value": "center bottom", "label": "Center bottom" }
        ]
      },
      {
        "type": "select",
        "id": "classic_aspect_ratio",
        "label": "Cell aspect ratio",
        "default": "none",
        "info": "Locks each classic cell’s frame. Pair with Crop images for best results.",
        "options": [
          { "value": "none", "label": "None (natural / column-driven)" },
          { "value": "1 / 1", "label": "1:1" },
          { "value": "4 / 5", "label": "4:5" },
          { "value": "3 / 4", "label": "3:4" },
          { "value": "2 / 3", "label": "2:3" },
          { "value": "16 / 9", "label": "16:9" },
          { "value": "4 / 3", "label": "4:3" },
          { "value": "360 / 553", "label": "Figma BTS cell (~360×553)" }
        ]
      },
      {
        "type": "range",
        "id": "classic_min_height_desktop",
        "label": "Min cell height (desktop)",
        "min": 0,
        "max": 800,
        "step": 20,
        "default": 0,
        "unit": "px",
        "info": "0 = off. Minimum height per cell; use with Crop images."
      },
      {
        "type": "range",
        "id": "classic_min_height_mobile",
        "label": "Min cell height (mobile)",
        "min": 0,
        "max": 600,
        "step": 20,
        "default": 0,
        "unit": "px",
        "info": "0 = off. Minimum height per cell; use with Crop images."
      },
      {
        "type": "range",
        "id": "images_per_row",
        "label": "Images per row",
        "min": 2,
        "max": 5,
        "step": 1,
        "default": 4,
        "info": "Applies to vertical masonry and classic only."
      },
      {
        "type": "checkbox",
        "id": "enable_lightbox",
        "label": "Enable lightbox",
        "default": true
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "link_color",
        "label": "Icons",
        "default": "#FFFFFF"
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "select",
        "id": "width",
        "label": "Width",
        "default": "standard",
        "options": [
          {
            "value": "standard",
            "label": "Standard"
          },
          {
            "value": "wide",
            "label": "Wide"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "show_gutter",
        "label": "Show gutter",
        "default": true
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Top spacing",
        "min": 0,
        "max": 80,
        "default": 20,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom spacing",
        "min": 0,
        "max": 80,
        "default": 20,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "animation",
        "label": "Animation",
        "default": "none",
        "options": [
          {
            "value": "none",
            "label": "None"
          },
          {
            "value": "fadeIn",
            "label": "Fade in"
          },
          {
            "value": "fadeInDown",
            "label": "Fade in down"
          },
          {
            "value": "fadeInLeft",
            "label": "Fade in left"
          },
          {
            "value": "fadeInRight",
            "label": "Fade in right"
          },
          {
            "value": "slideInLeft",
            "label": "Slide in left"
          },
          {
            "value": "slideInRight",
            "label": "Slide in right"
          },
          {
            "value": "zoomIn",
            "label": "Zoom in"
          }
        ]
      },
      {
        "type": "header",
        "content": "Accessibility"
      },
      {
        "type": "text",
        "id": "section_aria_label",
        "label": "Section label (screen readers)",
        "default": "Image gallery",
        "info": "Announces this section to screen reader users."
      },
      {
        "type": "header",
        "content": "Advanced"
      },
      {
        "type": "paragraph",
        "content": "[Learn more](https://help.outofthesandbox.com/hc/en-us/articles/360022329373)"
      },
      {
        "type": "text",
        "id": "css_class",
        "label": "CSS Class"
      },
      {
        "type": "textarea",
        "id": "custom_css",
        "label": "Custom CSS"
      }
    ],
    "blocks": [
      {
        "type": "image",
        "name": "Image",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "800 x 800px recommended"
          },
          {
            "type": "text",
            "id": "image_alt",
            "label": "Image alt text",
            "info": "Describe the image for screen readers. Falls back to Shopify library alt if blank."
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Gallery",
        "category": "Image",
        "blocks": [
          {
            "type": "image"
          },
          {
            "type": "image"
          },
          {
            "type": "image"
          },
          {
            "type": "image"
          }
        ]
      }
    ]
  }
{% endschema %}