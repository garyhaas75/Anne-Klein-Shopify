{% comment %}
  AK Artist Series — footer CTA band.
  Figma file: 0kmSuSntT1RaS2ElBXMw25 (AK_Homepage-2026)
  Frames: AK_Artist Series_Desktop 351:1393 (Group 25 region), AK_Artist Series_Mobile 333:422
  Composition: centered hero photo (decorative butterflies baked into the image),
  pull-quote richtext below, small brand label ("ANNE KLEIN"), Anne Klein cursive
  signature image, and a primary CTA button. All centered on a configurable
  background color.
  WCAG 2.2 AA: region landmark, configurable heading level for the quote
  (default p — pull quotes shouldn't be document headings), alt text on every
  image, button is a real <a>, visible focus, min 44px target, prefers-reduced-motion.
{% endcomment %}

{% assign id = section.id %}
{% assign image = section.settings.image %}
{% assign mobile_image = section.settings.mobile_image | default: image %}
{% assign image_alt = section.settings.image_alt | default: 'Anne Klein Artist Series campaign image' %}
{% assign image_max_width = section.settings.image_max_width | default: 480 %}
{% assign image_max_width_mobile = section.settings.image_max_width_mobile | default: 320 %}
{% assign quote_rt = section.settings.quote %}
{% assign quote_level = section.settings.quote_level | default: 'p' %}
{% assign brand_label = section.settings.brand_label %}
{% assign signature = section.settings.signature %}
{% assign signature_alt = section.settings.signature_alt | default: 'Anne Klein signature' %}
{% assign signature_max_width = section.settings.signature_max_width | default: 240 %}
{% assign signature_max_width_mobile = section.settings.signature_max_width_mobile | default: 180 %}
{% assign button_label = section.settings.button_label %}
{% assign button_link = section.settings.button_link %}
{% assign button_style = section.settings.button_style | default: 'button--primary' %}
{% assign text_color = section.settings.text_color | default: '#000000' %}
{% assign background_color = section.settings.background_color | default: '#ffffff' %}
{% assign content_max_width = section.settings.content_max_width | default: 56 %}
{% assign padding_top = section.settings.padding_top | default: 96 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 96 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: 64 %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: 64 %}
{% assign image_to_quote_gap = section.settings.image_to_quote_gap | default: 32 %}
{% assign quote_to_brand_gap = section.settings.quote_to_brand_gap | default: 24 %}
{% assign brand_to_signature_gap = section.settings.brand_to_signature_gap | default: 8 %}
{% assign signature_to_button_gap = section.settings.signature_to_button_gap | default: 28 %}
{% assign section_aria_label = section.settings.section_aria_label %}

{% capture quote_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.quote_font_family %}{% endcapture %}
{% assign quote_font_stack = quote_font_stack | strip %}
{% capture brand_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.brand_font_family %}{% endcapture %}
{% assign brand_font_stack = brand_font_stack | strip %}

{% assign quote_size = section.settings.quote_font_size | default: 50 %}
{% assign quote_size_mobile = section.settings.quote_font_size_mobile | default: 0 | plus: 0 %}
{% if quote_size_mobile < 1 %}
  {% assign quote_size_mobile = quote_size %}
{% endif %}
{% assign quote_weight = section.settings.quote_font_weight | default: '300' %}
{% assign quote_lh = section.settings.quote_line_height | default: 130 %}
{% assign brand_size = section.settings.brand_font_size | default: 14 %}
{% assign brand_weight = section.settings.brand_font_weight | default: '700' %}

{% capture section_aria %}
  {% if section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Shop the Artist Series collection"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    background-color: {{ background_color }};
    color: {{ text_color }};
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: {{ padding_top }}px clamp(1rem, 4vw, 4rem) {{ padding_bottom }}px;
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta {
      padding: {{ padding_top_mobile }}px 1rem {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__inner {
    max-width: {{ content_max_width }}rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-width: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__media {
    width: 100%;
    max-width: {{ image_max_width }}px;
    line-height: 0;
    margin-bottom: {{ image_to_quote_gap }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__media {
      max-width: {{ image_max_width_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__media img,
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__media .placeholder-svg {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__media .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote {
    font-family: {{ quote_font_stack }};
    /* Fluid scale: slider value matches ~1280px desktop. Cap = 3x slider so growth is only limited
       at extreme widths or extreme slider values. */
    font-size: clamp(1.25rem, calc({{ quote_size }}px * 0.4 + 2.4vw), calc({{ quote_size }}px * 3));
    font-weight: {{ quote_weight }};
    line-height: {{ quote_lh }}%;
    color: {{ text_color }};
    margin: 0 0 {{ quote_to_brand_gap }}px;
    overflow-wrap: break-word;
    max-width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote {
      font-size: clamp(1.125rem, calc({{ quote_size_mobile }}px * 0.65 + 2vw), {{ quote_size_mobile }}px);
    }
  }
  /* Normalize RTE inline font-size on quote children */
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote p,
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote li,
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote blockquote {
    font-size: clamp(1.25rem, calc({{ quote_size }}px * 0.4 + 2.4vw), calc({{ quote_size }}px * 3)) !important;
    line-height: {{ quote_lh }}%;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote p span,
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote li span {
    font-size: inherit !important;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote p,
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote li,
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote blockquote {
      font-size: clamp(1.125rem, calc({{ quote_size_mobile }}px * 0.65 + 2vw), {{ quote_size_mobile }}px) !important;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote p {
    margin: 0 0 0.5em;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__quote p:last-child {
    margin-bottom: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__brand {
    font-family: {{ brand_font_stack }};
    /* Fluid scaling for brand label on wide screens. Cap = 3x slider. */
    font-size: clamp(0.75rem, calc({{ brand_size }}px * 0.7 + 0.4vw), calc({{ brand_size }}px * 3));
    font-weight: {{ brand_weight }};
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ text_color }};
    margin: 0 0 {{ brand_to_signature_gap }}px;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__signature {
    display: block;
    width: min({{ signature_max_width }}px, 60vw);
    height: auto;
    max-width: 100%;
    margin: 0 0 {{ signature_to_button_gap }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta__signature {
      width: min({{ signature_max_width_mobile }}px, 70vw);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__actions {
    display: flex;
    justify-content: center;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__actions .button {
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
  }
  #shopify-section-{{ id }} .ak-artist-series-footer-cta__actions .button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-artist-series-footer-cta * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<section
  class="section is-width-wide ak-artist-series-footer-cta-section has-no-side-gutter has-background"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="ak-artist-series-footer-cta">
    <div class="ak-artist-series-footer-cta__inner">
      {% if image != blank or mobile_image != blank %}
        <div class="ak-artist-series-footer-cta__media">
          {% if image != blank %}
            {% include 'image-element', image: image, alt: image_alt, stretch_width: true, additional_classes: 'is-hidden-mobile-only' %}
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg is-hidden-mobile-only' }}
          {% endif %}
          {% if mobile_image != blank %}
            <div class="is-hidden-desktop-only">
              {% include 'image-element', image: mobile_image, alt: image_alt, stretch_width: true %}
            </div>
          {% elsif image != blank %}
            <div class="is-hidden-desktop-only">
              {% include 'image-element', image: image, alt: image_alt, stretch_width: true %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if quote_rt != blank %}
        {% if quote_level == 'h2' %}
          <h2 class="ak-artist-series-footer-cta__quote rte">{{ quote_rt }}</h2>
        {% elsif quote_level == 'h3' %}
          <h3 class="ak-artist-series-footer-cta__quote rte">{{ quote_rt }}</h3>
        {% elsif quote_level == 'blockquote' %}
          <blockquote class="ak-artist-series-footer-cta__quote rte">{{ quote_rt }}</blockquote>
        {% else %}
          <div class="ak-artist-series-footer-cta__quote rte">{{ quote_rt }}</div>
        {% endif %}
      {% endif %}

      {% if brand_label != blank %}
        <p class="ak-artist-series-footer-cta__brand">{{ brand_label }}</p>
      {% endif %}

      {% if signature != blank %}
        <img
          class="ak-artist-series-footer-cta__signature"
          src="{{ signature | image_url: width: 600 }}"
          alt="{{ signature_alt | escape }}"
          loading="lazy"
          width="{{ signature.width }}"
          height="{{ signature.height }}"
        >
      {% endif %}

      {% if button_label != blank and button_link != blank %}
        <div class="ak-artist-series-footer-cta__actions">
          {% if section.settings.button_new_tab %}
            {% capture btn_attr %}target="_blank" rel="noopener noreferrer"{% endcapture %}
            {% include 'button', label: button_label, href: button_link, style: button_style, type: 'link', attribute: btn_attr %}
          {% else %}
            {% include 'button', label: button_label, href: button_link, style: button_style, type: 'link' %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

