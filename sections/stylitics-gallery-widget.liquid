<script src="https://web-assets.stylitics.com/loader/latest/loader.js"></script>
  
<div id="stylitics-widget-container" role="region" aria-label="Style gallery"></div>

<script>
let widgetInstance = new StyliticsDimensionCollageWidget("anneklein", "stylitics-widget-container", {
  api: {
    tags: "{{ section.settings.tag }}",
    max: 10,
    min: 3
  },
  display: {
    swipeableCarouselArrows: true,
    swipeableCarouselNextItemPeek: 0.275
  }
});
widgetInstance.start();
</script>

{% schema %}
  {
    "name": "Stylitics Gallery Widget",
    "settings": [
      {
        "type": "text",
        "id": "tag",
        "label": "Tag"
      }
    ],
    "presets": [{ "name": "Stylitics Gallery Widget" }]
  }
{% endschema %}