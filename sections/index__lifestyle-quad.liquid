{% comment %}
  AK Homepage 2026 – Lifestyle Quad (2x2)
  Four panels: image + overlay heading + CTA link
  WCAG 2.2 AA: single link per panel (stretched), h2, alt fallback, contrast, section label.
  B1: Dynamic aspect ratio from image or schema preset. C3: aspect-ratio fallback.
{% endcomment %}

{% assign id = section.id %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign text_color = section.settings.text_color %}
{% assign aspect_ratio_mode = section.settings.aspect_ratio_mode | default: 'match_image' %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign container_width = section.settings.container_width | default: 'full' %}
{% assign max_height_desktop = section.settings.max_height_desktop | default: 0 %}
{% assign max_height_mobile = section.settings.max_height_mobile | default: 0 %}

{% capture section_aria %}
  {% if section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Campaign lifestyle grid"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  #shopify-section-{{ id }} .ak-quad__heading,
  #shopify-section-{{ id }} .ak-quad__cta { color: {{ text_color }}; }
  #shopify-section-{{ id }} .ak-quad__wrap {
    margin: 0 auto;
    {% if container_width == 'standard' %}max-width: 1200px;{% elsif container_width == 'wide' %}max-width: 1400px;{% endif %}
  }
  #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  #shopify-section-{{ id }} .ak-quad__cell { min-height: 0; }
  #shopify-section-{{ id }} .ak-quad__panel { position: relative; overflow: hidden; }
  #shopify-section-{{ id }} .ak-quad__media { position: absolute; inset: 0; }
  #shopify-section-{{ id }} .ak-quad__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: none; }
  #shopify-section-{{ id }} .ak-quad__media video.ak-quad__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ id }} .ak-quad__video-wrap { position: absolute; inset: 0; }
  #shopify-section-{{ id }} .ak-quad__pause-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    z-index: 4;
    min-width: 44px;
    min-height: 44px;
    width: 32px;
    height: 32px;
    padding: 6px;
    border-radius: 50%;
    border: 2px solid currentColor;
    background: rgba(0,0,0,0.5);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ id }} .ak-quad__panel:hover .ak-quad__pause-btn,
  #shopify-section-{{ id }} .ak-quad__pause-btn:focus-visible { opacity: 1; }
  #shopify-section-{{ id }} .ak-quad__pause-btn:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-quad__pause-btn { opacity: 1; transition: none; }
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-quad__gradient {
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 50%; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-quad__caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 1.5rem 1.25rem 2rem; z-index: 1;
  }
  #shopify-section-{{ id }} .ak-quad__cta-link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;
    padding: 1.5rem 1.25rem 2rem;
    text-decoration: none;
    color: inherit;
    z-index: 2;
  }
  #shopify-section-{{ id }} .ak-quad__heading {
    font-family: Amiri, serif;
    font-size: clamp(1.5rem, 2.5vw, 2.625rem);
    font-weight: 400;
    margin: 0 0 0.35em;
    line-height: 1.2;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  #shopify-section-{{ id }} .ak-quad__cta {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  #shopify-section-{{ id }} .ak-quad__cta-link:hover,
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible { opacity: 0.9; }
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid { grid-template-columns: 1fr; }
  }
  {% if max_height_desktop > 0 %}
  #shopify-section-{{ id }} .ak-quad__panel {
    max-height: {{ max_height_desktop }}px;
    height: {{ max_height_desktop }}px;
  }
  #shopify-section-{{ id }} .ak-quad__panel-inner {
    position: absolute;
    inset: 0;
    padding-bottom: 0 !important;
    height: 100%;
  }
  {% else %}
  @supports (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel[data-aspect-ratio] { aspect-ratio: var(--ak-quad-ratio, 1); }
    #shopify-section-{{ id }} .ak-quad__panel-inner { position: absolute; inset: 0; padding-bottom: 0 !important; }
  }
  @supports not (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel-inner { height: 0; position: relative; }
    #shopify-section-{{ id }} .ak-quad__panel-inner .ak-quad__media { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }
  }
  {% endif %}
  @media only screen and (max-width: 798px) {
    {% if max_height_mobile > 0 %}
    #shopify-section-{{ id }} .ak-quad__panel {
      max-height: {{ max_height_mobile }}px;
      height: {{ max_height_mobile }}px;
    }
    #shopify-section-{{ id }} .ak-quad__panel-inner {
      position: absolute;
      inset: 0;
      padding-bottom: 0 !important;
      height: 100%;
    }
    {% elsif max_height_desktop > 0 %}
    #shopify-section-{{ id }} .ak-quad__panel {
      max-height: none;
      height: auto;
    }
    {% endif %}
  }
{% endstyle %}

<section class="section is-width-wide ak-lifestyle-quad has-no-side-gutter ak-quad--container-{{ container_width }}" id="shopify-section-{{ id }}" {{ section_aria }}>
  <div class="ak-quad__wrap">
  <div class="ak-quad__grid">
    {% for block in section.blocks %}
      {% if block.type == 'panel' %}
        {% assign panel_media_type = block.settings.media_type | default: 'image' %}
        {% assign panel_video = block.settings.video %}
        {% assign panel_image = block.settings.image %}
        {% assign panel_mobile_image = block.settings.mobile_image | default: panel_image %}
        {% assign panel_heading = block.settings.heading %}
        {% assign panel_cta_text = block.settings.cta_text %}
        {% assign panel_link = block.settings.link %}
        {% assign panel_alt = panel_image.alt | default: panel_heading | default: "Campaign image" %}
        {% assign panel_mobile_alt = panel_mobile_image.alt | default: panel_heading | default: "Campaign image" %}
        {% assign use_video = false %}
        {% if panel_media_type == 'video' and panel_video != blank %}
          {% assign use_video = true %}
        {% endif %}

        {% if use_video %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 3 / 4;"' %}
          {% assign padding_pct = 133 %}
        {% elsif aspect_ratio_mode == 'match_image' and panel_image != blank %}
          {% assign pw = panel_image.width %}
          {% assign ph = panel_image.height %}
          {% assign ratio_style = 'style="--ak-quad-ratio: ' | append: pw | append: ' / ' | append: ph | append: ';"' %}
          {% assign padding_pct = ph | times: 100 | divided_by: pw %}
        {% elsif aspect_ratio_mode == '3_4' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 3 / 4;"' %}
          {% assign padding_pct = 133 %}
        {% elsif aspect_ratio_mode == '8_9' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 960 / 1080;"' %}
          {% assign padding_pct = 112 %}
        {% elsif aspect_ratio_mode == '4_3' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 4 / 3;"' %}
          {% assign padding_pct = 75 %}
        {% else %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 1;"' %}
          {% assign padding_pct = 100 %}
        {% endif %}

        <div class="ak-quad__cell" {{ block.shopify_attributes }}>
          <div class="ak-quad__panel" data-aspect-ratio {{ ratio_style }}>
            <div class="ak-quad__panel-inner" style="padding-bottom: {{ padding_pct }}%;">
              <div class="ak-quad__media">
                {% if use_video %}
                  <div class="ak-quad__video-wrap">
                    <video
                      class="ak-quad__video is-hidden-mobile-only"
                      autoplay
                      muted
                      playsinline
                      loop
                      aria-label="{{ panel_heading | default: 'Panel video' | escape }}"
                      data-panel-video="{{ block.id }}"
                    >
                      {% for source in panel_video.sources %}
                        <source src="{{ source.url }}" type="{{ source.mime_type }}">
                      {% endfor %}
                    </video>
                  </div>
                  {% if panel_image != blank %}
                    <div class="is-hidden-desktop-only">
                      {% include 'image-element', image: panel_image, alt: panel_alt, stretch_width: true, additional_classes: 'ak-quad__img' %}
                    </div>
                  {% endif %}
                {% else %}
                  {% if panel_image != blank %}
                    {% include 'image-element', image: panel_image, alt: panel_alt, stretch_width: true, additional_classes: 'ak-quad__img is-hidden-mobile-only' %}
                  {% else %}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg ak-quad__img' }}
                  {% endif %}
                  {% if panel_mobile_image != blank %}
                    <div class="is-hidden-desktop-only">
                      {% include 'image-element', image: panel_mobile_image, alt: panel_mobile_alt, stretch_width: true, additional_classes: 'ak-quad__img' %}
                    </div>
                  {% endif %}
                {% endif %}
                <div class="ak-quad__gradient" aria-hidden="true"></div>
              </div>
            </div>

            {% if panel_link != blank %}
              <a href="{{ panel_link }}" class="ak-quad__cta-link" aria-label="{{ panel_heading | default: panel_cta_text | default: 'View' }}">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta">{{ panel_cta_text }}</p>
                {% endif %}
              </a>
            {% else %}
              <div class="ak-quad__caption">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta">{{ panel_cta_text }}</p>
                {% endif %}
              </div>
            {% endif %}

            {% if use_video and panel_video.sources[0] != blank %}
              <button type="button" class="ak-quad__pause-btn" aria-label="Pause video" data-pause-btn="{{ block.id }}">Pause</button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ id }}');
    if (!section) return;
    section.querySelectorAll('[data-pause-btn]').forEach(function(btn) {
      var blockId = btn.getAttribute('data-pause-btn');
      var video = section.querySelector('.ak-quad__video[data-panel-video="' + blockId + '"]');
      if (!video) return;
      function updateLabel() {
        btn.setAttribute('aria-label', video.paused ? 'Play video' : 'Pause video');
        btn.textContent = video.paused ? 'Play' : 'Pause';
      }
      btn.addEventListener('click', function() {
        if (video.paused) {
          video.play();
        } else {
          video.pause();
        }
        updateLabel();
      });
      video.addEventListener('play', updateLabel);
      video.addEventListener('pause', updateLabel);
      updateLabel();
    });
  })();
</script>

{% schema %}
{
  "name": "AK Lifestyle Quad",
  "class": "ak-lifestyle-quad-section",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Overlay text color",
      "default": "#ffffff",
      "info": "Use white or light text. The section applies a gradient and text shadow for contrast."
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "standard", "label": "Standard (1200px)" }
      ],
      "info": "Maximum width of the 2×2 grid. Full width uses the full viewport."
    },
    {
      "type": "select",
      "id": "aspect_ratio_mode",
      "label": "Image aspect ratio",
      "default": "match_image",
      "options": [
        { "value": "match_image", "label": "Match image" },
        { "value": "1_1", "label": "Square (1:1)" },
        { "value": "3_4", "label": "Portrait (3:4)" },
        { "value": "8_9", "label": "Portrait (8:9)" },
        { "value": "4_3", "label": "Landscape (4:3)" }
      ],
      "info": "Match image uses each panel's image dimensions. Presets apply a fixed ratio to all panels."
    },
    {
      "type": "header",
      "content": "Panel height"
    },
    {
      "type": "range",
      "id": "max_height_desktop",
      "min": 0,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Max height per panel (desktop)",
      "default": 0,
      "info": "0 = use aspect ratio. Set a value (400–1200) to cap each panel's height. Images will crop to fill."
    },
    {
      "type": "range",
      "id": "max_height_mobile",
      "min": 0,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Max height per panel (mobile)",
      "default": 0,
      "info": "0 = use aspect ratio on mobile (ignores desktop max height). Set a value for mobile-specific height."
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (for screen readers)",
      "info": "Optional. Leave blank for default 'Campaign lifestyle grid'."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "info": "Video shows a pause/play button for accessibility (ADA)."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Used when Media type is Video. Desktop only; use Image for mobile fallback."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Add alt in media library; panel heading used as fallback. Used as mobile fallback when Video is set."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AK Lifestyle Quad",
      "blocks": [
        { "type": "panel", "settings": { "heading": "Dress with Intention", "cta_text": "SHOP DRESSES" } },
        { "type": "panel", "settings": { "heading": "Business Leisure", "cta_text": "SHOP WORKWEAR" } },
        { "type": "panel", "settings": { "heading": "Finishing Touches", "cta_text": "SHOP ACCESSORIES" } },
        { "type": "panel", "settings": { "heading": "Vacation Mindset", "cta_text": "SHOP RESORT" } }
      ]
    }
  ]
}
{% endschema %}
