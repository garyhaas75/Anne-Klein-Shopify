{% comment %}
  AK Homepage 2026 – Lifestyle Quad (2x2)
  Four panels: image + overlay heading + CTA link
  WCAG 2.2 AA: single link per panel (stretched), h2, alt fallback, contrast, section label.
  B1: Dynamic aspect ratio from image or schema preset. C3: aspect-ratio fallback.
{% endcomment %}

{% assign id = section.id %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign overlay_caption_pt = section.settings.overlay_caption_padding_top | default: 24 %}
{% assign overlay_caption_pb = section.settings.overlay_caption_padding_bottom | default: 32 %}
{% assign overlay_caption_pt_m = section.settings.overlay_caption_padding_top_mobile | default: overlay_caption_pt %}
{% assign overlay_caption_pb_m = section.settings.overlay_caption_padding_bottom_mobile | default: overlay_caption_pb %}
{% assign text_color = section.settings.text_color %}
{% assign aspect_ratio_mode = section.settings.aspect_ratio_mode | default: 'match_image' %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign container_width = section.settings.container_width | default: 'full' %}
{% assign max_height_desktop = section.settings.max_height_desktop | default: 0 %}
{% assign max_height_mobile = section.settings.max_height_mobile | default: 0 %}
{% assign heading_font_size = section.settings.heading_font_size | default: 42 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '400' %}
{% assign cta_font_size = section.settings.cta_font_size | default: 14 %}
{% assign cta_font_weight = section.settings.cta_font_weight | default: '700' %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% assign _heading_font = section.settings.font_heading | default: section.settings.font_family %}
{% case _heading_font %}
  {% when 'arial' %}{% assign font_stack_heading = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack_heading = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack_heading = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack_heading = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack_heading = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'system' %}{% assign font_stack_heading = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack_heading = font_stack %}
{% endcase %}
{% assign _cta_font = section.settings.font_cta | default: section.settings.font_family %}
{% case _cta_font %}
  {% when 'arial' %}{% assign font_stack_cta = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack_cta = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack_cta = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack_cta = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack_cta = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'system' %}{% assign font_stack_cta = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack_cta = font_stack %}
{% endcase %}

{% capture section_aria %}
  {% if section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Campaign lifestyle grid"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-quad__heading,
  #shopify-section-{{ id }} .ak-quad__cta { color: {{ text_color }}; text-transform: none; }
  #shopify-section-{{ id }} .ak-quad__wrap {
    margin: 0 auto;
    {% if container_width == 'standard' %}max-width: 1200px;{% elsif container_width == 'wide' %}max-width: 1400px;{% endif %}
  }
  #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  #shopify-section-{{ id }} .ak-quad__cell { min-height: 0; }
  #shopify-section-{{ id }} .ak-quad__panel { position: relative; overflow: hidden; }
  #shopify-section-{{ id }} .ak-quad__media { position: absolute; inset: 0; }
  #shopify-section-{{ id }} .ak-quad__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: none; }
  #shopify-section-{{ id }} .ak-quad__media video.ak-quad__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ id }} .ak-quad__video-wrap { position: absolute; inset: 0; }
  #shopify-section-{{ id }} .ak-quad__pause-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    z-index: 4;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(0,0,0,0.5);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ id }} .ak-quad__pause-btn svg {
    width: 24px;
    height: 24px;
    display: block;
    fill: currentColor;
  }
  #shopify-section-{{ id }} .ak-quad__pause-btn .ak-quad__play-icon[hidden],
  #shopify-section-{{ id }} .ak-quad__pause-btn .ak-quad__pause-icon[hidden] {
    display: none;
  }
  #shopify-section-{{ id }} .ak-quad__panel:hover .ak-quad__pause-btn,
  #shopify-section-{{ id }} .ak-quad__pause-btn:focus-visible { opacity: 1; }
  #shopify-section-{{ id }} .ak-quad__pause-btn:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-quad__pause-btn { opacity: 1; transition: none; }
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: block !important; }
    #shopify-section-{{ id }} .ak-quad__panel.ak-quad--controls-visible .ak-quad__pause-btn { opacity: 1; }
    #shopify-section-{{ id }} .ak-quad__pause-btn:focus-visible { opacity: 1; }
  }
  #shopify-section-{{ id }} .ak-quad__gradient {
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 50%; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-quad__caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: {{ overlay_caption_pt }}px 1.25rem {{ overlay_caption_pb }}px; z-index: 1;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-quad__caption {
      padding: {{ overlay_caption_pt_m }}px 1rem {{ overlay_caption_pb_m }}px;
    }
  }
  #shopify-section-{{ id }} .ak-quad__cta-link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;
    padding: {{ overlay_caption_pt }}px 1.25rem {{ overlay_caption_pb }}px;
    text-decoration: none;
    color: inherit;
    z-index: 2;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-quad__cta-link {
      padding: {{ overlay_caption_pt_m }}px 1rem {{ overlay_caption_pb_m }}px;
    }
  }
  #shopify-section-{{ id }} .ak-quad__heading {
    font-family: {{ font_stack_heading }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    margin: 0 0 0.35em;
    line-height: 1.2;
    text-shadow: 0 1px 2px rgba(0,0,0,0.75);
  }
  #shopify-section-{{ id }} .ak-quad__cta {
    margin: 0;
    font-family: {{ font_stack_cta }};
    font-size: {{ cta_font_size }}px;
    font-weight: {{ cta_font_weight }};
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-shadow: 0 1px 2px rgba(0,0,0,0.75);
  }
  #shopify-section-{{ id }} .ak-quad__cta-link:hover,
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible { opacity: 0.9; }
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-quad__caption .ak-quad__heading:focus-visible,
  #shopify-section-{{ id }} .ak-quad__caption .ak-quad__cta:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid { grid-template-columns: 1fr; }
  }
  {% if max_height_desktop > 0 %}
  #shopify-section-{{ id }} .ak-quad__panel {
    max-height: {{ max_height_desktop }}px;
    height: {{ max_height_desktop }}px;
  }
  #shopify-section-{{ id }} .ak-quad__panel-inner {
    position: absolute;
    inset: 0;
    padding-bottom: 0 !important;
    height: 100%;
  }
  {% else %}
  @supports (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel[data-aspect-ratio] { aspect-ratio: var(--ak-quad-ratio, 1); }
    #shopify-section-{{ id }} .ak-quad__panel-inner { position: absolute; inset: 0; padding-bottom: 0 !important; }
  }
  @supports not (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel-inner { height: 0; position: relative; }
    #shopify-section-{{ id }} .ak-quad__panel-inner .ak-quad__media { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }
  }
  {% endif %}
  @media only screen and (max-width: 798px) {
    {% if max_height_mobile > 0 %}
    #shopify-section-{{ id }} .ak-quad__panel {
      max-height: {{ max_height_mobile }}px;
      height: {{ max_height_mobile }}px;
    }
    #shopify-section-{{ id }} .ak-quad__panel-inner {
      position: absolute;
      inset: 0;
      padding-bottom: 0 !important;
      height: 100%;
    }
    {% elsif max_height_desktop > 0 %}
    #shopify-section-{{ id }} .ak-quad__panel {
      max-height: none;
      height: auto;
    }
    {% endif %}
  }
{% endstyle %}

<section class="section is-width-wide ak-lifestyle-quad has-no-side-gutter ak-quad--container-{{ container_width }}" id="shopify-section-{{ id }}" {{ section_aria }}>
  <div class="ak-quad__wrap">
  <div class="ak-quad__grid">
    {% for block in section.blocks %}
      {% if block.type == 'panel' %}
        {% assign panel_media_type = block.settings.media_type | default: 'image' %}
        {% assign panel_video = block.settings.video %}
        {% assign panel_image = block.settings.image %}
        {% assign panel_mobile_image = block.settings.mobile_image | default: panel_image %}
        {% assign panel_heading = block.settings.heading %}
        {% assign panel_cta_text = block.settings.cta_text %}
        {% assign panel_link = block.settings.link %}
        {% assign panel_alt = panel_image.alt | default: '' %}
        {% assign panel_mobile_alt = panel_mobile_image.alt | default: '' %}
        {% assign use_video = false %}
        {% if panel_media_type == 'video' and panel_video != blank %}
          {% assign use_video = true %}
        {% endif %}

        {% comment %} Same aspect ratio for image and video panels, from section setting {% endcomment %}
        {% if aspect_ratio_mode == '1_1' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 1;"' %}
          {% assign padding_pct = 100 %}
        {% elsif aspect_ratio_mode == '3_4' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 3 / 4;"' %}
          {% assign padding_pct = 133 %}
        {% elsif aspect_ratio_mode == '8_9' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 960 / 1080;"' %}
          {% assign padding_pct = 112 %}
        {% elsif aspect_ratio_mode == '4_3' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 4 / 3;"' %}
          {% assign padding_pct = 75 %}
        {% elsif aspect_ratio_mode == 'match_image' and panel_image != blank %}
          {% assign pw = panel_image.width %}
          {% assign ph = panel_image.height %}
          {% assign ratio_style = 'style="--ak-quad-ratio: ' | append: pw | append: ' / ' | append: ph | append: ';"' %}
          {% assign padding_pct = ph | times: 100 | divided_by: pw %}
        {% else %}
          {% comment %} match_image with no image (e.g. video-only panel) or unknown mode: default 3:4 {% endcomment %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 3 / 4;"' %}
          {% assign padding_pct = 133 %}
        {% endif %}

        <div class="ak-quad__cell" {{ block.shopify_attributes }}>
          <div class="ak-quad__panel" data-aspect-ratio {{ ratio_style }}>
            <div class="ak-quad__panel-inner" style="padding-bottom: {{ padding_pct }}%;">
              <div class="ak-quad__media">
                {% if use_video %}
                  <div class="ak-quad__video-wrap">
                    <video
                      class="ak-quad__video"
                      autoplay
                      muted
                      playsinline
                      loop
                      preload="auto"
                      aria-label="{{ panel_heading | default: 'Panel video' | escape }}"
                      data-panel-video="{{ block.id }}"
                      {% assign poster_image = panel_mobile_image | default: panel_image %}
                      {% if poster_image != blank %}poster="{{ poster_image | image_url: width: 1200 }}"{% endif %}
                    >
                      {% for source in panel_video.sources %}
                        <source src="{{ source.url }}" type="{{ source.mime_type }}">
                      {% endfor %}
                    </video>
                  </div>
                {% else %}
                  {% if panel_image != blank %}
                    {% include 'image-element', image: panel_image, alt: panel_alt, stretch_width: true, additional_classes: 'ak-quad__img is-hidden-mobile-only' %}
                  {% else %}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg ak-quad__img' }}
                  {% endif %}
                  {% if panel_mobile_image != blank %}
                    <div class="is-hidden-desktop-only">
                      {% include 'image-element', image: panel_mobile_image, alt: panel_mobile_alt, stretch_width: true, additional_classes: 'ak-quad__img' %}
                    </div>
                  {% endif %}
                {% endif %}
                <div class="ak-quad__gradient" aria-hidden="true"></div>
              </div>
            </div>

            {% if panel_link != blank %}
              <a href="{{ panel_link }}" class="ak-quad__cta-link" aria-label="{{ panel_heading | default: panel_cta_text | default: 'View campaign' | escape }}">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta">{{ panel_cta_text }}</p>
                {% endif %}
              </a>
            {% else %}
              <div class="ak-quad__caption">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading" tabindex="0">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta" tabindex="0">{{ panel_cta_text }}</p>
                {% endif %}
              </div>
            {% endif %}

            {% if use_video and panel_video.sources[0] != blank %}
              <button type="button" class="ak-quad__pause-btn" aria-label="Pause video" data-pause-btn="{{ block.id }}">
                <span class="ak-quad__pause-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg></span>
                <span class="ak-quad__play-icon" aria-hidden="true" hidden><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7L8 5z"/></svg></span>
              </button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ id }}');
    if (!section) return;
    var videos = section.querySelectorAll('.ak-quad__video[data-panel-video]');
    function tryPlay(video) {
      if (!video || video.readyState < 2) return;
      video.muted = true;
      video.play().catch(function() {});
    }
    section.querySelectorAll('[data-pause-btn]').forEach(function(btn) {
      var blockId = btn.getAttribute('data-pause-btn');
      var video = section.querySelector('.ak-quad__video[data-panel-video="' + blockId + '"]');
      if (!video) return;
      function updateLabel() {
        btn.setAttribute('aria-label', video.paused ? 'Play video' : 'Pause video');
        var pauseIcon = btn.querySelector('.ak-quad__pause-icon');
        var playIcon = btn.querySelector('.ak-quad__play-icon');
        if (pauseIcon) pauseIcon.hidden = video.paused;
        if (playIcon) playIcon.hidden = !video.paused;
      }
      btn.addEventListener('click', function() {
        if (video.paused) {
          video.play();
        } else {
          video.pause();
        }
        updateLabel();
      });
      video.addEventListener('play', updateLabel);
      video.addEventListener('pause', updateLabel);
      video.addEventListener('loadeddata', function() { tryPlay(video); });
      video.addEventListener('canplay', function() { tryPlay(video); });
      if (video.readyState >= 2) tryPlay(video);
      updateLabel();
    });
    var isMobileQuad = window.matchMedia && window.matchMedia('(max-width: 798px)').matches;
    if (isMobileQuad) {
      section.querySelectorAll('.ak-quad__panel').forEach(function(panel) {
        var timer = null;
        panel.addEventListener('click', function(e) {
          if (e.target.closest('.ak-quad__pause-btn')) return;
          panel.classList.add('ak-quad--controls-visible');
          clearTimeout(timer);
          timer = setTimeout(function() {
            panel.classList.remove('ak-quad--controls-visible');
          }, 4000);
        });
      });
    }
    if (typeof IntersectionObserver !== 'undefined' && videos.length) {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          var v = entry.target;
          if (entry.isIntersecting) {
            v.muted = true;
            v.play().catch(function() {});
          } else {
            v.pause();
          }
        });
      }, { rootMargin: '10%', threshold: 0.1 });
      videos.forEach(function(v) { io.observe(v); });
    }
  })();
</script>

{% schema %}
{
  "name": "AK Lifestyle Quad",
  "class": "ak-lifestyle-quad-section",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Overlay text color",
      "default": "#ffffff",
      "info": "Use white or light text. The section applies a gradient and text shadow for contrast."
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Default font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Used when heading or CTA font below is set to \"Same as default\"."
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Panel heading font",
      "default": "",
      "options": [
        { "value": "", "label": "Same as default" },
        { "value": "system", "label": "System" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "select",
      "id": "font_cta",
      "label": "CTA font",
      "default": "",
      "options": [
        { "value": "", "label": "Same as default" },
        { "value": "system", "label": "System" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 18,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading font size",
      "default": 42,
      "info": "Panel heading (e.g. Dress with Intention)."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "range",
      "id": "cta_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "CTA font size",
      "default": 14,
      "info": "CTA text (e.g. SHOP DRESSES)."
    },
    {
      "type": "select",
      "id": "cta_font_weight",
      "label": "CTA font weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "standard", "label": "Standard (1200px)" }
      ],
      "info": "Maximum width of the 2×2 grid. Full width uses the full viewport."
    },
    {
      "type": "select",
      "id": "aspect_ratio_mode",
      "label": "Image aspect ratio",
      "default": "match_image",
