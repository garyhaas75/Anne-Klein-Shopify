{% comment %}
  AK Homepage 2026 – Lifestyle Quad (2x2)
  Four panels: image + overlay heading + CTA link
  WCAG 2.2 AA: single link per panel (stretched), h2, alt fallback, contrast, section label.
  B1: Dynamic aspect ratio from image or schema preset. C3: aspect-ratio fallback.
{% endcomment %}

{% assign id = section.id %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign text_color = section.settings.text_color %}
{% assign aspect_ratio_mode = section.settings.aspect_ratio_mode | default: 'match_image' %}
{% assign section_aria_label = section.settings.section_aria_label %}

{% capture section_aria %}
  {% if section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Campaign lifestyle grid"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  #shopify-section-{{ id }} .ak-quad__heading,
  #shopify-section-{{ id }} .ak-quad__cta { color: {{ text_color }}; }
  #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  #shopify-section-{{ id }} .ak-quad__cell { min-height: 0; }
  #shopify-section-{{ id }} .ak-quad__panel { position: relative; overflow: hidden; }
  #shopify-section-{{ id }} .ak-quad__media { position: absolute; inset: 0; }
  #shopify-section-{{ id }} .ak-quad__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-quad__media .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-quad__gradient {
    position: absolute; left: 0; right: 0; bottom: 0;
    height: 50%; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-quad__caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 1.5rem 1.25rem 2rem; z-index: 1;
  }
  #shopify-section-{{ id }} .ak-quad__cta-link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;
    padding: 1.5rem 1.25rem 2rem;
    text-decoration: none;
    color: inherit;
    z-index: 2;
  }
  #shopify-section-{{ id }} .ak-quad__heading {
    font-family: Amiri, serif;
    font-size: clamp(1.5rem, 2.5vw, 2.625rem);
    font-weight: 400;
    margin: 0 0 0.35em;
    line-height: 1.2;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  #shopify-section-{{ id }} .ak-quad__cta {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  #shopify-section-{{ id }} .ak-quad__cta-link:hover,
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible { opacity: 0.9; }
  #shopify-section-{{ id }} .ak-quad__cta-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-lifestyle-quad .ak-quad__grid { grid-template-columns: 1fr; }
  }
  @supports (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel[data-aspect-ratio] { aspect-ratio: var(--ak-quad-ratio, 1); }
    #shopify-section-{{ id }} .ak-quad__panel-inner { position: absolute; inset: 0; padding-bottom: 0 !important; }
  }
  @supports not (aspect-ratio: 1) {
    #shopify-section-{{ id }} .ak-quad__panel-inner { height: 0; position: relative; }
    #shopify-section-{{ id }} .ak-quad__panel-inner .ak-quad__media { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }
  }
{% endstyle %}

<section class="section is-width-wide ak-lifestyle-quad has-no-side-gutter" id="shopify-section-{{ id }}" {{ section_aria }}>
  <div class="ak-quad__grid">
    {% for block in section.blocks %}
      {% if block.type == 'panel' %}
        {% assign panel_image = block.settings.image %}
        {% assign panel_mobile_image = block.settings.mobile_image | default: panel_image %}
        {% assign panel_heading = block.settings.heading %}
        {% assign panel_cta_text = block.settings.cta_text %}
        {% assign panel_link = block.settings.link %}
        {% assign panel_alt = panel_image.alt | default: panel_heading | default: "Campaign image" %}
        {% assign panel_mobile_alt = panel_mobile_image.alt | default: panel_heading | default: "Campaign image" %}

        {% if aspect_ratio_mode == 'match_image' and panel_image != blank %}
          {% assign pw = panel_image.width %}
          {% assign ph = panel_image.height %}
          {% assign ratio_style = 'style="--ak-quad-ratio: ' | append: pw | append: ' / ' | append: ph | append: ';"' %}
          {% assign padding_pct = ph | times: 100 | divided_by: pw %}
        {% elsif aspect_ratio_mode == '3_4' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 3 / 4;"' %}
          {% assign padding_pct = 133 %}
        {% elsif aspect_ratio_mode == '8_9' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 960 / 1080;"' %}
          {% assign padding_pct = 112 %}
        {% elsif aspect_ratio_mode == '4_3' %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 4 / 3;"' %}
          {% assign padding_pct = 75 %}
        {% else %}
          {% assign ratio_style = 'style="--ak-quad-ratio: 1;"' %}
          {% assign padding_pct = 100 %}
        {% endif %}

        <div class="ak-quad__cell" {{ block.shopify_attributes }}>
          <div class="ak-quad__panel" data-aspect-ratio {{ ratio_style }}>
            <div class="ak-quad__panel-inner" style="padding-bottom: {{ padding_pct }}%;">
              <div class="ak-quad__media">
                {% if panel_image != blank %}
                  {% include 'image-element', image: panel_image, alt: panel_alt, stretch_width: true, additional_classes: 'ak-quad__img is-hidden-mobile-only' %}
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg ak-quad__img' }}
                {% endif %}
                {% if panel_mobile_image != blank %}
                  <div class="is-hidden-desktop-only">
                    {% include 'image-element', image: panel_mobile_image, alt: panel_mobile_alt, stretch_width: true, additional_classes: 'ak-quad__img' %}
                  </div>
                {% endif %}
                <div class="ak-quad__gradient" aria-hidden="true"></div>
              </div>
            </div>

            {% if panel_link != blank %}
              <a href="{{ panel_link }}" class="ak-quad__cta-link" aria-label="{{ panel_heading | default: panel_cta_text | default: 'View' }}">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta">{{ panel_cta_text }}</p>
                {% endif %}
              </a>
            {% else %}
              <div class="ak-quad__caption">
                {% if panel_heading != blank %}
                  <h2 class="ak-quad__heading">{{ panel_heading }}</h2>
                {% endif %}
                {% if panel_cta_text != blank %}
                  <p class="ak-quad__cta">{{ panel_cta_text }}</p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "AK Lifestyle Quad",
  "class": "ak-lifestyle-quad-section",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Overlay text color",
      "default": "#ffffff",
      "info": "Use white or light text. The section applies a gradient and text shadow for contrast."
    },
    {
      "type": "select",
      "id": "aspect_ratio_mode",
      "label": "Image aspect ratio",
      "default": "match_image",
      "options": [
        { "value": "match_image", "label": "Match image" },
        { "value": "1_1", "label": "Square (1:1)" },
        { "value": "3_4", "label": "Portrait (3:4)" },
        { "value": "8_9", "label": "Portrait (8:9)" },
        { "value": "4_3", "label": "Landscape (4:3)" }
      ],
      "info": "Match image uses each panel's image dimensions. Presets apply a fixed ratio to all panels."
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (for screen readers)",
      "info": "Optional. Leave blank for default 'Campaign lifestyle grid'."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Add alt in media library; panel heading used as fallback."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AK Lifestyle Quad",
      "blocks": [
        { "type": "panel", "settings": { "heading": "Dress with Intention", "cta_text": "SHOP DRESSES" } },
        { "type": "panel", "settings": { "heading": "Business Leisure", "cta_text": "SHOP WORKWEAR" } },
        { "type": "panel", "settings": { "heading": "Finishing Touches", "cta_text": "SHOP ACCESSORIES" } },
        { "type": "panel", "settings": { "heading": "Vacation Mindset", "cta_text": "SHOP RESORT" } }
      ]
    }
  ]
}
{% endschema %}
