{% comment %}
  AK Campaign landing — collection / editorial CTA: title line, richtext, primary button.
  WCAG 2.2 AA: region, correct heading semantics (or paragraph for quotes), visible focus, min touch target on CTA.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign body_rt = section.settings.body %}
{% assign btn_label = section.settings.button_label %}
{% assign btn_href = section.settings.button_link %}
{% assign heading_level = section.settings.heading_level | default: 'h2' %}
{% assign text_align = section.settings.text_alignment | default: 'center' %}
{% assign text_color = section.settings.text_color | default: '#000000' %}
{% assign bg_color = section.settings.background_color | default: '#ffffff' %}
{% assign padding_top = section.settings.padding_top | default: 48 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 48 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign max_width = section.settings.content_max_width | default: 48 %}
{% assign max_width_m = section.settings.content_max_width_mobile | default: 0 | plus: 0 %}
{% if max_width_m < 1 %}
  {% assign max_width_m = max_width %}
{% endif %}
{% assign cta_spacing = section.settings.cta_spacing | default: 28 %}
{% assign cta_spacing_m = section.settings.cta_spacing_mobile | default: 0 | plus: 0 %}
{% if cta_spacing_m < 1 %}
  {% assign cta_spacing_m = cta_spacing %}
{% endif %}
{% assign body_lh = section.settings.body_line_height | default: 165 %}
{% assign body_lh_m = section.settings.body_line_height_mobile | default: 0 | plus: 0 %}
{% if body_lh_m < 1 %}
  {% assign body_lh_m = body_lh %}
{% endif %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign btn_style = section.settings.button_style | default: 'button--primary' %}

{% capture heading_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.heading_font_family %}{% endcapture %}
{% assign heading_font_stack = heading_font_stack | strip %}
{% capture body_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.body_font_family %}{% endcapture %}
{% assign body_font_stack = body_font_stack | strip %}

{% assign heading_size = section.settings.heading_font_size | default: 36 %}
{% assign heading_weight = section.settings.heading_font_weight | default: '700' %}
{% assign body_size = section.settings.body_font_size | default: 18 %}
{% assign body_weight = section.settings.body_font_weight | default: '400' %}
{% assign heading_size_mobile = section.settings.heading_font_size_mobile | default: 0 | plus: 0 %}
{% if heading_size_mobile < 1 %}
  {% assign heading_size_mobile = heading_size %}
{% endif %}
{% assign body_size_mobile = section.settings.body_font_size_mobile | default: 0 | plus: 0 %}
{% if body_size_mobile < 1 %}
  {% assign body_size_mobile = body_size %}
{% endif %}
{% assign heading_line_2 = section.settings.heading_line_2 | strip %}
{% assign h_mw_d = section.settings.heading_max_width_desktop | default: 0 | plus: 0 %}
{% assign h_mw_m = section.settings.heading_max_width_mobile | default: 0 | plus: 0 %}
{% if h_mw_m < 1 %}
  {% assign h_mw_m = h_mw_d %}
{% endif %}
{% capture heading_h_margin %}
{% if text_align == 'left' %}
    margin-left: 0;
    margin-right: auto;
{% elsif text_align == 'right' %}
    margin-left: auto;
    margin-right: 0;
{% else %}
    margin-left: auto;
    margin-right: auto;
{% endif %}
{% endcapture %}

{% capture section_aria %}
  {% if heading != blank or heading_line_2 != blank %}
    aria-labelledby="ak-campaign-cta-heading-{{ id }}"
  {% elsif section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Shop the collection"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    background-color: {{ bg_color }};
    color: {{ text_color }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-cta__inner {
    max-width: {{ max_width }}rem;
    margin-left: auto;
    margin-right: auto;
    text-align: {{ text_align }};
  }
  #shopify-section-{{ id }} .ak-campaign-cta__heading {
    font-family: {{ heading_font_stack }};
    font-size: clamp(1.125rem, 6vw + 0.75rem, {{ heading_size }}px);
    font-weight: {{ heading_weight }};
    line-height: 1.2;
    margin: 0 0 1rem;
    color: {{ text_color }};
    width: 100%;
    max-width: none;
    overflow-wrap: break-word;
    {% if section.settings.heading_underline %}text-decoration: underline; text-underline-offset: 0.15em;{% endif %}
  }
  @media only screen and (min-width: 799px) {
    {% if h_mw_d > 0 %}
    #shopify-section-{{ id }} .ak-campaign-cta__heading {
      max-width: {{ h_mw_d }}rem;
      width: 100%;
      {{ heading_h_margin | strip }}
    }
    {% endif %}
  }
  #shopify-section-{{ id }} .ak-campaign-cta__rte {
    font-family: {{ body_font_stack }};
    font-size: {{ body_size }}px;
    font-weight: {{ body_weight }};
    line-height: {{ body_lh }}%;
    color: {{ text_color }};
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__rte p {
    margin: 0 0 1em;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__rte p:last-child {
    margin-bottom: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__rte a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__rte a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: {{ cta_spacing }}px;
    justify-content: {% if text_align == 'left' %}flex-start{% elsif text_align == 'right' %}flex-end{% else %}center{% endif %};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-cta__inner {
      max-width: {{ max_width_m }}rem;
    }
    #shopify-section-{{ id }} .ak-campaign-cta__heading {
      font-size: clamp(1.0625rem, 4.5vw + 1.75rem, {{ heading_size_mobile }}px);
    }
    {% if h_mw_m > 0 %}
    #shopify-section-{{ id }} .ak-campaign-cta__heading {
      max-width: {{ h_mw_m }}rem;
      width: 100%;
      {{ heading_h_margin | strip }}
    }
    {% endif %}
    #shopify-section-{{ id }} .ak-campaign-cta__rte {
      font-size: {{ body_size_mobile }}px;
      line-height: {{ body_lh_m }}%;
    }
    #shopify-section-{{ id }} .ak-campaign-cta__actions {
      margin-top: {{ cta_spacing_m }}px;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-cta__actions .button {
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__actions .button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-campaign-cta__heading:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
{% endstyle %}

<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-campaign-cta-section {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="container">
    <div class="ak-campaign-cta__inner">
      {% if heading != blank or heading_line_2 != blank %}
        {% if heading_line_2 != blank %}
          {% capture heading_html %}{% if heading != blank %}{{ heading | strip | escape }}{% endif %}{% if heading != blank %}<br aria-hidden="true">{% endif %}{{ heading_line_2 | escape }}{% endcapture %}
        {% else %}
          {% capture heading_html %}{{ heading | strip | escape | newline_to_br }}{% endcapture %}
        {% endif %}
        {% if heading_level == 'p' %}
          <p class="ak-campaign-cta__heading" id="ak-campaign-cta-heading-{{ id }}">{{ heading_html }}</p>
        {% elsif heading_level == 'h1' %}
          <h1 class="ak-campaign-cta__heading" id="ak-campaign-cta-heading-{{ id }}">{{ heading_html }}</h1>
        {% elsif heading_level == 'h3' %}
          <h3 class="ak-campaign-cta__heading" id="ak-campaign-cta-heading-{{ id }}">{{ heading_html }}</h3>
        {% else %}
          <h2 class="ak-campaign-cta__heading" id="ak-campaign-cta-heading-{{ id }}">{{ heading_html }}</h2>
        {% endif %}
      {% endif %}
      {% if body_rt != blank %}
        <div class="ak-campaign-cta__rte rte">
          {{ body_rt }}
        </div>
      {% endif %}
      {% if btn_label != blank and btn_href != blank %}
        <div class="ak-campaign-cta__actions">
          {% if section.settings.button_new_tab %}
            {% capture btn_attr %}target="_blank" rel="noopener noreferrer"{% endcapture %}
            {% include 'button', label: btn_label, href: btn_href, style: btn_style, type: 'link', attribute: btn_attr %}
          {% else %}
            {% include 'button', label: btn_label, href: btn_href, style: btn_style, type: 'link' %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Campaign CTA",
  "class": "ak-campaign-cta-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Editorial block with heading, rich text, and a button (e.g. shop the collection). Set the button link to your campaign collection."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (line 1)",
      "default": "Anne Klein Spring-Summer 2026"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading (line 2, optional)",
      "default": "",
      "info": "Second line of the same heading (e.g. Spring-Summer 2026). Leave blank for one line. Pair with Title max width (mobile) to tune wrapping on phones."
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Title element",
      "default": "h2",
      "info": "Use Paragraph for pull quotes or lines that should not be a document heading (better for accessibility).",
      "options": [
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "p", "label": "Paragraph (quote / not a heading)" }
      ]
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Explore the full campaign and shop new arrivals from the season.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP THE COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Usually a collection or campaign landing URL."
    },
    {
      "type": "checkbox",
      "id": "button_new_tab",
      "label": "Open button link in new tab",
      "default": false
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "button--primary",
      "options": [
        { "value": "button--primary", "label": "Primary" },
        { "value": "button--secondary", "label": "Secondary" },
        { "value": "button--link-style", "label": "Link style" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Max content width (desktop)",
      "min": 28,
      "max": 64,
      "step": 1,
      "default": 48,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "content_max_width_mobile",
      "label": "Max content width (mobile)",
      "min": 0,
      "max": 64,
      "step": 1,
      "default": 0,
      "unit": "rem",
      "info": "0 = same as desktop."
    },
    {
      "type": "header",
      "content": "Title max width (optional)"
    },
    {
      "type": "range",
      "id": "heading_max_width_desktop",
      "label": "Title max width (desktop)",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 0,
      "unit": "rem",
      "info": "0 = full width of the content column. Narrow this to wrap the title on more lines on large screens."
    },
    {
      "type": "range",
      "id": "heading_max_width_mobile",
      "label": "Title max width (mobile)",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 0,
      "unit": "rem",
      "info": "0 = same as desktop title max width above. Set a smaller value (e.g. 10–16) at ≤798px to balance a two-line title independently from desktop."
    },
    {
      "type": "range",
      "id": "cta_spacing",
      "label": "Space above button (desktop)",
      "min": 8,
      "max": 64,
      "step": 4,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "cta_spacing_mobile",
      "label": "Space above button (mobile)",
      "min": 0,
      "max": 64,
      "step": 4,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop."
    },
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Fonts — heading"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font",
      "default": "amiri",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Title / heading size (desktop max)",
      "min": 20,
      "max": 72,
      "step": 1,
      "default": 36,
      "unit": "px",
      "info": "Caps the largest size on wide screens. Fluid between a minimum and this cap so narrow viewports still scale."
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Title / heading size (mobile max)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop max. On ≤798px this caps a fluid size (scales up until it hits this value)."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "header",
      "content": "Fonts — body"
    },
    {
      "type": "select",
      "id": "body_font_family",
      "label": "Body font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body copy size (desktop)",
      "min": 14,
      "max": 36,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size_mobile",
      "label": "Body copy size (mobile)",
      "min": 0,
      "max": 36,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop body size. Applied at ≤798px."
    },
    {
      "type": "select",
      "id": "body_font_weight",
      "label": "Body font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "body_line_height",
      "label": "Body line height (desktop)",
      "min": 130,
      "max": 200,
      "step": 5,
      "default": 165,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "body_line_height_mobile",
      "label": "Body line height (mobile)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 0,
      "unit": "%",
      "info": "0 = same as desktop."
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (screen readers)",
      "info": "Optional if heading is visible."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Padding top (mobile)"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Padding bottom (mobile)"
    }
  ],
  "presets": [
    {
      "name": "AK Campaign CTA",
      "category": "Custom"
    }
  ]
}
{% endschema %}
