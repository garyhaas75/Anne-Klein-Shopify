{% comment %}
  Homepage sale / promo capsule — pattern background + double-outline oval + type + CTA.
  Ported from isaac-mizrahi-shopify-theme (sections/index__sale-banner.liquid). Isaac SS26 refs: ElBlsfaoybShYgXX41ly3S — desktop `1:4`, mobile `1:15`.
  AK Homepage 2026 sale treatment: figma.com/design/7xTpsAXro8e8zKFbWnm5Dd — nodes `1217:20740` (20% Off Sitewide), `1217:20741` (Mother’s Day Gifting Sale): Amiri, ~90px display / 80px leading, tuned letter/word spacing.
  WCAG: semantic headings, visible focus on CTA, sufficient contrast (verify capsule vs text in editor).
{% endcomment %}

{% assign id = section.id %}
{% assign bg_image = section.settings.background_image %}
{% assign bg_mobile = section.settings.background_image_mobile %}
{% assign bg_color = section.settings.background_color %}
{% assign capsule_bg = section.settings.capsule_background %}
{% assign capsule_border = section.settings.capsule_border_color %}
{% assign text_color = section.settings.text_color %}
{% assign headline_color = section.settings.headline_color %}
{% assign cta_label_color = section.settings.cta_label_color %}
{% assign eyebrow = section.settings.eyebrow %}
{% assign line1 = section.settings.headline_line_1 %}
{% assign line2 = section.settings.headline_line_2 %}
{% assign code_prefix = section.settings.promo_code_prefix %}
{% assign code_value = section.settings.promo_code_value %}
{% assign cta_label = section.settings.cta_label %}
{% assign cta_url = section.settings.cta_link %}
{% assign sr_title = section.settings.section_title %}
{% assign sr_fallback = section.settings.section_aria_label %}

{% if section.settings.eyebrow_font_family == 'amiri' or section.settings.headline_font_family == 'amiri' or section.settings.code_font_family == 'amiri' or section.settings.cta_font_family == 'amiri' %}
  {% render 'ak-campaign-fonts' %}
{% endif %}
{% capture ak_sale_ff_eyebrow %}{% render 'ak-campaign-font-stack', font_key: section.settings.eyebrow_font_family %}{% endcapture %}
{% capture ak_sale_ff_headline %}{% render 'ak-campaign-font-stack', font_key: section.settings.headline_font_family %}{% endcapture %}
{% capture ak_sale_ff_code %}{% render 'ak-campaign-font-stack', font_key: section.settings.code_font_family %}{% endcapture %}
{% capture ak_sale_ff_cta %}{% render 'ak-campaign-font-stack', font_key: section.settings.cta_font_family %}{% endcapture %}

{% comment %} Inner border vs outer outline ring. New: capsule_inner_border_width + capsule_outer_ring_width. Legacy: capsule_inner_w (optional) from old capsule_border_width. {% endcomment %}
{% assign capsule_inner_w = section.settings.capsule_inner_border_width %}
{% assign capsule_outer_w = section.settings.capsule_outer_ring_width %}
{% if capsule_inner_w == blank %}
  {% assign capsule_inner_w = section.settings.capsule_border_width %}
{% endif %}
{% if capsule_inner_w == blank %}
  {% assign capsule_inner_w = 1 %}
{% endif %}
{% if capsule_outer_w == blank %}
  {% assign capsule_outer_w = section.settings.capsule_border_width %}
{% endif %}
{% if capsule_outer_w == blank %}
  {% assign capsule_outer_w = 1 %}
{% endif %}

{% comment %} Map editor “fit” to CSS background-size (not object-fit on <img> — avoids global img rules in styles.scss.liquid and sizing quirks). {% endcomment %}
{% case section.settings.background_image_fit %}
  {% when 'fill' %}
    {% assign sale_bg_size = '100% 100%' %}
  {% when 'contain' %}
    {% assign sale_bg_size = 'contain' %}
  {% when 'none' %}
    {% assign sale_bg_size = 'auto' %}
  {% when 'scale-down' %}
    {% assign sale_bg_size = 'contain' %}
  {% else %}
    {% assign sale_bg_size = 'cover' %}
{% endcase %}
{% assign sale_bg_pos = section.settings.background_image_position | default: 'center' %}
{% if bg_mobile != blank %}
  {% assign sale_bg_mobile_img = bg_mobile %}
{% else %}
  {% assign sale_bg_mobile_img = bg_image %}
{% endif %}

{% comment %} Mobile stack spacing: 0 uses the matching desktop slider for that row {% endcomment %}
{% assign cap_gap_eh_m = section.settings.capsule_gap_eyebrow_headline_mobile %}
{% if cap_gap_eh_m == 0 %}{% assign cap_gap_eh_m = section.settings.capsule_gap_eyebrow_headline_desktop %}{% endif %}
{% assign cap_gap_hc_m = section.settings.capsule_gap_headline_to_code_mobile %}
{% if cap_gap_hc_m == 0 %}{% assign cap_gap_hc_m = section.settings.capsule_gap_headline_to_code_desktop %}{% endif %}
{% assign cap_gap_cc_m = section.settings.capsule_gap_code_to_cta_mobile %}
{% if cap_gap_cc_m == 0 %}{% assign cap_gap_cc_m = section.settings.capsule_gap_code_to_cta_desktop %}{% endif %}
{% assign cap_gap_hl_m = section.settings.capsule_gap_headline_lines_mobile %}
{% if cap_gap_hl_m == 0 %}{% assign cap_gap_hl_m = section.settings.capsule_gap_headline_lines_desktop %}{% endif %}
{% assign cap_stack_pt_m = section.settings.capsule_stack_pad_top_mobile %}
{% if cap_stack_pt_m == 0 %}{% assign cap_stack_pt_m = section.settings.capsule_stack_pad_top_desktop %}{% endif %}
{% assign cap_stack_pb_m = section.settings.capsule_stack_pad_bottom_mobile %}
{% if cap_stack_pb_m == 0 %}{% assign cap_stack_pb_m = section.settings.capsule_stack_pad_bottom_desktop %}{% endif %}

{% capture sale_aria %}
  {% if sr_title != blank %}
    aria-label="{{ sr_title | escape }}"
  {% elsif line1 != blank or line2 != blank or eyebrow != blank %}
    aria-labelledby="sale-banner-heading-{{ id }}"
  {% elsif sr_fallback != blank %}
    aria-label="{{ sr_fallback | escape }}"
  {% else %}
    aria-label="Promotion"
  {% endif %}
{% endcapture %}

{% style %}
  /*
    Layout chain (homepage):
    - templates/index.liquid: <main class="shopify-section index-sections">
    - assets/styles.scss.liquid: .index-sections { display:flex; flex-wrap:wrap; justify-content:center; width:100%; }
    - Child section wrappers are flex items (default flex: 0 1 auto; min-width:auto). With justify-content:center, any flex line
      shorter than the main inner width is centered → equal side gaps (often read as “white gutters” beside the band).
    Fix: (1) force this section to occupy a full flex row; (2) viewport breakout (same math as snippets/content.*.builder.liquid)
    so the band is not limited by a narrower ancestor (e.g. .is-beside-vertical-header width 80% in styles.scss.liquid ~13644).
  */
  #shopify-section-{{ id }} {
    flex: 0 0 100%;
    min-width: 0;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    position: relative;
    padding-top: {{ section.settings.section_spacing_top }}px;
    padding-bottom: {{ section.settings.section_spacing_bottom }}px;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ section.settings.section_spacing_top_mobile }}px;
      padding-bottom: {{ section.settings.section_spacing_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .sale-banner-section {
    display: block;
    width: 100%;
  }
  /*
    Background color + background image MUST live on the same element (.sale-banner).
    If the image lived on a separate absolutely positioned child, any box mismatch (flex, rounding, stacking)
    exposed the parent’s solid background — looked like “color fills but image doesn’t” (e.g. one vertical strip).
  */
  #shopify-section-{{ id }} .sale-banner {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: {{ section.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ bg_color }};
    background-repeat: no-repeat;
    background-size: {{ sale_bg_size }};
    background-position: {{ sale_bg_pos }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner {
      min-height: {{ section.settings.min_height_mobile }}px;
    }
  }
  {% if bg_image != blank %}
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .sale-banner {
      background-image: url('{{ bg_image | image_url: width: 2400 }}');
    }
  }
  {% endif %}
  {% if sale_bg_mobile_img != blank %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner {
      background-image: url('{{ sale_bg_mobile_img | image_url: width: 2000 }}');
    }
  }
  {% endif %}
  #shopify-section-{{ id }} .sale-banner__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 100%;
    padding: {{ section.settings.padding_top }}px 1.25rem {{ section.settings.padding_bottom }}px;
    display: flex;
    justify-content: center;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .sale-banner__capsule {
    width: 100%;
    max-width: {{ section.settings.capsule_max_width_percent }}%;
    margin: 0 auto;
    padding-top: {{ section.settings.capsule_padding_top }}px;
    padding-bottom: {{ section.settings.capsule_padding_bottom }}px;
    padding-left: {{ section.settings.capsule_padding_left }}px;
    padding-right: {{ section.settings.capsule_padding_right }}px;
    background-color: {{ capsule_bg }};
    {% if capsule_inner_w > 0 %}
    border: {{ capsule_inner_w }}px solid {{ capsule_border }};
    {% else %}
    border: none;
    {% endif %}
    {% if capsule_outer_w > 0 %}
    outline: {{ capsule_outer_w }}px solid {{ capsule_border }};
    outline-offset: {{ section.settings.capsule_ring_gap }}px;
    {% else %}
    outline: none;
    {% endif %}
    {% case section.settings.capsule_shape %}
      {% when 'ellipse' %}
    border-radius: 50%;
      {% when 'pill' %}
    border-radius: 9999px;
      {% when 'rounded' %}
    border-radius: {{ section.settings.capsule_corner_radius }}px;
    {% endcase %}
    text-align: {{ section.settings.text_alignment }};
    color: {{ text_color }};
    box-sizing: border-box;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
  }
  @media only screen and (min-width: 799px) {
    {% if section.settings.capsule_min_height_desktop > 0 %}
    #shopify-section-{{ id }} .sale-banner__capsule {
      min-height: {{ section.settings.capsule_min_height_desktop }}px;
    }
    {% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__capsule {
      {% if section.settings.capsule_max_width_mobile > 0 %}
      max-width: {{ section.settings.capsule_max_width_mobile }}%;
      {% endif %}
      padding-top: {{ section.settings.capsule_padding_top_mobile }}px;
      padding-bottom: {{ section.settings.capsule_padding_bottom_mobile }}px;
      padding-left: {{ section.settings.capsule_padding_left_mobile }}px;
      padding-right: {{ section.settings.capsule_padding_right_mobile }}px;
      {% if section.settings.capsule_min_height_mobile > 0 %}
      min-height: {{ section.settings.capsule_min_height_mobile }}px;
      {% endif %}
    }
  }
  #shopify-section-{{ id }} .sale-banner__capsule-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    padding-top: {{ section.settings.capsule_stack_pad_top_desktop }}px;
    padding-bottom: {{ section.settings.capsule_stack_pad_bottom_desktop }}px;
    transform: translateY({{ section.settings.capsule_content_offset_desktop }}px);
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__capsule-stack {
      padding-top: {{ cap_stack_pt_m }}px;
      padding-bottom: {{ cap_stack_pb_m }}px;
      transform: translateY({{ section.settings.capsule_content_offset_mobile }}px);
    }
  }
  #shopify-section-{{ id }} .sale-banner__eyebrow {
    margin: 0 0 {{ section.settings.capsule_gap_eyebrow_headline_desktop }}px;
    font-family: {{ ak_sale_ff_eyebrow | strip }};
    font-weight: {{ section.settings.eyebrow_font_weight | default: '600' }};
    font-style: normal;
    font-size: {{ section.settings.eyebrow_size }}px;
    line-height: {{ section.settings.eyebrow_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}px;
    text-transform: {{ section.settings.eyebrow_text_transform }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__eyebrow {
      margin-bottom: {{ cap_gap_eh_m }}px;
      {% if section.settings.eyebrow_size_mobile > 0 %}font-size: {{ section.settings.eyebrow_size_mobile }}px;{% endif %}
      {% if section.settings.eyebrow_line_height_mobile > 0 %}line-height: {{ section.settings.eyebrow_line_height_mobile | divided_by: 100.0 }};{% endif %}
      {% if section.settings.eyebrow_letter_spacing_mobile != 0 %}letter-spacing: {{ section.settings.eyebrow_letter_spacing_mobile }}px;{% endif %}
    }
  }
  #shopify-section-{{ id }} .sale-banner__headline {
    color: {{ headline_color }};
    margin: 0 0 {{ section.settings.capsule_gap_headline_to_code_desktop }}px;
    font-family: {{ ak_sale_ff_headline | strip }};
    font-weight: {{ section.settings.headline_font_weight | default: '700' }};
    font-style: normal;
    {% if section.settings.headline_line_height_px_desktop > 0 %}
    line-height: {{ section.settings.headline_line_height_px_desktop }}px;
    {% else %}
    line-height: {{ section.settings.headline_line_height | divided_by: 100.0 }};
    {% endif %}
    letter-spacing: {{ section.settings.headline_letter_spacing }}px;
    word-spacing: {{ section.settings.headline_word_spacing_desktop }}px;
    text-transform: {{ section.settings.headline_text_transform }};
    font-size: {{ section.settings.headline_size_desktop }}px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    {% case section.settings.text_alignment %}
      {% when 'left' %}justify-content: flex-start;
      {% when 'right' %}justify-content: flex-end;
      {% else %}justify-content: center;
    {% endcase %}
    align-items: baseline;
    row-gap: 0;
    column-gap: {{ section.settings.capsule_gap_headline_lines_desktop }}px;
    max-width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__headline {
      margin-bottom: {{ cap_gap_hc_m }}px;
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      min-width: 0;
      row-gap: {{ cap_gap_hl_m }}px;
      column-gap: 0;
      font-size: {{ section.settings.headline_size_mobile }}px;
      {% if section.settings.headline_line_height_px_mobile > 0 %}
      line-height: {{ section.settings.headline_line_height_px_mobile }}px;
      {% elsif section.settings.headline_line_height_mobile > 0 %}
      line-height: {{ section.settings.headline_line_height_mobile | divided_by: 100.0 }};
      {% elsif section.settings.headline_line_height_px_desktop > 0 %}
      line-height: {{ section.settings.headline_line_height_px_desktop }}px;
      {% else %}
      line-height: {{ section.settings.headline_line_height | divided_by: 100.0 }};
      {% endif %}
      {% if section.settings.headline_letter_spacing_mobile != 0 %}letter-spacing: {{ section.settings.headline_letter_spacing_mobile }}px;{% else %}letter-spacing: 0px;{% endif %}
      word-spacing: {{ section.settings.headline_word_spacing_mobile }}px;
      max-width: 100%;
    }
    {% if section.settings.text_alignment_mobile != 'inherit' %}
    #shopify-section-{{ id }} .sale-banner__capsule {
      text-align: {{ section.settings.text_alignment_mobile }};
    }
    {% endif %}
  }
  #shopify-section-{{ id }} .sale-banner__code {
    margin: 0 0 {{ section.settings.capsule_gap_code_to_cta_desktop }}px;
    font-family: {{ ak_sale_ff_code | strip }};
    font-weight: {{ section.settings.code_font_weight | default: '400' }};
    font-style: normal;
    font-size: {{ section.settings.code_size }}px;
    line-height: {{ section.settings.code_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.code_letter_spacing }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__code {
      margin-bottom: {{ cap_gap_cc_m }}px;
      {% if section.settings.code_size_mobile > 0 %}font-size: {{ section.settings.code_size_mobile }}px;{% endif %}
      {% if section.settings.code_line_height_mobile > 0 %}line-height: {{ section.settings.code_line_height_mobile | divided_by: 100.0 }};{% endif %}
      {% if section.settings.code_letter_spacing_mobile != 0 %}letter-spacing: {{ section.settings.code_letter_spacing_mobile }}px;{% endif %}
    }
  }
  #shopify-section-{{ id }} .sale-banner__code strong {
    font-weight: 600;
  }
  #shopify-section-{{ id }} .sale-banner__cta {
    display: inline-block;
    font-family: {{ ak_sale_ff_cta | strip }};
    font-weight: {{ section.settings.cta_font_weight | default: '600' }};
    font-style: normal;
    font-synthesis: none;
    font-size: {{ section.settings.cta_size_desktop }}px !important;
    line-height: {{ section.settings.cta_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.cta_letter_spacing }}px;
    {% if section.settings.cta_match_x_height %}
    font-size-adjust: {{ section.settings.cta_x_height_ratio | divided_by: 100.0 }};
    {% endif %}
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    color: {{ cta_label_color }};
    padding: 0.35em 0.5em;
    margin: 0 -0.5em;
    border-radius: 2px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .sale-banner__cta {
      font-size: {{ section.settings.cta_size_mobile }}px !important;
      {% if section.settings.cta_line_height_mobile > 0 %}line-height: {{ section.settings.cta_line_height_mobile | divided_by: 100.0 }};{% endif %}
      {% if section.settings.cta_letter_spacing_mobile != 0 %}letter-spacing: {{ section.settings.cta_letter_spacing_mobile }}px;{% endif %}
    }
  }
  #shopify-section-{{ id }} .sale-banner__cta:focus {
    outline: none;
  }
  #shopify-section-{{ id }} .sale-banner__cta:focus-visible {
    outline: 2px solid {{ cta_label_color }};
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .sale-banner__cta {
      transition: none;
    }
  }
{% endstyle %}

<section
  class="sale-banner-section {{ section.settings.css_class }}"
  {{ sale_aria }}
>
  <div class="sale-banner">
    <div class="sale-banner__inner">
      <div class="sale-banner__capsule">
        <div class="sale-banner__capsule-stack">
        {% if eyebrow != blank %}
          {% if line1 != blank or line2 != blank %}
            <p class="sale-banner__eyebrow">{{ eyebrow | escape }}</p>
          {% else %}
            <h2 class="sale-banner__eyebrow" id="sale-banner-heading-{{ id }}">{{ eyebrow | escape }}</h2>
          {% endif %}
        {% endif %}

        {% if line1 != blank or line2 != blank %}
          <h2
            class="sale-banner__headline"
            id="sale-banner-heading-{{ id }}"
            {% if line1 != blank and line2 != blank %}aria-label="{{ line1 | escape }} {{ line2 | escape }}"{% endif %}
          >
            {% if line1 != blank %}
              <span class="sale-banner__hl sale-banner__hl--1" {% if line2 != blank %}aria-hidden="true"{% endif %}>{{ line1 | escape }}</span>
            {% endif %}
            {% if line2 != blank %}
              <span class="sale-banner__hl sale-banner__hl--2" {% if line1 != blank %}aria-hidden="true"{% endif %}>{{ line2 | escape }}</span>
            {% endif %}
          </h2>
        {% endif %}

        {% if code_prefix != blank or code_value != blank %}
          <p class="sale-banner__code">
            {% if code_prefix != blank %}{{ code_prefix | escape }}{% endif %}
            {% if code_value != blank %}<strong>{{ code_value | escape }}</strong>{% endif %}
          </p>
        {% endif %}

        {% if cta_label != blank and cta_url != blank %}
          <a href="{{ cta_url }}" class="sale-banner__cta" {% if section.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ cta_label | escape }}
          </a>
        {% elsif cta_label != blank %}
          <span class="sale-banner__cta" role="text">{{ cta_label | escape }}</span>
        {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% comment %}
  CTA copy (cta_label): do not add a schema default or preset value.
  Shopify disallows blank text defaults; any non-blank default repopulates the CTA on the storefront.
  Merchants opt in in the editor. After git pull --rebase, verify conflict resolutions did not restore old preset defaults.
{% endcomment %}
{% schema %}
{
  "name": "Sale banner",
  "class": "index-sale-banner-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Promo strip with patterned background and centered capsule (Spring SS26 sale band). Search: sale, promo, banner."
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section name (optional)",
      "info": "If set, sets the section region aria-label for assistive tech (in addition to visible headings)."
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (fallback)",
      "info": "Used when title and headlines are empty."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Falls back to desktop image if empty."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color (fallback)",
      "default": "#5c3d5c"
    },
    {
      "type": "select",
      "id": "background_image_fit",
      "label": "Background image fit",
      "default": "cover",
      "info": "Uses CSS background-size (not an <img>). Cover = zoom/crop to band (best for patterns). Fill = true stretch (100%×100%, may look “squashed”). Contain = whole image visible (may letterbox). If the band still has side gaps, see theme doc Sale banner checklist (flex parent / editor frame).",
      "options": [
        { "value": "cover", "label": "Cover (fill band, crop edges)" },
        { "value": "contain", "label": "Contain (full image, may letterbox)" },
        { "value": "fill", "label": "Fill (stretch non-proportionally)" },
        { "value": "none", "label": "None (natural size, may clip)" },
        { "value": "scale-down", "label": "Scale down" }
      ]
    },
    {
      "type": "select",
      "id": "background_image_position",
      "label": "Background image position",
      "default": "center",
      "info": "Focal point when the image is cropped (Cover) or letterboxed (Contain).",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Capsule"
    },
    {
      "type": "select",
      "id": "capsule_shape",
      "label": "Capsule shape",
      "default": "ellipse",
      "info": "Ellipse: curvature scales with width (wide = flat oval). Pill: semicircle ends. Rounded: custom corner radius.",
      "options": [
        { "value": "ellipse", "label": "Ellipse (flat oval)" },
        { "value": "pill", "label": "Pill (semicircle ends)" },
        { "value": "rounded", "label": "Rounded rectangle" }
      ]
    },
    {
