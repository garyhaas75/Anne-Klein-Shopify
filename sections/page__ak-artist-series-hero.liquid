{% comment %}
  AK Artist Series — hero band.
  Figma file: 0kmSuSntT1RaS2ElBXMw25 (AK_Homepage-2026)
  Frames: AK_Artist Series_Desktop 351:1393, AK_Artist Series_Mobile 333:422
  Composition: full-bleed photo (butterflies + AK signature baked in) with top-left
  “Anne Klein Artist Series” as live text, large eyebrow + artist name overlay
  that overlaps a bottom white band, and a centered AK logo inside that band.
  WCAG 2.2 AA: region landmark, single h1 by default, alt on every image,
  focus-visible, prefers-reduced-motion respected.
{% endcomment %}

{% if section.settings.wordmark_font_family == 'amiri' or section.settings.eyebrow_font_family == 'amiri' or section.settings.name_font_family == 'amiri' %}
  {% render 'ak-campaign-fonts' %}
{% endif %}

{% assign id = section.id %}
{% assign image = section.settings.image %}
{% assign mobile_image = section.settings.mobile_image | default: image %}
{% assign image_alt = section.settings.image_alt %}
{% assign wordmark_text = section.settings.wordmark_text | strip %}
{% assign wordmark_color = section.settings.wordmark_color | default: '#ffe1e3' %}
{% assign wordmark_size = section.settings.wordmark_font_size | default: 22 %}
{% assign wordmark_size_mobile = section.settings.wordmark_font_size_mobile | default: 0 | plus: 0 %}
{% if wordmark_size_mobile < 1 %}
  {% assign wordmark_size_mobile = wordmark_size %}
{% endif %}
{% assign wordmark_weight = section.settings.wordmark_font_weight | default: '400' %}
{% capture wordmark_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.wordmark_font_family %}{% endcapture %}
{% assign wordmark_font_stack = wordmark_font_stack | strip %}
{% assign ak_logo = section.settings.ak_logo %}
{% assign ak_logo_alt = section.settings.ak_logo_alt | default: 'Anne Klein' %}
{% assign eyebrow = section.settings.eyebrow %}
{% assign artist_name = section.settings.artist_name %}
{% assign heading_level = section.settings.heading_level | default: 'h1' %}
{% assign overlay_text_color = section.settings.overlay_text_color | default: '#ffffff' %}
{% assign band_color = section.settings.band_color | default: '#ffffff' %}
{% assign band_text_color = section.settings.band_text_color | default: '#000000' %}
{% assign image_min_height = section.settings.image_min_height | default: 720 %}
{% assign image_min_height_mobile = section.settings.image_min_height_mobile | default: 480 %}
{% assign band_height = section.settings.band_height | default: 220 %}
{% assign band_height_mobile = section.settings.band_height_mobile | default: 160 %}
{% assign overlay_overlap = section.settings.overlay_overlap | default: 96 %}
{% assign overlay_overlap_mobile = section.settings.overlay_overlap_mobile | default: 56 %}
{% assign wordmark_max_width = section.settings.wordmark_max_width | default: 320 %}
{% assign wordmark_max_width_mobile = section.settings.wordmark_max_width_mobile | default: 180 %}
{% assign wordmark_offset_top = section.settings.wordmark_offset_top | default: 32 %}
{% assign wordmark_offset_left = section.settings.wordmark_offset_left | default: 32 %}
{% assign ak_logo_max_width = section.settings.ak_logo_max_width | default: 320 %}
{% assign ak_logo_max_width_mobile = section.settings.ak_logo_max_width_mobile | default: 200 %}
{% assign image_object_position = section.settings.image_object_position | default: 'center' %}
{% assign image_fill_and_crop = section.settings.image_fill_and_crop %}
{% assign overlay_name_color = section.settings.overlay_name_color | default: '#000000' %}
{% assign has_hero_image = false %}
{% if image != blank or mobile_image != blank %}
  {% assign has_hero_image = true %}
{% endif %}

{% capture eyebrow_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.eyebrow_font_family %}{% endcapture %}
{% assign eyebrow_font_stack = eyebrow_font_stack | strip %}
{% capture name_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.name_font_family %}{% endcapture %}
{% assign name_font_stack = name_font_stack | strip %}

{% assign eyebrow_size = section.settings.eyebrow_font_size | default: 24 %}
{% assign eyebrow_size_mobile = section.settings.eyebrow_font_size_mobile | default: 0 | plus: 0 %}
{% if eyebrow_size_mobile < 1 %}
  {% assign eyebrow_size_mobile = eyebrow_size %}
{% endif %}
{% assign eyebrow_weight = section.settings.eyebrow_font_weight | default: '700' %}
{% assign name_size = section.settings.name_font_size | default: 144 %}
{% assign name_size_mobile = section.settings.name_font_size_mobile | default: 0 | plus: 0 %}
{% if name_size_mobile < 1 %}
  {% assign name_size_mobile = name_size %}
{% endif %}
{% assign name_weight = section.settings.name_font_weight | default: '400' %}
{% assign name_letter_spacing = section.settings.name_letter_spacing | default: -4 %}

{% capture section_aria %}
  {% if artist_name != blank %}
    aria-labelledby="ak-artist-series-hero-name-{{ id }}"
  {% else %}
    aria-label="Anne Klein Artist Series"
  {% endif %}
{% endcapture %}

{% assign img_alt_resolved = image_alt | default: artist_name | default: 'Anne Klein Artist Series featured artist' %}

{% style %}
  /*
    Theme Flex: `.section.is-width-wide` = full content width.
    Default `natural` layout: image keeps its aspect ratio (width 100%, height auto)
    so nothing is cropped; band + eyebrow/name are absolutely positioned over the photo.
    Optional `crop` layout: fixed min-height + object-fit cover (fills stage, crops image).
    Artist name uses overlay_name_color so it stays readable on the white band (not white-on-white).

    Background images use image-element back_to_basics mode so Lazysizes’ aspect-ratio helper
    (data-aspectratio + padded .image-element__wrap) does not crop the uploaded asset.
  */
  #shopify-section-{{ id }} {
    display: block;
    width: 100%;
    max-width: none;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero {
    width: 100%;
    max-width: 100%;
    overflow: visible;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage {
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  /* --- Natural height: show full photo (no cover crop) --- */
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural {
    overflow: visible;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder {
    min-height: {{ image_min_height }}px;
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder {
      min-height: {{ image_min_height_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media {
    position: relative;
    z-index: 0;
    width: 100%;
    line-height: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media .image-element__wrap {
    position: relative !important;
    inset: auto !important;
    width: 100% !important;
    height: auto !important;
    max-width: 100% !important;
    margin: 0 !important;
    overflow: visible !important;
    padding-bottom: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media img,
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media .placeholder-svg {
    display: block;
    width: 100% !important;
    height: auto !important;
    max-width: 100%;
    vertical-align: middle;
    position: relative !important;
    object-fit: unset !important;
    object-position: unset !important;
    min-height: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only {
    position: relative;
    width: 100%;
    inset: auto;
    height: auto;
  }
  /* --- Crop-fill: fixed min-height + cover (optional) --- */
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
    min-height: {{ image_min_height }}px;
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
      min-height: {{ image_min_height_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    line-height: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    margin: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media img,
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media .placeholder-svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ image_object_position }};
    min-height: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media > .is-hidden-desktop-only {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark {
    position: absolute;
    top: {{ wordmark_offset_top }}px;
    left: {{ wordmark_offset_left }}px;
    width: min({{ wordmark_max_width }}px, 52vw);
    max-width: 85%;
    z-index: 4;
    margin: 0;
    padding: 0;
    font-family: {{ wordmark_font_stack }};
    font-size: {{ wordmark_size }}px;
    font-weight: {{ wordmark_weight }};
    line-height: {{ section.settings.wordmark_line_height | default: 120 }}%;
    letter-spacing: {{ section.settings.wordmark_letter_spacing | default: 0 }}px;
    color: {{ wordmark_color }};
    white-space: pre-line;
    overflow-wrap: break-word;
    {% if section.settings.wordmark_uppercase %}text-transform: uppercase; letter-spacing: 0.08em;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__wordmark {
      top: 16px;
      left: 16px;
      width: min({{ wordmark_max_width_mobile }}px, 85vw);
      max-width: 90%;
      font-size: {{ wordmark_size_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__band {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    height: {{ band_height }}px;
    min-height: 0;
    background-color: {{ band_color }};
    color: {{ band_text_color }};
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.5rem;
    pointer-events: none;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__band {
      height: {{ band_height_mobile }}px;
      padding: 1rem;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__ak-logo {
    display: block;
    width: min({{ ak_logo_max_width }}px, 60vw);
    height: auto;
    max-width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__ak-logo {
      width: min({{ ak_logo_max_width_mobile }}px, 70vw);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc({{ band_height }}px - {{ overlay_overlap }}px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 1.5rem;
    z-index: 3;
    pointer-events: none;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__overlay {
      bottom: calc({{ band_height_mobile }}px - {{ overlay_overlap_mobile }}px);
      padding: 0 1rem;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow {
    font-family: {{ eyebrow_font_stack }};
    font-size: {{ eyebrow_size }}px;
    font-weight: {{ eyebrow_weight }};
    line-height: 1.2;
    margin: 0 0 0.5em;
    color: {{ overlay_text_color }};
    {% if section.settings.eyebrow_uppercase %}text-transform: uppercase; letter-spacing: 0.12em;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow {
      font-size: {{ eyebrow_size_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__name {
    font-family: {{ name_font_stack }};
    font-size: clamp(2.5rem, 11vw, {{ name_size }}px);
    font-weight: {{ name_weight }};
    line-height: 1;
    letter-spacing: {{ name_letter_spacing }}px;
    margin: 0;
    overflow-wrap: break-word;
    max-width: 100%;
    color: {{ overlay_name_color }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__name {
      font-size: clamp(2rem, 12vw, {{ name_size_mobile }}px);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__name:focus-visible,
  #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-artist-series-hero,
    #shopify-section-{{ id }} .ak-artist-series-hero * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<section
  class="section is-width-wide ak-artist-series-hero-section has-no-side-gutter"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="ak-artist-series-hero">
    <div class="ak-artist-series-hero__stage{% if image_fill_and_crop %} ak-artist-series-hero__stage--crop{% else %} ak-artist-series-hero__stage--natural{% endif %}{% unless has_hero_image %} ak-artist-series-hero__stage--placeholder{% endunless %}">
      <div class="ak-artist-series-hero__media">
        {% if image != blank %}
          {% include 'image-element', image: image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'is-hidden-mobile-only ak-artist-series-hero__img' %}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg is-hidden-mobile-only' }}
        {% endif %}
        {% if mobile_image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: mobile_image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'ak-artist-series-hero__img' %}
          </div>
        {% elsif image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'ak-artist-series-hero__img' %}
          </div>
        {% else %}
          <div class="is-hidden-desktop-only">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>

      <div class="ak-artist-series-hero__band">
        {% if ak_logo != blank %}
          <img
            class="ak-artist-series-hero__ak-logo"
            src="{{ ak_logo | img_url: '800x' }}"
            alt="{{ ak_logo_alt | escape }}"
            loading="lazy"
            width="{{ ak_logo.width }}"
            height="{{ ak_logo.height }}"
          >
        {% endif %}
      </div>

      {% if eyebrow != blank or artist_name != blank %}
        <div class="ak-artist-series-hero__overlay" aria-hidden="false">
          {% if eyebrow != blank %}
            <p class="ak-artist-series-hero__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if artist_name != blank %}
            {% if heading_level == 'h2' %}
              <h2 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name }}</h2>
            {% elsif heading_level == 'h3' %}
              <h3 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name }}</h3>
            {% else %}
              <h1 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name }}</h1>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}

      {% if wordmark_text != blank %}
        <p class="ak-artist-series-hero__wordmark">{{ wordmark_text | escape }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Artist Series hero",
  "class": "ak-artist-series-hero-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Full-bleed hero with top-left wordmark text, large overlay (eyebrow + artist name) that overlaps a bottom band containing the AK logo. Bake decorative butterflies and signatures into the background image."
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)",
      "info": "Wide landscape recommended. With “Fill stage and crop image” off, the full image is shown (width 100%, no cropping). Bake butterflies and signature into the file."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Hero image (mobile)",
      "info": "Optional; falls back to desktop. Same full-frame behavior when crop is off."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Hero image alt text",
      "info": "Describe the photo (artist, setting). Falls back to the artist name."
    },
    {
      "type": "select",
      "id": "image_object_position",
      "label": "Image focal point",
      "default": "center",
      "info": "Used when “Fill stage and crop image” is enabled.",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "checkbox",
      "id": "image_fill_and_crop",
      "label": "Fill stage and crop image",
      "default": false,
      "info": "Off (default): full image is visible at natural aspect ratio (width 100%). On: fixed min-height with object-fit cover (may crop edges)."
    },
    {
      "type": "range",
      "id": "image_min_height",
      "label": "Hero min height (desktop)",
      "min": 480,
      "max": 1080,
      "step": 20,
      "default": 720,
      "unit": "px",
      "info": "Crop mode: minimum stage height. Natural mode: used only when no image is set (placeholder)."
    },
    {
      "type": "range",
      "id": "image_min_height_mobile",
      "label": "Hero min height (mobile)",
      "min": 320,
      "max": 900,
      "step": 20,
      "default": 480,
      "unit": "px",
      "info": "Crop mode: minimum stage height. Natural mode: placeholder only."
    },
    {
      "type": "header",
      "content": "Top-left wordmark (live text)"
    },
    {
      "type": "textarea",
      "id": "wordmark_text",
      "label": "Wordmark text",
      "default": "Anne Klein Artist Series",
      "info": "Use line breaks for multiple lines (e.g. Anne Klein on one line, Artist Series on the next)."
    },
    {
      "type": "color",
      "id": "wordmark_color",
      "label": "Wordmark text color",
      "default": "#ffe1e3"
    },
    {
      "type": "select",
      "id": "wordmark_font_family",
      "label": "Wordmark font",
      "default": "amiri",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" },
        { "value": "helvetica", "label": "Helvetica Neue" }
      ]
    },
    {
      "type": "range",
      "id": "wordmark_font_size",
      "label": "Wordmark size (desktop)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "wordmark_font_size_mobile",
      "label": "Wordmark size (mobile)",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop."
    },
    {
      "type": "select",
      "id": "wordmark_font_weight",
      "label": "Wordmark weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "wordmark_line_height",
      "label": "Wordmark line height",
      "min": 100,
      "max": 160,
      "step": 5,
      "default": 120,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "wordmark_letter_spacing",
      "label": "Wordmark letter spacing",
      "min": -2,
      "max": 8,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "wordmark_uppercase",
      "label": "Wordmark uppercase + tracking",
      "default": false
    },
    {
      "type": "range",
      "id": "wordmark_max_width",
      "label": "Wordmark max width (desktop)",
      "min": 120,
      "max": 480,
      "step": 10,
      "default": 320,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "wordmark_max_width_mobile",
      "label": "Wordmark max width (mobile)",
      "min": 80,
      "max": 320,
      "step": 10,
      "default": 180,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "wordmark_offset_top",
      "label": "Wordmark offset from top (desktop)",
      "min": 8,
      "max": 120,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "wordmark_offset_left",
      "label": "Wordmark offset from left (desktop)",
      "min": 8,
      "max": 120,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
