{% style %}
  /*
    Theme Flex: `.section.is-width-wide` = full content width.
    Default `natural` layout: image keeps its aspect ratio (width 100%, height auto)
    so nothing is cropped; band + eyebrow/name are absolutely positioned over the photo.
    Optional `crop` layout: fixed min-height + object-fit cover (fills stage, crops image).
    Default layout matches Figma: gradient scrim at bottom + transparent “logo strip”,
    large name in overlay_name_color (typically light pink over scrim).

    Artist name font-size: min(setting max, max(2.5rem, fluid vw)) so the slider max can
    actually render past ~120px on common desktop widths (11vw was too low).

    Background images use image-element back_to_basics mode so Lazysizes’ aspect-ratio helper
    (data-aspectratio + padded .image-element__wrap) does not crop the uploaded asset.
  */
  #shopify-section-{{ id }} {
    display: block;
    width: 100%;
    max-width: none;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero {
    width: 100%;
    max-width: 100%;
    overflow: visible;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage {
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  /* --- Natural height: show full photo (no cover crop) --- */
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural {
    overflow: visible;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder {
    min-height: {{ image_min_height }}px;
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder {
      min-height: {{ image_min_height_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media {
    position: relative;
    z-index: 0;
    width: 100%;
    line-height: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media .image-element__wrap {
    position: relative !important;
    inset: auto !important;
    width: 100% !important;
    height: auto !important;
    max-width: 100% !important;
    margin: 0 !important;
    overflow: visible !important;
    padding-bottom: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media img,
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media .placeholder-svg {
    display: block;
    width: 100% !important;
    height: auto !important;
    max-width: 100%;
    vertical-align: middle;
    position: relative !important;
    object-fit: unset !important;
    object-position: unset !important;
    min-height: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only {
    position: relative;
    width: 100%;
    inset: auto;
    height: auto;
  }
  /* Fallback when no image: split gradient + curve hint (matches comp, not gray SVG placeholder). */
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--placeholder.ak-artist-series-hero__stage--natural .ak-artist-series-hero__media {
    position: relative;
    min-height: {{ image_min_height }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--placeholder.ak-artist-series-hero__stage--natural .ak-artist-series-hero__media {
      min-height: {{ image_min_height_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder .ak-artist-series-hero__placeholder-fill {
    position: absolute;
    inset: 0;
    width: 100%;
    min-height: {{ image_min_height }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural.ak-artist-series-hero__stage--placeholder .ak-artist-series-hero__placeholder-fill {
      min-height: {{ image_min_height_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__placeholder-fill {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    box-sizing: border-box;
    margin: 0;
    aspect-ratio: auto;
    pointer-events: none;
    border: 0;
    background-color: #1e281c;
    background-image:
      radial-gradient(
        ellipse 118% 145% at 115% -8%,
        rgba(148, 168, 138, 0.95) 0%,
        rgba(84, 98, 74, 0.92) 38%,
        rgba(46, 56, 42, 0.94) 56%,
        transparent 56.5%
      ),
      linear-gradient(
        104deg,
        #243022 0%,
        #243022 39.5%,
        #374433 41%,
        #596556 72%,
        #8f9f8a 100%
      );
    background-repeat: no-repeat;
    background-size: cover;
  }
  /* --- Crop-fill: min-height + cover; min() keeps short viewports from forced overflow --- */
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
    min-height: min({{ image_min_height }}px, 92vh);
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
      min-height: min({{ image_min_height_mobile }}px, 88vh);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    line-height: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    margin: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media img,
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media .placeholder-svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ image_object_position }};
    min-height: 0 !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__media > .is-hidden-desktop-only {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop .ak-artist-series-hero__placeholder-fill {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-artist-series-hero__media .is-hidden-desktop-only { display: block !important; }
  }
  {% comment %}
    Natural + max height: desktop art uses img.is-hidden-mobile-only (see image-element); it is not
    a direct child of .ak-artist-series-hero__media, so old `> .is-hidden-mobile-only` never matched.
    min(px, vh) keeps tall caps from overflowing short desktop viewports.
  {% endcomment %}
  {% if image_fill_and_crop == false and image_max_height > 0 %}
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media img.is-hidden-mobile-only {
      max-height: min({{ image_max_height }}px, 92vh) !important;
      max-width: 100% !important;
      width: 100% !important;
      height: auto !important;
      object-fit: contain;
      object-position: {{ image_object_position }};
    }
  }
  {% endif %}
  {% if image_fill_and_crop == false and image_max_height_mobile > 0 %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only {
      max-height: min({{ image_max_height_mobile }}px, 88vh);
      width: 100%;
      box-sizing: border-box;
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only .image-element__wrap {
      max-height: inherit;
      width: 100% !important;
      max-width: 100% !important;
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only img,
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--natural .ak-artist-series-hero__media > .is-hidden-desktop-only .placeholder-svg {
      max-width: 100% !important;
      width: 100% !important;
      max-height: min({{ image_max_height_mobile }}px, 88vh) !important;
      height: auto !important;
      object-fit: contain;
      object-position: {{ image_object_position }};
    }
  }
  {% endif %}
  {% if image_fill_and_crop and image_max_height > 0 %}
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
      min-height: min({{ image_min_height }}px, 92vh);
      max-height: min({{ image_max_height | at_least: image_min_height }}px, 95vh);
    }
  }
  {% endif %}
  {% if image_fill_and_crop and image_max_height_mobile > 0 %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__stage--crop {
      min-height: min({{ image_min_height_mobile }}px, 88vh);
      max-height: min({{ image_max_height_mobile | at_least: image_min_height_mobile }}px, 92vh);
    }
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark {
    position: absolute;
    top: {{ wordmark_offset_top }}px;
    left: {{ wordmark_offset_left }}px;
    width: min({{ wordmark_max_width }}px, 52vw);
    max-width: 85%;
    z-index: 4;
    margin: 0;
    padding: 0;
    overflow-wrap: break-word;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line {
    display: block;
    margin: 0;
    max-width: 100%;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line + .ak-artist-series-hero__wordmark-line {
    margin-top: 0.08em;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line--1 {
    font-family: {{ wm1_stack }};
    /* Smooth linear ramp across desktop widths (slider = base @ ~1024px → 2.2× @ ~3000px). */
    font-size: clamp({{ wm1_sz | times: 0.85 | divided_by: 16.0 }}rem, calc({{ wm1_sz | times: 0.31 | divided_by: 16.0 }}rem + {{ wm1_sz | times: 0.0675 }}vw), {{ wm1_sz | times: 3 | divided_by: 16.0 }}rem);
    font-weight: {{ wm1_wt }};
    line-height: {{ wm1_lh }}%;
    color: {{ wm1_co }};
    text-align: {{ wm1_al }};
    padding: {{ wm1_pt }}px {{ wm1_pr }}px {{ wm1_pb }}px {{ wm1_pl }}px;
    {% if wm1_uc %}
      text-transform: uppercase;
      letter-spacing: 0.08em;
    {% else %}
      letter-spacing: {{ wm1_ls }}px;
    {% endif %}
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line--2 {
    font-family: {{ wm2_stack }};
    /* Smooth linear ramp across desktop widths (slider = base @ ~1024px → 2.2× @ ~3000px). */
    font-size: clamp({{ wm2_sz | times: 0.85 | divided_by: 16.0 }}rem, calc({{ wm2_sz | times: 0.31 | divided_by: 16.0 }}rem + {{ wm2_sz | times: 0.0675 }}vw), {{ wm2_sz | times: 3 | divided_by: 16.0 }}rem);
    font-weight: {{ wm2_wt }};
    line-height: {{ wm2_lh }}%;
    color: {{ wm2_co }};
    text-align: {{ wm2_al }};
    padding: {{ wm2_pt }}px {{ wm2_pr }}px {{ wm2_pb }}px {{ wm2_pl }}px;
    {% if wm2_uc %}
      text-transform: uppercase;
      letter-spacing: 0.08em;
    {% else %}
      letter-spacing: {{ wm2_ls }}px;
    {% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__wordmark {
      top: 16px;
      left: 16px;
      width: min({{ wordmark_max_width_mobile }}px, 85vw);
      max-width: 90%;
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line--1 {
      font-size: {{ wm1_sz_m | divided_by: 16.0 }}rem;
      text-align: {{ wm1_al_m }};
      padding: {{ wm1_ptm }}px {{ wm1_prm }}px {{ wm1_pbm }}px {{ wm1_plm }}px;
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__wordmark-line--2 {
      font-size: {{ wm2_sz_m | divided_by: 16.0 }}rem;
      text-align: {{ wm2_al_m }};
      padding: {{ wm2_ptm }}px {{ wm2_prm }}px {{ wm2_pbm }}px {{ wm2_plm }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    height: min(46vh, 340px);
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(12, 14, 11, {{ scrim_alpha }}) 0%,
      rgba(12, 14, 11, {{ scrim_alpha | times: 0.55 }}) 52%,
      rgba(12, 14, 11, 0) 100%
    );
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__scrim {
      height: min(52vh, 280px);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__band {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    min-height: 0;
    color: {{ band_text_color }};
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.5rem;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__band--solid {
    height: {{ band_height }}px;
    background-color: {{ band_color }};
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__band--floating {
    height: {{ band_height }}px;
    background-color: transparent;
    justify-content: flex-end;
    padding-bottom: 1.25rem;
    padding-top: 0.5rem;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__band--solid {
      height: {{ band_height_mobile }}px;
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__band--floating {
      height: {{ band_height_mobile }}px;
      padding: 0.75rem 1rem 1rem;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__ak-logo {
    display: block;
    width: min({{ ak_logo_max_width }}px, 60vw);
    height: auto;
    max-width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__ak-logo {
      width: min({{ ak_logo_max_width_mobile }}px, 70vw);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc({{ band_height }}px - {{ overlay_overlap }}px);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 0;
    z-index: 3;
    pointer-events: none;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__overlay {
      bottom: calc({{ band_height_mobile }}px - {{ overlay_overlap_mobile }}px);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow {
    font-family: {{ eyebrow_font_stack }};
    /* Smooth linear ramp across desktop widths.
       Anchor points: at ~1024px viewport ≈ slider value; at ~3000px viewport ≈ 2.2× slider.
       Between those it interpolates linearly via vw — no breakpoints, no plateaus. */
    font-size: clamp({{ eb_sz | times: 0.85 | divided_by: 16.0 }}rem, calc({{ eb_sz | times: 0.31 | divided_by: 16.0 }}rem + {{ eb_sz | times: 0.0675 }}vw), {{ eb_sz | times: 3 | divided_by: 16.0 }}rem);
    font-weight: {{ eb_wt }};
    line-height: {{ eb_lh }}%;
    margin: 0;
    width: 100%;
    box-sizing: border-box;
    color: {{ eyebrow_co }};
    text-align: {{ eb_al }};
    padding: {{ eb_pt }}px {{ eb_pr }}px {{ eb_pb }}px {{ eb_pl }}px;
    transform: translateY({{ eb_nudge }}px);
    {% if section.settings.eyebrow_uppercase %}
      text-transform: uppercase;
      letter-spacing: 0.12em;
    {% else %}
      letter-spacing: {{ eb_ls }}px;
    {% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow {
      font-size: {{ eb_sz_m | divided_by: 16.0 }}rem;
      text-align: {{ eb_al_m }};
      padding: {{ eb_ptm }}px {{ eb_prm }}px {{ eb_pbm }}px {{ eb_plm }}px;
      transform: translateY({{ eb_nudge_m }}px);
      {% unless section.settings.eyebrow_uppercase %}
        letter-spacing: {{ eb_ls_m }}px;
      {% endunless %}
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__name {
    font-family: {{ name_font_stack }};
    /* Preferred max size: smooth linear ramp across desktop widths
       (slider value ≈ size at ~1024px viewport, ≈ 2.5× slider at ~3000px).
       The auto-fit script below scales DOWN from this size when needed so the
       artist name always fits on a single line within its container. */
    font-size: clamp({{ nm_sz | times: 0.85 | divided_by: 16.0 }}rem, calc({{ nm_sz | times: 0.235 | divided_by: 16.0 }}rem + {{ nm_sz | times: 0.075 }}vw), {{ nm_sz | times: 3.5 | divided_by: 16.0 }}rem);
    font-weight: {{ nm_wt }};
    line-height: {{ nm_lh }}%;
    letter-spacing: {{ nm_ls }}px;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
    box-sizing: border-box;
    width: 100%;
    text-align: {{ nm_al }};
    /* Extra 0.2em on the bottom keeps serif descenders (g, j, p, y)
       from being clipped by overflow: hidden when line-height is tight. */
    padding: {{ nm_pt }}px {{ nm_pr }}px calc({{ nm_pb }}px + 0.2em) {{ nm_pl }}px;
    transform: translateY({{ nm_nudge }}px);
  }
  /* Scrim: shadow on eyebrow only. Name colors are set per word; a dark text-shadow
     on the name muddies black type and looks like a glow on light areas. */
  #shopify-section-{{ id }}.ak-artist-series-hero-section--scrim .ak-artist-series-hero__name,
  #shopify-section-{{ id }}.ak-artist-series-hero-section--scrim .ak-artist-series-hero__name * {
    text-shadow: none;
  }
  #shopify-section-{{ id }}.ak-artist-series-hero-section--scrim .ak-artist-series-hero__eyebrow {
    text-shadow: 0 2px 18px rgba(5, 8, 6, 0.55), 0 1px 4px rgba(5, 8, 6, 0.92);
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__name {
      /* Mobile linear ramp: slider value ≈ size at ~390px viewport,
         scaling smoothly up toward ~1.5× slider near the 798px breakpoint.
         Auto-fit script shrinks from this if it ever overflows the container. */
      font-size: clamp({{ nm_sz_m | times: 0.6 | divided_by: 16.0 }}rem, calc({{ nm_sz_m | times: 0.522 | divided_by: 16.0 }}rem + {{ nm_sz_m | times: 0.1225 }}vw), {{ nm_sz_m | times: 1.7 | divided_by: 16.0 }}rem);
      text-align: {{ nm_al_m }};
      padding: {{ nm_ptm }}px {{ nm_prm }}px calc({{ nm_pbm }}px + 0.2em) {{ nm_plm }}px;
      letter-spacing: {{ nm_ls_m }}px;
      transform: translateY({{ nm_nudge_m }}px);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__name-part--first {
    color: {{ name_co_first }};
  }
  #shopify-section-{{ id }} .ak-artist-series-hero__name-part--last {
    color: {{ name_co_last }};
  }
  {% if name_match_mobile_name_colors == false %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__name-part--first {
      color: {{ name_co_first_m }};
    }
    #shopify-section-{{ id }} .ak-artist-series-hero__name-part--last {
      color: {{ name_co_last_m }};
    }
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-artist-series-hero__name:focus-visible {
    outline: 2px solid {{ name_co_first }};
    outline-offset: 4px;
  }
  {% if name_match_mobile_name_colors == false %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-hero__name:focus-visible {
      outline-color: {{ name_co_first_m }};
    }
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-artist-series-hero__eyebrow:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-artist-series-hero,
    #shopify-section-{{ id }} .ak-artist-series-hero * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<section
  class="section is-width-wide ak-artist-series-hero-section has-no-side-gutter{% if show_bottom_gradient_scrim %} ak-artist-series-hero-section--scrim{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="ak-artist-series-hero">
    <div class="ak-artist-series-hero__stage{% if image_fill_and_crop %} ak-artist-series-hero__stage--crop{% else %} ak-artist-series-hero__stage--natural{% endif %}{% unless has_hero_image %} ak-artist-series-hero__stage--placeholder{% endunless %}">
      <div class="ak-artist-series-hero__media">
        {% if image != blank %}
          {% include 'image-element', image: image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'is-hidden-mobile-only ak-artist-series-hero__img' %}
        {% else %}
          <div class="ak-artist-series-hero__placeholder-fill is-hidden-mobile-only" aria-hidden="true"></div>
        {% endif %}
        {% if mobile_image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: mobile_image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'ak-artist-series-hero__img' %}
          </div>
        {% elsif image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: image, alt: img_alt_resolved, stretch_width: true, back_to_basics: true, additional_classes: 'ak-artist-series-hero__img' %}
          </div>
        {% else %}
          <div class="is-hidden-desktop-only">
            <div class="ak-artist-series-hero__placeholder-fill" aria-hidden="true"></div>
          </div>
        {% endif %}
      </div>

      {% if show_bottom_gradient_scrim %}
        <div class="ak-artist-series-hero__scrim" aria-hidden="true"></div>
      {% endif %}

      <div class="ak-artist-series-hero__band {% if solid_white_bottom_band %}ak-artist-series-hero__band--solid{% else %}ak-artist-series-hero__band--floating{% endif %}">
        {% if ak_logo != blank %}
          <img
            class="ak-artist-series-hero__ak-logo"
            src="{{ ak_logo | img_url: '800x' }}"
            alt="{{ ak_logo_alt | escape }}"
            loading="lazy"
            width="{{ ak_logo.width }}"
            height="{{ ak_logo.height }}"
          >
        {% endif %}
      </div>

      {% if eyebrow != blank or artist_name != blank %}
        <div class="ak-artist-series-hero__overlay" aria-hidden="false">
          {% if eyebrow != blank %}
            <p class="ak-artist-series-hero__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if artist_name != blank %}
            {% assign _an_st = artist_name | strip %}
            {% assign _an_tok = _an_st | split: ' ' %}
            {% assign _an_first = _an_tok[0] %}
            {% assign _an_last = '' %}
            {% for _an_w in _an_tok %}
              {% unless forloop.first %}
                {% if _an_last != '' %}{% assign _an_last = _an_last | append: ' ' %}{% endif %}
                {% assign _an_last = _an_last | append: _an_w %}
              {% endunless %}
            {% endfor %}
            {% capture artist_name_html %}
              {% if _an_last != '' %}
                <span class="ak-artist-series-hero__name-part ak-artist-series-hero__name-part--first">{{ _an_first | escape }}</span><span class="ak-artist-series-hero__name-sep" aria-hidden="true"> </span><span class="ak-artist-series-hero__name-part ak-artist-series-hero__name-part--last">{{ _an_last | escape }}</span>
              {% else %}
                <span class="ak-artist-series-hero__name-part ak-artist-series-hero__name-part--first">{{ _an_st | escape }}</span>
              {% endif %}
            {% endcapture %}
            {% if heading_level == 'h2' %}
              <h2 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name_html }}</h2>
            {% elsif heading_level == 'h3' %}
              <h3 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name_html }}</h3>
            {% elsif heading_level == 'p' %}
              <p class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name_html }}</p>
            {% else %}
              <h1 class="ak-artist-series-hero__name" id="ak-artist-series-hero-name-{{ id }}">{{ artist_name_html }}</h1>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}

      {% if wordmark_line_1 != blank or wordmark_line_2 != blank %}
        {%- comment -%}
          When the wordmark is a heading (h1/h2/h3) we wrap BOTH lines in a single
          heading element (with span sub-lines) so screen readers announce one
          coherent heading instead of two consecutive ones. When set to "p" we
          keep the original two-paragraph structure.
        {%- endcomment -%}
        {% if wordmark_heading_level == 'h1' or wordmark_heading_level == 'h2' or wordmark_heading_level == 'h3' %}
          {% if wordmark_heading_level == 'h2' %}
            <h2 class="ak-artist-series-hero__wordmark">
          {% elsif wordmark_heading_level == 'h3' %}
            <h3 class="ak-artist-series-hero__wordmark">
          {% else %}
            <h1 class="ak-artist-series-hero__wordmark">
          {% endif %}
            {% if wordmark_line_1 != blank %}
              <span class="ak-artist-series-hero__wordmark-line ak-artist-series-hero__wordmark-line--1">
                {{- wordmark_line_1 | escape -}}
              </span>
            {% endif %}
            {% if wordmark_line_2 != blank %}
              <span class="ak-artist-series-hero__wordmark-line ak-artist-series-hero__wordmark-line--2">
                {{- wordmark_line_2 | escape -}}
              </span>
            {% endif %}
          {% if wordmark_heading_level == 'h2' %}
            </h2>
          {% elsif wordmark_heading_level == 'h3' %}
            </h3>
          {% else %}
            </h1>
          {% endif %}
        {% else %}
          <div class="ak-artist-series-hero__wordmark">
            {% if wordmark_line_1 != blank %}
              <p class="ak-artist-series-hero__wordmark-line ak-artist-series-hero__wordmark-line--1">
                {{- wordmark_line_1 | escape -}}
              </p>
            {% endif %}
            {% if wordmark_line_2 != blank %}
              <p class="ak-artist-series-hero__wordmark-line ak-artist-series-hero__wordmark-line--2">
                {{- wordmark_line_2 | escape -}}
              </p>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
</section>

{%- if artist_name != blank -%}
  <script>
    (function () {
      var nameId = 'ak-artist-series-hero-name-{{ id }}';
      var el = document.getElementById(nameId);
      if (!el) return;
      var parent = el.parentElement;
      if (!parent) return;

      var pending = false;
      function fit() {
        if (pending) return;
        pending = true;
        window.requestAnimationFrame(function () {
          pending = false;
          // Reset to the CSS-defined preferred max, then shrink to fit.
          el.style.fontSize = '';
          var style = window.getComputedStyle(el);
          var paddingX = (parseFloat(style.paddingLeft) || 0) + (parseFloat(style.paddingRight) || 0);
          var available = parent.clientWidth - paddingX;
          if (available <= 0) return;
          var current = parseFloat(style.fontSize);
          if (!current) return;
          // Floor to keep type readable on very narrow viewports.
          var minSize = 18;
          // Two-pass proportional shrink converges in 1–2 iterations.
          for (var i = 0; i < 4; i++) {
            var overflow = el.scrollWidth;
            if (overflow <= available + 0.5) break;
            current = Math.max(minSize, current * (available / overflow));
            el.style.fontSize = current + 'px';
            if (current === minSize) break;
          }
        });
      }

      fit();
      var ro = (typeof ResizeObserver === 'function') ? new ResizeObserver(fit) : null;
      if (ro) ro.observe(parent);
      window.addEventListener('resize', fit, { passive: true });
      window.addEventListener('orientationchange', fit, { passive: true });
      if (document.fonts && document.fonts.ready && typeof document.fonts.ready.then === 'function') {
        document.fonts.ready.then(fit);
      }
      // Re-fit when the Theme Editor swaps section content.
      document.addEventListener('shopify:section:load', function (e) {
        if (e && e.detail && e.detail.sectionId === '{{ id }}') fit();
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "AK Artist Series hero",
  "class": "ak-artist-series-hero-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Full-bleed hero. Wordmark (2 lines), eyebrow, and artist name each have their own font, size, color, desktop/mobile alignment, and padding. Optional solid bottom band; otherwise a gradient scrim. Bake butterflies and signatures into the photo."
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)",
      "info": "Wide landscape recommended. With “Fill stage and crop image” off, the full image is shown (width 100%, no cropping). Bake butterflies and signature into the file."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Hero image (mobile)",
      "info": "Optional; falls back to desktop. Same full-frame behavior when crop is off."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Hero image alt text",
      "info": "Describe the photo (artist, setting). Falls back to the artist name."
    },
    {
      "type": "select",
      "id": "image_object_position",
      "label": "Image focal point",
      "default": "center",
      "info": "Used when “Fill stage and crop image” is enabled.",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "checkbox",
      "id": "image_fill_and_crop",
      "label": "Fill stage and crop image",
      "default": false,
      "info": "Off (default): full image is visible at natural aspect ratio (width 100%). On: fixed min-height with object-fit cover (may crop edges)."
    },
    {
      "type": "range",
      "id": "image_min_height",
      "label": "Hero min height (desktop)",
      "min": 480,
      "max": 1080,
      "step": 20,
      "default": 720,
      "unit": "px",
      "info": "Fill & crop: minimum stage height. Natural: only the empty placeholder; with a real image, width is 100% and height follows the file unless you set max height below."
    },
    {
      "type": "range",
      "id": "image_min_height_mobile",
      "label": "Hero min height (mobile)",
      "min": 320,
      "max": 900,
      "step": 20,
      "default": 480,
      "unit": "px",
      "info": "Fill & crop: minimum stage height. Natural: placeholder only when there is no image."
    },
    {
      "type": "range",
      "id": "image_max_height",
      "label": "Hero max height (natural, desktop)",
      "min": 0,
      "max": 2000,
      "step": 20,
      "default": 0,
      "unit": "px",
      "info": "Only when “Fill stage and crop” is off. 0 = no cap (image uses full height). Otherwise caps the desktop image at this height (also limited by 92% of the viewport height on short screens)."
    },
    {
      "type": "range",
      "id": "image_max_height_mobile",
      "label": "Hero max height (natural, mobile)",
      "min": 0,
      "max": 900,
      "step": 20,
      "default": 0,
      "unit": "px",
      "info": "Only for natural (non-crop) layout. 0 = no cap. Caps the mobile image; also limited by 88% of the viewport height."
    },
    {
      "type": "header",
      "content": "Top-left wordmark"
