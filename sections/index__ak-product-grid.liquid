{% comment %}
  AK Product grid — hand-picked products and/or one collection, or override-only tiles.
  Fixed CSS grid only: no carousel, Flickity, or horizontal product slider.
  Optional per-tile art direction: override image (desktop) + override image (mobile) using is-hidden-* classes at 798px.
{% endcomment %}

{% assign id = section.id %}
{% assign title = section.settings.title %}
{% assign products_per_row = section.settings.products_per | default: 4 | plus: 0 %}
{% if products_per_row < 1 %}{% assign products_per_row = 4 %}{% endif %}
{% assign products_per_row_mobile = section.settings.products_per_mobile | default: 2 | plus: 0 %}
{% if products_per_row_mobile < 1 %}{% assign products_per_row_mobile = 2 %}{% endif %}
{% assign grid_gap = section.settings.grid_gap | default: 16 | plus: 0 %}
{% assign grid_gap_mobile = section.settings.grid_gap_mobile | default: 0 | plus: 0 %}
{% if grid_gap_mobile < 1 %}{% assign grid_gap_mobile = grid_gap %}{% endif %}
{% assign show_title = section.settings.show_title %}
{% if section.settings.show_title == nil %}{% assign show_title = true %}{% endif %}
{% assign show_price = section.settings.show_price %}
{% if section.settings.show_price == nil %}{% assign show_price = true %}{% endif %}
{% assign show_more_colors = section.settings.show_more_colors %}
{% if section.settings.show_more_colors == nil %}{% assign show_more_colors = true %}{% endif %}
{% assign show_stickers = section.settings.show_stickers %}
{% if section.settings.show_stickers == nil %}{% assign show_stickers = true %}{% endif %}
{% assign align_height = section.settings.align_height %}
{% assign height = section.settings.collection_height | default: 320 | plus: 0 %}
{% assign width = section.settings.width | default: 'wide' %}
{% assign show_gutter = section.settings.show_gutter %}
{% assign padding_top = section.settings.padding_top | default: 40 | plus: 0 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 40 | plus: 0 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign heading_alignment = section.settings.heading_alignment | default: 'center' %}
{% assign heading_font_size = section.settings.heading_font_size | default: 24 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '400' %}
{% assign heading_underline = section.settings.heading_underline %}
{% assign heading_font_size_mobile = section.settings.heading_font_size_mobile | default: 0 %}
{% assign heading_alignment_mobile = section.settings.heading_alignment_mobile | default: '' %}
{% if section.settings.font_family == 'amiri' %}
  {% render 'ak-campaign-fonts' %}
{% endif %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'amiri' %}{% assign font_stack = 'Amiri, Georgia, serif' %}
  {% when 'helvetica' %}{% assign font_stack = '"Helvetica Neue", Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}

{% assign product_source = section.settings.product_source | default: 'blocks' %}
{% assign product_limit_setting = section.settings.products_limit | default: 12 | plus: 0 %}
{% assign collection_ref = section.settings.collection %}

{% assign block_product_count = 0 %}
{% for block in section.blocks %}
  {% if block.type == 'product' %}
    {% if block.settings.product != blank %}
      {% assign block_product_count = block_product_count | plus: 1 %}
    {% elsif block.settings.override_image != blank or block.settings.override_image_mobile != blank %}
      {% assign block_product_count = block_product_count | plus: 1 %}
    {% endif %}
  {% endif %}
{% endfor %}

{% assign use_collection_loop = false %}
{% assign collection_size = 0 %}
{% if product_source == 'collection' and collection_ref != blank and collections[collection_ref] != blank and block_product_count == 0 %}
  {% assign collection_size = collections[collection_ref].products.size | plus: 0 %}
  {% if collection_size > 0 %}
    {% assign use_collection_loop = true %}
  {% endif %}
{% endif %}

{% assign products_count = 0 %}
{% assign product_limit = product_limit_setting %}
{% if use_collection_loop %}
  {% assign products_count = product_limit_setting %}
  {% if collection_size < product_limit_setting %}
    {% assign products_count = collection_size %}
  {% endif %}
  {% assign product_limit = products_count %}
{% else %}
  {% assign product_limit = product_limit_setting %}
  {% if block_product_count < product_limit_setting %}
    {% assign product_limit = block_product_count %}
  {% endif %}
  {% assign products_count = product_limit %}
{% endif %}

{% assign ak_pg_editor = request.design_mode %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}width: 100%;{% endif %}
    max-width: 100vw;
    overflow: hidden;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} { padding-top: {{ padding_top_mobile }}px; padding-bottom: {{ padding_bottom_mobile }}px; }
  }
  #shopify-section-{{ id }} .ak-pg__heading-wrap { width: 100%; display: block; box-sizing: border-box; }
  #shopify-section-{{ id }} .ak-pg__heading {
    margin: 0 0 1.5rem; font-family: {{ font_stack }}; font-size: {{ heading_font_size }}px; font-weight: {{ heading_font_weight }};
    text-align: {{ heading_alignment }}; text-transform: none; display: block; width: 100%;
    {% if heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-pg__heading {
      {% if heading_font_size_mobile > 0 %}font-size: {{ heading_font_size_mobile }}px;{% else %}font-size: {{ heading_font_size | times: 0.75 | round }}px;{% endif %}
      {% if heading_alignment_mobile != '' %}text-align: {{ heading_alignment_mobile }};{% endif %}
    }
  }
  #shopify-section-{{ id }} .ak-pg__link { text-decoration: none; color: inherit; display: block; }
  #shopify-section-{{ id }} .ak-pg__image-only { display: block; color: inherit; }
  {% unless show_title %}
  #shopify-section-{{ id }} .product-thumbnail__title, #shopify-section-{{ id }} .product-thumbnail__vendor { display: none !important; }
  {% endunless %}
  {% unless show_price %}
  #shopify-section-{{ id }} .product-thumbnail__price, #shopify-section-{{ id }} .product-thumbnail__was-price { display: none !important; }
  {% endunless %}
  {% unless show_more_colors %}
  #shopify-section-{{ id }} .thumbnail-swatch, #shopify-section-{{ id }} .more_color { display: none !important; }
  {% endunless %}
  {% unless show_stickers %}
  #shopify-section-{{ id }} .sticker-holder, #shopify-section-{{ id }} .thumbnail-sticker { display: none !important; }
  {% endunless %}
  #shopify-section-{{ id }} .ak-pg__grid {
    display: grid;
    grid-template-columns: repeat({{ products_per_row }}, minmax(0, 1fr));
    gap: {{ grid_gap }}px;
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  #shopify-section-{{ id }} .ak-pg__grid .gallery-cell {
    width: 100%; min-width: 0; box-sizing: border-box; margin: 0; padding: 0; float: none;
  }
  #shopify-section-{{ id }} .ak-pg__grid .gallery-cell .product-wrap,
  #shopify-section-{{ id }} .ak-pg__grid .gallery-cell .product-image__wrapper,
  #shopify-section-{{ id }} .ak-pg__grid .gallery-cell .image__container {
    width: 100%; max-width: 100%; box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-pg__grid {
      grid-template-columns: repeat({{ products_per_row_mobile }}, minmax(0, 1fr));
      gap: {{ grid_gap_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-pg__imageContainer--split .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-pg__imageContainer--split .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-pg__imageContainer--split .is-hidden-desktop-only { display: block !important; }
  }
{% endstyle %}

{% assign section_aria_label = section.settings.section_aria_label %}
<section class="section is-width-{{ width }} ak-product-grid-section {% if show_gutter %}has-gutter-enabled{% else %}has-no-side-gutter has-background{% endif %}" id="shopify-section-{{ id }}"
  {% if title != blank %}aria-labelledby="ak-pg-heading-{{ id }}"
  {% elsif section_aria_label != blank %}aria-label="{{ section_aria_label | escape }}"
  {% else %}aria-label="Product grid"{% endif %}>
  {% if title != blank %}
    <div class="container ak-pg__heading-wrap">
      <h2 class="ak-pg__heading" id="ak-pg-heading-{{ id }}">{{ title }}</h2>
    </div>
  {% endif %}
  <div class="container">
    <div class="one-whole column has-column-padding-bottom">
      {% if products_count > 0 %}
        <div class="ak-pg__grid" role="list" aria-label="{{ title | default: 'Product grid' | strip | escape }}">
          {% if use_collection_loop %}
            {% for product in collections[collection_ref].products limit: product_limit %}
              {% assign hover_enabled = settings.thumbnail_hover_enabled %}
              {% if product.featured_media != blank and product.featured_media.preview_image.alt != blank %}
                {% assign alt_text = product.featured_media.preview_image.alt %}
              {% else %}
                {% assign alt_text = product.title %}
              {% endif %}
              <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if product.media[1] != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}" role="listitem">
                <a href="{{ product.url }}" class="ak-pg__link" aria-label="{{ product.title | escape }}">
                  <div class="product-wrap">
                    <div class="product-image__wrapper">
                      <div class="image__container product__imageContainer">
                        {% if settings.stickers_enabled %}{% include 'product-thumbnail__sticker' %}{% endif %}
                        {% if product.featured_media != blank %}
                          {% include 'image-element', image: product.featured_media.preview_image, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                        {% if product.media[1] != blank and settings.show_secondary_image %}
                          {% include 'image-element', image: product.media[1], alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                        {% endif %}
                      </div>
                      {% if hover_enabled or settings.enable_quickshop %}
                        <div class="thumbnail-overlay__container">
                          {% if hover_enabled %}
                            <div class="quick-shop__info animated fadeInDown">
                              <div class="thumbnail-overlay">
                                <div class="info text-align-{{ settings.thumbnail_text_alignment }}">{% include 'product-thumbnail__product-info' %}</div>
                              </div>
                            </div>
                          {% endif %}
                          {% if settings.enable_quickshop %}{% include 'product-thumbnail__quick-shop-button' %}{% endif %}
                        </div>
                      {% endif %}
                    </div>
                    {% if hover_enabled == false %}
                      <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">{% include 'product-thumbnail__product-info' %}</div>
                    {% endif %}
                  </div>
                </a>
                {% include 'product-thumbnail__swatch' %}
              </div>
            {% endfor %}
          {% else %}
            {% assign output_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'product' and block.settings.product != blank %}
                {% if output_index < product_limit %}
                  {% assign product = block.settings.product %}
                  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
                  {% assign ov = block.settings.override_image %}
                  {% assign ov_m = block.settings.override_image_mobile %}
                  {% assign override_image_hover = block.settings.override_image_hover %}
                  {% assign override_alt = block.settings.image_alt | strip %}
                  {% if ov != blank %}
                    {% assign primary_desktop = ov %}
                  {% elsif product.featured_media != blank %}
                    {% assign primary_desktop = product.featured_media.preview_image %}
                  {% else %}
                    {% assign primary_desktop = blank %}
                  {% endif %}
                  {% if ov_m != blank %}
                    {% assign primary_mobile = ov_m %}
                    {% assign use_ak_split = true %}
                  {% else %}
                    {% assign use_ak_split = false %}
                    {% assign primary_mobile = primary_desktop %}
                  {% endif %}
                  {% if override_alt != blank %}
                    {% assign alt_text = override_alt %}
                  {% elsif primary_desktop != blank and primary_desktop.alt != blank %}
                    {% assign alt_text = primary_desktop.alt %}
                  {% else %}
                    {% assign alt_text = product.title %}
                  {% endif %}
                  {% if override_image_hover != blank %}
                    {% assign hover_image = override_image_hover %}
                  {% elsif ov == blank and product.media[1] != blank %}
                    {% assign hover_image = product.media[1] %}
                  {% else %}
                    {% assign hover_image = blank %}
                  {% endif %}
                  <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if hover_image != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}" role="listitem" {{ block.shopify_attributes }}>
                    <a href="{{ product.url }}" class="ak-pg__link" aria-label="{{ product.title | escape }}">
                      <div class="product-wrap">
                        <div class="product-image__wrapper">
                          <div class="image__container product__imageContainer{% if use_ak_split %} ak-pg__imageContainer--split{% endif %}">
                            {% if settings.stickers_enabled %}{% include 'product-thumbnail__sticker' %}{% endif %}
                            {% if use_ak_split %}
                              <div class="is-hidden-mobile-only">
                                {% if primary_desktop != blank %}
                                  {% include 'image-element', image: primary_desktop, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                                {% else %}
                                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                                {% if hover_image != blank and settings.show_secondary_image %}
                                  {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                                {% endif %}
                              </div>
                              <div class="is-hidden-desktop-only">
                                {% if primary_mobile != blank %}
                                  {% include 'image-element', image: primary_mobile, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                                {% else %}
                                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                                {% if hover_image != blank and settings.show_secondary_image %}
                                  {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                                {% endif %}
                              </div>
                            {% else %}
                              {% if primary_desktop != blank %}
                                {% include 'image-element', image: primary_desktop, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                              {% else %}
                                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                              {% if hover_image != blank and settings.show_secondary_image %}
                                {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                              {% endif %}
                            {% endif %}
                          </div>
                          {% if hover_enabled or settings.enable_quickshop %}
                            <div class="thumbnail-overlay__container">
                              {% if hover_enabled %}
                                <div class="quick-shop__info animated fadeInDown">
                                  <div class="thumbnail-overlay">
                                    <div class="info text-align-{{ settings.thumbnail_text_alignment }}">{% include 'product-thumbnail__product-info' %}</div>
                                  </div>
                                </div>
                              {% endif %}
                              {% if settings.enable_quickshop %}{% include 'product-thumbnail__quick-shop-button' %}{% endif %}
                            </div>
                          {% endif %}
                        </div>
                        {% if hover_enabled == false %}
                          <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">{% include 'product-thumbnail__product-info' %}</div>
                        {% endif %}
                      </div>
                    </a>
                    {% include 'product-thumbnail__swatch' %}
                  </div>
                  {% assign output_index = output_index | plus: 1 %}
                {% endif %}
              {% elsif block.type == 'product' and block.settings.product == blank %}
                {% if block.settings.override_image != blank or block.settings.override_image_mobile != blank %}
                {% if output_index < product_limit %}
                  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
                  {% assign d_img = block.settings.override_image %}
                  {% assign m_img = block.settings.override_image_mobile %}
                  {% if d_img != blank and m_img != blank %}
                    {% assign use_ak_io_split = true %}
                    {% assign primary_desk_io = d_img %}
                    {% assign primary_mob_io = m_img %}
                  {% elsif m_img != blank %}
                    {% assign use_ak_io_split = false %}
                    {% assign primary_desk_io = m_img %}
                  {% else %}
                    {% assign use_ak_io_split = false %}
                    {% assign primary_desk_io = d_img %}
                  {% endif %}
                  {% assign hover_image = block.settings.override_image_hover %}
                  {% assign tile_title = block.settings.tile_title | strip %}
                  {% assign tile_link = block.settings.tile_link %}
                  {% assign alt_text = block.settings.image_alt | strip %}
                  {% if alt_text == blank %}
                    {% if tile_title != blank %}
                      {% assign alt_text = tile_title %}
                    {% else %}
                      {% assign alt_text = 'Product grid item' %}
                    {% endif %}
                  {% endif %}
                  {% assign sr_label = '' %}
                  {% if tile_title != blank and alt_text != blank and tile_title != alt_text %}
                    {% assign sr_label = tile_title | append: '. ' | append: alt_text %}
                  {% elsif tile_title != blank %}
                    {% assign sr_label = tile_title %}
                  {% elsif alt_text != blank %}
                    {% assign sr_label = alt_text %}
                  {% endif %}
                  <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column {% if hover_image != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %} ak-pg__image-only-tile" role="listitem" {{ block.shopify_attributes }}>
                    {% if tile_link != blank %}
                      <a href="{{ tile_link }}" class="ak-pg__link"{% if sr_label != blank %} aria-label="{{ sr_label | escape }}"{% endif %}>
                    {% else %}
                      <div class="ak-pg__image-only" role="group"{% if sr_label != blank %} aria-label="{{ sr_label | escape }}"{% endif %}>
                    {% endif %}
                      <div class="product-wrap">
                        <div class="product-image__wrapper">
                          <div class="image__container product__imageContainer{% if use_ak_io_split %} ak-pg__imageContainer--split{% endif %}">
                            {% if use_ak_io_split %}
                              <div class="is-hidden-mobile-only">
                                {% include 'image-element', image: primary_desk_io, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                                {% if hover_image != blank and settings.show_secondary_image %}
                                  {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                                {% endif %}
                              </div>
                              <div class="is-hidden-desktop-only">
                                {% include 'image-element', image: primary_mob_io, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                                {% if hover_image != blank and settings.show_secondary_image %}
                                  {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                                {% endif %}
                              </div>
                            {% else %}
                              {% include 'image-element', image: primary_desk_io, alt: alt_text, object_fit: align_height, max_height: height, back_to_basics: ak_pg_editor %}
                              {% if hover_image != blank and settings.show_secondary_image %}
                                {% include 'image-element', image: hover_image, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', back_to_basics: ak_pg_editor %}
                              {% endif %}
                            {% endif %}
                          </div>
                        </div>
                        {% if hover_enabled == false and show_title and tile_title != blank %}
                          <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                            <span class="product-thumbnail__title">{{ tile_title | escape }}</span>
                          </div>
                        {% endif %}
                      </div>
                    {% if tile_link != blank %}</a>{% else %}</div>{% endif %}
                  </div>
                  {% assign output_index = output_index | plus: 1 %}
                {% endif %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      {% else %}
        <p class="text-align-center" style="margin:0;">
          {% if product_source == 'collection' and collection_ref != blank and collections[collection_ref] == blank %}
            The selected collection could not be found. Check the collection, or set Product source to Hand-picked and add Product blocks.
          {% elsif product_source == 'collection' and collection_ref == blank and block_product_count == 0 %}
            Choose a collection, or set Product source to Hand-picked and add Product blocks.
          {% else %}
            Add Product blocks, or a collection with products. For image-only tiles, clear the product and set an override image (and optional mobile image).
          {% endif %}
        </p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Product grid",
  "class": "ak-product-grid-section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "SHOP THE LOOK" },
    {
      "type": "select", "id": "product_source", "label": "Product source", "default": "blocks",
      "options": [
        { "value": "blocks", "label": "Hand-picked products" },
        { "value": "collection", "label": "From collection" }
      ],
      "info": "If any Product block has a product or an override image, that hand-picked grid is used. From collection runs only when there are no such blocks. Clear blocks to pull from a collection when Product source is set to From collection."
    },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_limit", "label": "Product limit", "min": 2, "max": 50, "step": 1, "default": 12 },
    { "type": "range", "id": "products_per", "label": "Columns (desktop)", "min": 1, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "products_per_mobile", "label": "Columns (mobile)", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "grid_gap", "label": "Grid gap (desktop)", "min": 0, "max": 48, "step": 4, "default": 16, "unit": "px" },
    { "type": "range", "id": "grid_gap_mobile", "label": "Grid gap (mobile)", "min": 0, "max": 48, "step": 4, "default": 0, "unit": "px", "info": "0 = same as desktop" },
    { "type": "checkbox", "id": "align_height", "label": "Align to height", "default": false },
    { "type": "range", "id": "collection_height", "label": "Image height (when align to height)", "min": 200, "max": 500, "step": 10, "default": 320, "unit": "px" },
    { "type": "select", "id": "width", "label": "Width", "default": "wide", "options": [ { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" } ] },
    { "type": "checkbox", "id": "show_gutter", "label": "Show side gutter", "default": true },
    { "type": "checkbox", "id": "show_title", "label": "Show product title", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "checkbox", "id": "show_more_colors", "label": "Show more colors", "default": true },
    { "type": "checkbox", "id": "show_stickers", "label": "Show stickers", "default": true },
    { "type": "text", "id": "section_aria_label", "label": "Section ARIA label (if no heading)" },
    { "type": "header", "content": "Heading style" },
    { "type": "select", "id": "font_family", "label": "Font", "default": "system",
      "options": [
