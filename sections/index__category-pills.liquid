{% comment %}
  AK Homepage 2026 – Category Pills
  "New for the Season" heading + horizontal pill buttons (Clothing, Shoes, etc.)
  Matches Figma: AK_Homepage Launch 2026_Desktop – category nav block
  WCAG 2.2 AA: nav + list, focus styles, 44px touch target, section label.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign heading_color = section.settings.heading_color %}
{% assign heading_font_size = section.settings.heading_font_size | default: 30 %}
{% assign layout_mode = section.settings.layout_mode | default: 'inline' %}
{% assign content_alignment = section.settings.content_alignment | default: 'left' %}
{% assign bg_color = section.settings.background_color %}
{% assign pill_bg_color = section.settings.pill_background_color | default: '#000000' %}
{% assign pill_text_color = section.settings.pill_text_color | default: '#ffffff' %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign pill_font_size = section.settings.pill_font_size | default: 18 %}
{% assign pill_ls = section.settings.pill_letter_spacing | default: 2 %}
{% assign pill_padding_v = section.settings.pill_padding_vertical | default: 12 %}
{% assign pill_padding_h = section.settings.pill_padding_horizontal | default: 20 %}
{% assign pill_spacing = section.settings.pill_spacing | default: 8 %}
{% assign pill_padding_v_mobile = section.settings.pill_padding_vertical_mobile | default: 10 %}
{% assign pill_padding_h_mobile = section.settings.pill_padding_horizontal_mobile | default: 14 %}
{% assign pill_spacing_mobile = section.settings.pill_spacing_mobile | default: 6 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '400' %}
{% assign pill_font_weight = section.settings.pill_font_weight | default: '400' %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% assign _heading_font = section.settings.font_heading | default: section.settings.font_family %}
{% case _heading_font %}
  {% when 'arial' %}{% assign font_stack_heading = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack_heading = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack_heading = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack_heading = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack_heading = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'system' %}{% assign font_stack_heading = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack_heading = font_stack %}
{% endcase %}
{% assign _pill_font = section.settings.font_pills | default: section.settings.font_family %}
{% case _pill_font %}
  {% when 'arial' %}{% assign font_stack_pills = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack_pills = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack_pills = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack_pills = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack_pills = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'system' %}{% assign font_stack_pills = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack_pills = font_stack %}
{% endcase %}
{% if pill_ls >= 10 %}
  {% assign pill_letter_spacing_em = pill_ls | append: '' | prepend: '0.' %}
{% elsif pill_ls >= 1 %}
  {% assign pill_letter_spacing_em = pill_ls | append: '' | prepend: '0.0' %}
{% else %}
  {% assign pill_letter_spacing_em = '0' %}
{% endif %}

{% capture section_aria %}
  {% if heading != blank %}
    aria-labelledby="pills-heading-{{ id }}"
  {% elsif section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Shop by category"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    background-color: {{ bg_color }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-pills__heading { color: {{ heading_color }}; }
  #shopify-section-{{ id }} .ak-category-pills .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; display: flex; flex-wrap: wrap; }
  #shopify-section-{{ id }} .ak-category-pills .container.ak-pills__container--align-left { justify-content: flex-start; }
  #shopify-section-{{ id }} .ak-category-pills .container.ak-pills__container--align-center { justify-content: center; }
  #shopify-section-{{ id }} .ak-category-pills .container.ak-pills__container--align-right { justify-content: flex-end; }
  #shopify-section-{{ id }} .ak-category-pills .container > .ak-pills__inner { flex: 0 0 auto; }
  #shopify-section-{{ id }} .ak-pills__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem {{ pill_spacing }}px;
  }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--align-left { justify-content: flex-start; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--align-center { justify-content: center; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--align-right { justify-content: flex-end; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline {
    flex-direction: row;
    flex-wrap: wrap;
  }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline.ak-pills__inner--align-left { justify-content: flex-start; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline.ak-pills__inner--align-center { justify-content: center; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline.ak-pills__inner--align-right { justify-content: flex-end; }
  #shopify-section-{{ id }} .ak-pills__heading {
    font-family: {{ font_stack_heading }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    margin: 0;
    flex: 0 0 100%;
    text-transform: none;
  }
  #shopify-section-{{ id }} .ak-pills__inner--align-left .ak-pills__heading { text-align: left; }
  #shopify-section-{{ id }} .ak-pills__inner--align-center .ak-pills__heading { text-align: center; }
  #shopify-section-{{ id }} .ak-pills__inner--align-right .ak-pills__heading { text-align: right; }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline .ak-pills__heading {
    flex: 0 0 auto;
    margin-right: 1rem;
  }
  #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline .ak-pills__list {
    flex: 1 1 auto;
  }
  #shopify-section-{{ id }} .ak-pills__inner--align-center nav,
  #shopify-section-{{ id }} .ak-pills__inner--align-center.ak-pills__inner--inline nav { flex: 0 0 auto; }
  #shopify-section-{{ id }} .ak-pills__inner--align-left .ak-pills__list { justify-content: flex-start; }
  #shopify-section-{{ id }} .ak-pills__inner--align-center .ak-pills__list { justify-content: center; }
  #shopify-section-{{ id }} .ak-pills__inner--align-right .ak-pills__list { justify-content: flex-end; }
  #shopify-section-{{ id }} .ak-pills__list {
    display: flex;
    flex-wrap: wrap;
    gap: {{ pill_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #shopify-section-{{ id }} .ak-pills__item { flex: 0 0 auto; }
  #shopify-section-{{ id }} .ak-pills__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: {{ pill_padding_v }}px {{ pill_padding_h }}px;
    background: {{ pill_bg_color }} !important;
    background-color: {{ pill_bg_color }} !important;
    color: {{ pill_text_color }} !important;
    font-family: {{ font_stack_pills }};
    font-size: {{ pill_font_size }}px;
    font-weight: {{ pill_font_weight }};
    letter-spacing: {{ pill_letter_spacing_em }}em;
    text-decoration: none !important;
    text-transform: none;
    border-radius: 7px;
    border: none !important;
    cursor: pointer;
    transition: opacity 0.2s;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-pills__pill:hover,
  #shopify-section-{{ id }} .ak-pills__pill:focus-visible { opacity: 0.85; color: {{ pill_text_color }} !important; }
  #shopify-section-{{ id }} .ak-pills__pill:focus-visible {
    outline: 2px solid {{ pill_bg_color }};
    outline-offset: 3px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-category-pills .container > .ak-pills__inner {
      flex: 1 1 100% !important;
      min-width: 0 !important;
      max-width: 100% !important;
    }
    #shopify-section-{{ id }} .ak-pills__list {
      min-width: 0 !important;
    }
    #shopify-section-{{ id }} .ak-pills__inner { gap: 0.75rem {{ pill_spacing_mobile }}px; }
    #shopify-section-{{ id }} .ak-pills__list { gap: {{ pill_spacing_mobile }}px; }
    #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline {
      flex-direction: column !important;
      align-items: stretch !important;
    }
    #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline .ak-pills__heading {
      flex: 0 0 auto !important;
      margin-right: 0 !important;
    }
    #shopify-section-{{ id }} .ak-pills__inner.ak-pills__inner--inline nav {
      flex: 0 1 auto !important;
      min-width: 0 !important;
    }
    #shopify-section-{{ id }} .ak-pills__pill { padding: {{ pill_padding_v_mobile }}px {{ pill_padding_h_mobile }}px; font-size: {{ pill_font_size | times: 0.9375 | round }}px; }
  }
{% endstyle %}

<section class="section is-width-wide ak-category-pills" id="shopify-section-{{ id }}" {{ section_aria }}>
  <div class="container ak-pills__container--align-{{ content_alignment }}">
    <div class="ak-pills__inner ak-pills__inner--align-{{ content_alignment }} {% if layout_mode == 'inline' %}ak-pills__inner--inline{% endif %}">
      {% if heading != blank %}
        <h2 class="ak-pills__heading" id="pills-heading-{{ id }}">{{ heading }}</h2>
      {% endif %}
      <nav aria-label="{{ heading | default: section_aria_label | default: 'Shop by category' | escape }}">
        <ul class="ak-pills__list">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% if block.settings.label != blank %}
                <li class="ak-pills__item" {{ block.shopify_attributes }}>
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="ak-pills__pill">
                      {{ block.settings.label }}
                    </a>
                  {% else %}
                    <span class="ak-pills__pill" style="cursor: default;">{{ block.settings.label }}</span>
                  {% endif %}
                </li>
              {% endif %}
            {% endfor %}
          {% else %}
            {% assign default_links = section.settings.default_menu %}
            {% if default_links != blank %}
              {% for link in linklists[default_links].links %}
                <li class="ak-pills__item">
                  <a href="{{ link.url }}" class="ak-pills__pill">{{ link.title }}</a>
                </li>
              {% endfor %}
            {% endif %}
          {% endif %}
        </ul>
      </nav>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Category Pills",
  "class": "ak-category-pills-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New for the Season"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 18,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Heading font size",
      "default": 30,
      "info": "Font size for the section heading (e.g. New for the Season)."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout",
      "default": "inline",
      "options": [
        { "value": "inline", "label": "Inline (heading left, pills right)" },
        { "value": "stacked", "label": "Stacked (heading above pills)" }
      ],
      "info": "Inline matches Figma: heading and pills on the same row."
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "info": "Aligns the heading and pills as a group (left, center, or right on the page)."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "pill_background_color",
      "label": "Pill background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "pill_text_color",
      "label": "Pill text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Default font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Used when \"Same as default\" is selected for heading or pills below."
    },
    {
      "type": "select",
      "id": "font_heading",
      "label": "Section heading font",
      "default": "",
      "options": [
        { "value": "", "label": "Same as default" },
        { "value": "system", "label": "System" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Font for the section heading (e.g. \"New for the Season\"). Can be different from pill labels."
    },
    {
      "type": "select",
      "id": "font_pills",
      "label": "Pill button labels font",
      "default": "",
      "options": [
        { "value": "", "label": "Same as default" },
        { "value": "system", "label": "System" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Font for the category pill buttons. Can be different from the section heading."
    },
    {
      "type": "select",
      "id": "pill_font_weight",
      "label": "Pill font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "range",
      "id": "pill_font_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Pill font size",
      "default": 18,
      "info": "Font size for category pill labels."
    },
    {
      "type": "range",
      "id": "pill_letter_spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "label": "Pill letter spacing",
      "default": 2,
      "info": "Letter spacing (0–10, stored as % of em; 2 ≈ 0.02em)."
    },
    {
      "type": "range",
      "id": "pill_padding_vertical",
      "min": 6,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Pill height (desktop)",
      "default": 12,
      "info": "Vertical padding per pill on desktop."
    },
    {
      "type": "range",
      "id": "pill_padding_horizontal",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Pill width (desktop)",
      "default": 20,
      "info": "Horizontal padding per pill on desktop."
    },
    {
      "type": "range",
      "id": "pill_spacing",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Pill spacing (desktop)",
      "default": 8,
      "info": "Gap between pills on desktop."
    },
    {
      "type": "header",
      "content": "Pill size & spacing (mobile)"
    },
    {
      "type": "range",
      "id": "pill_padding_vertical_mobile",
      "min": 6,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Pill height (mobile)",
      "default": 10,
      "info": "Vertical padding per pill on mobile."
    },
    {
      "type": "range",
      "id": "pill_padding_horizontal_mobile",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Pill width (mobile)",
      "default": 14,
      "info": "Horizontal padding per pill on mobile."
    },
    {
      "type": "range",
      "id": "pill_spacing_mobile",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Pill spacing (mobile)",
      "default": 6,
      "info": "Gap between pills on mobile."
    },
    {
      "type": "link_list",
      "id": "default_menu",
      "label": "Default menu (if no blocks)",
      "info": "Used when no blocks are added. Otherwise use blocks below."
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (for screen readers)",
      "info": "Optional. Used when this section has no visible heading. Leave blank to use the heading above or a default."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AK Category Pills",
      "blocks": [
        { "type": "pill", "settings": { "label": "Clothing" } },
        { "type": "pill", "settings": { "label": "Shoes" } },
        { "type": "pill", "settings": { "label": "Handbags" } },
        { "type": "pill", "settings": { "label": "Watches" } },
        { "type": "pill", "settings": { "label": "Jewelry" } }
      ]
    }
  ]
}
{% endschema %}
