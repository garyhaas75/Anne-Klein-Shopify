{% comment %}
  AK Artist Series — mission band ("Where Style & Story Connect").
  Figma file: 0kmSuSntT1RaS2ElBXMw25 (AK_Homepage-2026)
  Frames: AK_Artist Series_Desktop 351:1393, AK_Artist Series_Mobile 333:422
  Composition: optional stacked Artist Series logo in a left column; heading +
  richtext body; optional Anne Klein signature image bottom-right of the band.
  Without a logo upload, layout is single-column text only.
  WCAG 2.2 AA: region landmark, configurable heading level (default h2),
  alt on logo + signature, focus-visible, prefers-reduced-motion.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign body_rt = section.settings.body %}
{% assign heading_level = section.settings.heading_level | default: 'h2' %}
{% assign text_alignment = section.settings.text_alignment | default: 'left' %}
{% assign content_max_width = section.settings.content_max_width | default: 58 %}
{% assign content_max_width_mobile = section.settings.content_max_width_mobile | default: 0 | plus: 0 %}
{% if content_max_width_mobile < 1 %}
  {% assign content_max_width_mobile = content_max_width %}
{% endif %}
{% assign content_offset_right = section.settings.content_offset_right | default: 0 %}
{% assign text_color = section.settings.text_color | default: '#000000' %}
{% assign background_color = section.settings.background_color | default: '#ffffff' %}
{% assign padding_top = section.settings.padding_top | default: 96 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 120 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: 64 %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: 80 %}
{% assign artist_series_logo = section.settings.artist_series_logo %}
{% assign artist_series_logo_alt = section.settings.artist_series_logo_alt | default: 'Anne Klein Artist Series' %}
{% assign artist_series_logo_max_width = section.settings.artist_series_logo_max_width | default: 280 %}
{% assign artist_series_logo_max_width_mobile = section.settings.artist_series_logo_max_width_mobile | default: 220 %}
{% assign signature = section.settings.signature %}
{% assign signature_alt = section.settings.signature_alt | default: 'Anne Klein signature' %}
{% assign signature_max_width = section.settings.signature_max_width | default: 320 %}
{% assign signature_max_width_mobile = section.settings.signature_max_width_mobile | default: 200 %}
{% assign signature_offset_right = section.settings.signature_offset_right | default: 32 %}
{% assign signature_offset_bottom = section.settings.signature_offset_bottom | default: 32 %}
{% assign section_aria_label = section.settings.section_aria_label %}

{% capture heading_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.heading_font_family %}{% endcapture %}
{% assign heading_font_stack = heading_font_stack | strip %}
{% assign heading_ff_mobile_setting = section.settings.heading_font_family_mobile | default: 'same' %}
{% if heading_ff_mobile_setting == 'same' %}
  {% assign heading_font_stack_mobile = heading_font_stack %}
{% else %}
  {% capture heading_font_stack_mobile %}{% render 'ak-campaign-font-stack', font_key: heading_ff_mobile_setting %}{% endcapture %}
  {% assign heading_font_stack_mobile = heading_font_stack_mobile | strip %}
{% endif %}

{% capture body_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.body_font_family %}{% endcapture %}
{% assign body_font_stack = body_font_stack | strip %}
{% assign body_ff_mobile_setting = section.settings.body_font_family_mobile | default: 'same' %}
{% if body_ff_mobile_setting == 'same' %}
  {% assign body_font_stack_mobile = body_font_stack %}
{% else %}
  {% capture body_font_stack_mobile %}{% render 'ak-campaign-font-stack', font_key: body_ff_mobile_setting %}{% endcapture %}
  {% assign body_font_stack_mobile = body_font_stack_mobile | strip %}
{% endif %}

{% assign heading_ff_mobile_resolved = heading_ff_mobile_setting %}
{% if heading_ff_mobile_resolved == 'same' %}
  {% assign heading_ff_mobile_resolved = section.settings.heading_font_family | default: 'helvetica' %}
{% endif %}
{% assign body_ff_mobile_resolved = body_ff_mobile_setting %}
{% if body_ff_mobile_resolved == 'same' %}
  {% assign body_ff_mobile_resolved = section.settings.body_font_family | default: 'helvetica' %}
{% endif %}
{% if section.settings.heading_font_family == 'amiri' or heading_ff_mobile_resolved == 'amiri' or section.settings.body_font_family == 'amiri' or body_ff_mobile_resolved == 'amiri' %}
  {% render 'ak-campaign-fonts' %}
{% endif %}

{% assign heading_size = section.settings.heading_font_size | default: 46 %}
{% assign heading_size_mobile = section.settings.heading_font_size_mobile | default: 0 | plus: 0 %}
{% if heading_size_mobile < 1 %}
  {% assign heading_size_mobile = heading_size %}
{% endif %}
{% assign heading_weight = section.settings.heading_font_weight | default: '700' %}
{% assign body_size = section.settings.body_font_size | default: 18 %}
{% assign body_size_mobile = section.settings.body_font_size_mobile | default: 0 | plus: 0 %}
{% if body_size_mobile < 1 %}
  {% assign body_size_mobile = body_size %}
{% endif %}
{% assign body_weight = section.settings.body_font_weight | default: '400' %}
{% assign body_lh = section.settings.body_line_height | default: 145 %}
{% assign body_lh_mobile = section.settings.body_line_height_mobile | default: 0 | plus: 0 %}
{% if body_lh_mobile < 1 %}
  {% assign body_lh_mobile = body_lh %}
{% endif %}

{% assign heading_container_max_width = section.settings.heading_container_max_width | default: 0 | plus: 0 %}
{% assign heading_container_max_width_m0 = section.settings.heading_container_max_width_mobile | default: 0 | plus: 0 %}
{% if heading_container_max_width_m0 < 0.001 %}
  {% assign heading_container_max_width_mobile = heading_container_max_width %}
{% else %}
  {% assign heading_container_max_width_mobile = heading_container_max_width_m0 %}
{% endif %}

{% assign heading_padding_top = section.settings.heading_padding_top | default: 0 %}
{% assign heading_padding_right = section.settings.heading_padding_right | default: 0 %}
{% assign heading_padding_bottom = section.settings.heading_padding_bottom | default: 20 %}
{% assign heading_padding_left = section.settings.heading_padding_left | default: 0 %}
{% assign heading_padding_top_m = section.settings.heading_padding_top_mobile | default: 0 %}
{% assign heading_padding_right_m = section.settings.heading_padding_right_mobile | default: 0 %}
{% assign heading_padding_bottom_m = section.settings.heading_padding_bottom_mobile | default: 20 %}
{% assign heading_padding_left_m = section.settings.heading_padding_left_mobile | default: 0 %}

{% assign body_container_max_width = section.settings.body_container_max_width | default: 0 | plus: 0 %}
{% assign body_container_max_width_m0 = section.settings.body_container_max_width_mobile | default: 0 | plus: 0 %}
{% if body_container_max_width_m0 < 0.001 %}
  {% assign body_container_max_width_mobile = body_container_max_width %}
{% else %}
  {% assign body_container_max_width_mobile = body_container_max_width_m0 %}
{% endif %}

{% assign body_padding_top = section.settings.body_padding_top | default: 0 %}
{% assign body_padding_right = section.settings.body_padding_right | default: 0 %}
{% assign body_padding_bottom = section.settings.body_padding_bottom | default: 0 %}
{% assign body_padding_left = section.settings.body_padding_left | default: 0 %}
{% assign body_padding_top_m = section.settings.body_padding_top_mobile | default: 0 %}
{% assign body_padding_right_m = section.settings.body_padding_right_mobile | default: 0 %}
{% assign body_padding_bottom_m = section.settings.body_padding_bottom_mobile | default: 0 %}
{% assign body_padding_left_m = section.settings.body_padding_left_mobile | default: 0 %}

{% capture section_aria %}
  {% if heading != blank %}
    aria-labelledby="ak-artist-series-mission-heading-{{ id }}"
  {% elsif section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Mission"
  {% endif %}
{% endcapture %}

{% capture mission_inner_block %}
  {% if heading != blank %}
    {% if heading_level == 'h1' %}
      <h1 class="ak-artist-series-mission__heading" id="ak-artist-series-mission-heading-{{ id }}">{{ heading }}</h1>
    {% elsif heading_level == 'h3' %}
      <h3 class="ak-artist-series-mission__heading" id="ak-artist-series-mission-heading-{{ id }}">{{ heading }}</h3>
    {% else %}
      <h2 class="ak-artist-series-mission__heading" id="ak-artist-series-mission-heading-{{ id }}">{{ heading }}</h2>
    {% endif %}
  {% endif %}
  {% if body_rt != blank %}
    <div class="ak-artist-series-mission__rte rte">
      {{ body_rt }}
    </div>
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    background-color: {{ background_color }};
    color: {{ text_color }};
  }
  #shopify-section-{{ id }} .ak-artist-series-mission {
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: {{ padding_top }}px clamp(1rem, 4vw, 4rem) {{ padding_bottom }}px;
    overflow: hidden;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission {
      padding: {{ padding_top_mobile }}px 1rem {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__layout {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__logo-col {
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__logo-col {
      justify-content: center;
      margin-bottom: 0.5rem;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__brand-logo {
    display: block;
    width: min({{ artist_series_logo_max_width }}px, 100%);
    height: auto;
    max-width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__brand-logo {
      width: min({{ artist_series_logo_max_width_mobile }}px, 85vw);
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__inner {
    max-width: {{ content_max_width }}rem;
    {% if text_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% elsif text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% else %}
      margin-left: 0;
      margin-right: auto;
    {% endif %}
    {% if content_offset_right > 0 %}
      margin-right: {{ content_offset_right }}rem;
    {% endif %}
    text-align: {{ text_alignment }};
    min-width: 0;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__inner {
      max-width: {{ content_max_width_mobile }}rem;
      margin-right: auto;
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__heading {
    font-family: {{ heading_font_stack }};
    /* Fluid scale: slider value matches ~1280px desktop, grows ~1.4x at 1920px, capped at 2.2x */
    font-size: clamp(1.75rem, calc({{ heading_size }}px * 0.3 + 2.6vw), calc({{ heading_size }}px * 2.2));
    font-weight: {{ heading_weight }};
    line-height: 1.15;
    margin: 0;
    padding: {{ heading_padding_top }}px {{ heading_padding_right }}px {{ heading_padding_bottom }}px {{ heading_padding_left }}px;
    box-sizing: border-box;
    width: 100%;
    {% if heading_container_max_width > 0 %}
      max-width: {{ heading_container_max_width }}rem;
    {% endif %}
    {% if text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif text_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% else %}
      margin-left: 0;
      margin-right: auto;
    {% endif %}
    color: {{ text_color }};
    overflow-wrap: break-word;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__heading {
      font-family: {{ heading_font_stack_mobile }};
      font-size: clamp(1.5rem, 7vw, {{ heading_size_mobile }}px);
      padding: {{ heading_padding_top_m }}px {{ heading_padding_right_m }}px {{ heading_padding_bottom_m }}px {{ heading_padding_left_m }}px;
      {% if heading_container_max_width_mobile > 0 %}
        max-width: {{ heading_container_max_width_mobile }}rem;
      {% else %}
        max-width: none;
      {% endif %}
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__heading:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte {
    font-family: {{ body_font_stack }};
    /* Fluid scale: slider value matches ~1280px desktop, grows up to 1.6x on ultra-wide */
    font-size: clamp(calc({{ body_size }}px * 0.85), calc({{ body_size }}px * 0.75 + 0.5vw), calc({{ body_size }}px * 1.6));
    font-weight: {{ body_weight }};
    line-height: {{ body_lh }}%;
    margin: 0;
    padding: {{ body_padding_top }}px {{ body_padding_right }}px {{ body_padding_bottom }}px {{ body_padding_left }}px;
    box-sizing: border-box;
    width: 100%;
    {% if body_container_max_width > 0 %}
      max-width: {{ body_container_max_width }}rem;
    {% endif %}
    {% if text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif text_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% else %}
      margin-left: 0;
      margin-right: auto;
    {% endif %}
    color: {{ text_color }};
  }
  /* Rich text often includes inline font-size on <p>, <span>, etc.; force the section's fluid size */
  #shopify-section-{{ id }} .ak-artist-series-mission__rte p,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte li,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte td,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte th,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte blockquote {
    font-size: clamp(calc({{ body_size }}px * 0.85), calc({{ body_size }}px * 0.75 + 0.5vw), calc({{ body_size }}px * 1.6)) !important;
    line-height: {{ body_lh }}%;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h1,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h2,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h3,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h4,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h5,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte h6 {
    font-size: clamp(calc({{ body_size }}px * 0.85), calc({{ body_size }}px * 0.75 + 0.5vw), calc({{ body_size }}px * 1.6)) !important;
    line-height: {{ body_lh }}%;
    font-weight: {{ body_weight }};
    font-family: {{ body_font_stack }};
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte p span,
  #shopify-section-{{ id }} .ak-artist-series-mission__rte li span {
    font-size: inherit !important;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte p {
    margin: 0 0 1em;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte p:last-child {
    margin-bottom: 0;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__rte a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__rte {
      font-family: {{ body_font_stack_mobile }};
      font-size: {{ body_size_mobile }}px;
      line-height: {{ body_lh_mobile }}%;
      padding: {{ body_padding_top_m }}px {{ body_padding_right_m }}px {{ body_padding_bottom_m }}px {{ body_padding_left_m }}px;
      {% if body_container_max_width_mobile > 0 %}
        max-width: {{ body_container_max_width_mobile }}rem;
      {% else %}
        max-width: none;
      {% endif %}
    }
    #shopify-section-{{ id }} .ak-artist-series-mission__rte p,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte li,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte td,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte th,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte blockquote {
      font-size: clamp(calc({{ body_size_mobile }}px * 0.85), calc({{ body_size_mobile }}px * 0.85 + 0.6vw), {{ body_size_mobile }}px) !important;
      line-height: {{ body_lh_mobile }}%;
    }
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h1,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h2,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h3,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h4,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h5,
    #shopify-section-{{ id }} .ak-artist-series-mission__rte h6 {
      font-size: clamp(calc({{ body_size_mobile }}px * 0.85), calc({{ body_size_mobile }}px * 0.85 + 0.6vw), {{ body_size_mobile }}px) !important;
      line-height: {{ body_lh_mobile }}%;
      font-weight: {{ body_weight }};
      font-family: {{ body_font_stack_mobile }};
    }
  }
  #shopify-section-{{ id }} .ak-artist-series-mission__signature {
    position: absolute;
    right: {{ signature_offset_right }}px;
    bottom: {{ signature_offset_bottom }}px;
    width: min({{ signature_max_width }}px, 30vw);
    height: auto;
    max-width: 50%;
    pointer-events: none;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-artist-series-mission__signature {
      position: static;
      display: block;
      width: min({{ signature_max_width_mobile }}px, 60vw);
      max-width: 100%;
      margin: 1.5rem auto 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-artist-series-mission * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<section
  class="section is-width-wide ak-artist-series-mission-section has-no-side-gutter has-background"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="ak-artist-series-mission">
    {% if artist_series_logo != blank %}
      <div class="ak-artist-series-mission__layout">
        <div class="ak-artist-series-mission__logo-col">
          <img
            class="ak-artist-series-mission__brand-logo"
            src="{{ artist_series_logo | image_url: width: 800 }}"
            alt="{{ artist_series_logo_alt | escape }}"
            loading="lazy"
            width="{{ artist_series_logo.width }}"
            height="{{ artist_series_logo.height }}"
          >
        </div>
        <div class="ak-artist-series-mission__inner">
          {{ mission_inner_block }}
        </div>
      </div>
    {% else %}
      <div class="ak-artist-series-mission__inner">
        {{ mission_inner_block }}
      </div>
    {% endif %}

    {% if signature != blank %}
      <img
        class="ak-artist-series-mission__signature"
        src="{{ signature | image_url: width: 600 }}"
        alt="{{ signature_alt | escape }}"
        loading="lazy"
        width="{{ signature.width }}"
        height="{{ signature.height }}"
      >
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "AK Artist Series mission",
  "class": "ak-artist-series-mission-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Mission band: optional Anne Klein Artist Series logo (left column on desktop), heading + richtext, and optional script signature bottom-right."
    },
    {
      "type": "header",
      "content": "Anne Klein Artist Series logo"
    },
    {
      "type": "image_picker",
      "id": "artist_series_logo",
      "label": "Anne Klein Artist Series logo",
      "info": "Stacked wordmark for the left column (PNG or SVG). Leave empty for text-only layout."
    },
    {
      "type": "text",
      "id": "artist_series_logo_alt",
      "label": "Logo alt text",
      "default": "Anne Klein Artist Series"
    },
    {
      "type": "range",
      "id": "artist_series_logo_max_width",
      "label": "Logo max width (desktop)",
      "min": 120,
      "max": 420,
      "step": 10,
      "default": 280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "artist_series_logo_max_width_mobile",
      "label": "Logo max width (mobile)",
      "min": 120,
      "max": 360,
      "step": 10,
      "default": 220,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where Style & Story Connect"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Anne Klein is committed to empowering women who wear its brand by partnering with entrepreneurial women to develop a print capsule collection that connects with our consumers.</p>"
    },
    {
      "type": "header",
      "content": "Bottom-right signature"
    },
    {
      "type": "image_picker",
      "id": "signature",
      "label": "Signature image",
      "info": "Recommended: SVG or transparent PNG."
    },
    {
      "type": "text",
      "id": "signature_alt",
      "label": "Signature alt text",
      "default": "Anne Klein signature"
    },
    {
      "type": "range",
      "id": "signature_max_width",
      "label": "Signature max width (desktop)",
      "min": 120,
      "max": 480,
      "step": 10,
      "default": 320,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "signature_max_width_mobile",
      "label": "Signature max width (mobile)",
      "min": 80,
      "max": 320,
      "step": 10,
      "default": 200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "signature_offset_right",
      "label": "Signature offset from right (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "signature_offset_bottom",
      "label": "Signature offset from bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
