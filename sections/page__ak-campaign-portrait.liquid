{% comment %}
  AK Campaign — full-bleed model portrait(s). Each block: image or Shopify video + name/role overlay.
  WCAG 2.2 AA: landmark, alt/video title, scrim for contrast, whole-card link for image only, native video controls, optional autoplay (pair with Start muted for browser policy), focus-visible.
{% endcomment %}

{% assign id = section.id %}
{% assign padding_top = section.settings.padding_top | default: 0 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 0 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign min_h = section.settings.portrait_min_height | default: 520 %}
{% assign scrim_opacity = section.settings.scrim_opacity | default: 72 %}
{% assign text_color = section.settings.overlay_text_color | default: '#ffffff' %}

{% assign layout_desktop = section.settings.layout_desktop | default: 'two_columns' %}
{% assign portrait_gap = section.settings.stack_gap | default: 0 %}
{% assign stack_gap_m = section.settings.stack_gap_mobile | default: 0 | plus: 0 %}
{% if stack_gap_m < 1 %}
  {% assign stack_gap_m = portrait_gap %}
{% endif %}
{% assign name_sz = section.settings.name_font_size | default: 40 %}
{% assign name_sz_m = section.settings.name_font_size_mobile | default: 0 | plus: 0 %}
{% if name_sz_m < 1 %}
  {% assign name_sz_m = name_sz %}
{% endif %}
{% assign role_sz = section.settings.role_font_size | default: 14 %}
{% assign role_sz_m = section.settings.role_font_size_mobile | default: 0 | plus: 0 %}
{% if role_sz_m < 1 %}
  {% assign role_sz_m = role_sz %}
{% endif %}
{% assign cap_v = section.settings.caption_vertical | default: 'bottom' %}
{% case cap_v %}
  {% when 'top' %}{% assign cap_justify = 'flex-start' %}
  {% when 'center' %}{% assign cap_justify = 'center' %}
  {% else %}{% assign cap_justify = 'flex-end' %}
{% endcase %}
{% assign img_fit = section.settings.image_object_fit | default: 'cover' %}
{% assign portrait_natural_height = false %}
{% if img_fit == 'natural' %}
  {% assign portrait_natural_height = true %}
{% endif %}
{% assign img_pos = section.settings.image_object_position | default: 'center' %}
{% assign ar_d = section.settings.portrait_aspect_desktop | default: 'none' %}
{% assign ar_m = section.settings.portrait_aspect_mobile | default: 'none' %}
{% assign scrim_h_pct = section.settings.scrim_height_percent | default: 45 %}
{% assign scrim_op_f = scrim_opacity | divided_by: 100.0 %}
{% capture name_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.name_font_family %}{% endcapture %}
{% assign name_font_stack = name_font_stack | strip %}
{% capture role_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.role_font_family %}{% endcapture %}
{% assign role_font_stack = role_font_stack | strip %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  /* Theme .container is flex: children need .columns.one-whole or explicit width or they shrink to content (breaks absolute-fill images). */
  #shopify-section-{{ id }} .ak-campaign-portrait__grid {
    width: 100%;
    flex: 1 1 100%;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__list {
    display: flex;
    flex-direction: column;
    gap: {{ stack_gap_m }}px;
    margin: 0;
    padding: 0;
    list-style: none;
    width: 100%;
  }
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-campaign-portrait__list {
      gap: {{ portrait_gap }}px;
    }
    #shopify-section-{{ id }} .ak-campaign-portrait__list--two-columns {
      flex-direction: row;
      flex-wrap: wrap;
      gap: {{ portrait_gap }}px;
    }
    #shopify-section-{{ id }} .ak-campaign-portrait__list--two-columns .ak-campaign-portrait__item {
      flex: 1 1 0;
      min-width: 0;
      width: auto;
      max-width: none;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__item {
    width: 100%;
    min-width: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__card {
    position: relative;
    display: block;
    overflow: hidden;
    width: 100%;
    min-height: {{ min_h }}px;
    background-color: {{ section.settings.image_letterbox_color | default: '#1a1a1a' }};
  }
  @media only screen and (min-width: 799px) {
    {% if portrait_natural_height == false %}
      {% if ar_d != blank and ar_d != 'none' %}
      #shopify-section-{{ id }} .ak-campaign-portrait__card {
        aspect-ratio: {{ ar_d }};
      }
      {% endif %}
    {% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-portrait__card {
      min-height: {{ section.settings.portrait_min_height_mobile | default: min_h }}px;
    }
    {% if portrait_natural_height == false %}
      {% if ar_m != blank and ar_m != 'none' %}
      #shopify-section-{{ id }} .ak-campaign-portrait__card {
        aspect-ratio: {{ ar_m }};
      }
      {% endif %}
    {% endif %}
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only .image-element__wrap {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media > .placeholder-svg {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media .ak-campaign-portrait__video-shell {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media img,
  #shopify-section-{{ id }} .ak-campaign-portrait__media .placeholder-svg,
  #shopify-section-{{ id }} .ak-campaign-portrait__media video.ak-campaign-portrait__video {
    width: 100%;
    height: 100%;
    {% unless portrait_natural_height %}
    object-fit: {{ img_fit }};
    object-position: {{ img_pos }};
    {% endunless %}
    display: block;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only { display: block !important; }
    /* Match desktop wrap: theme .image-element__wrap + lazysizes can shrink the img and auto-margin it off-center. */
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only .image-element__wrap {
      width: 100%;
      height: 100%;
      max-width: none;
      margin: 0;
    }
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only img,
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only .placeholder-svg,
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only video.ak-campaign-portrait__video {
      width: 100% !important;
      max-width: none;
      margin-left: 0 !important;
      margin-right: 0 !important;
      {% if portrait_natural_height %}
      height: auto !important;
      {% endif %}
    }
    #shopify-section-{{ id }} .ak-campaign-portrait__media .is-hidden-desktop-only .ak-campaign-portrait__video-shell {
      width: 100%;
      height: 100%;
      max-width: none;
      margin: 0;
    }
  }
  {% if portrait_natural_height %}
  /* Natural height: image sets card height (width 100%, height auto). Ignores aspect ratio settings. Focal point has no effect. */
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media > .placeholder-svg {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media .image-element__wrap,
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media .is-hidden-desktop-only .image-element__wrap {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media .is-hidden-desktop-only {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media .ak-campaign-portrait__video-shell {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media img,
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media .placeholder-svg,
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__media video.ak-campaign-portrait__video {
    width: 100% !important;
    height: auto !important;
    max-width: 100%;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__caption {
    position: absolute;
    inset: 0;
    min-height: 0 !important;
    width: 100%;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }}.ak-campaign-portrait-section--natural-height .ak-campaign-portrait__caption {
      min-height: 0 !important;
    }
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-campaign-portrait__scrim {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 1;
    pointer-events: none;
    height: {{ scrim_h_pct }}%;
    min-height: 120px;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--text-bottom .ak-campaign-portrait__scrim {
    bottom: 0;
    top: auto;
    background: linear-gradient(to top, rgba(0,0,0,{{ scrim_op_f }}), transparent);
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--text-top .ak-campaign-portrait__scrim {
    top: 0;
    bottom: auto;
    background: linear-gradient(to bottom, rgba(0,0,0,{{ scrim_op_f }}), transparent);
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--text-center .ak-campaign-portrait__scrim {
    top: 0;
    bottom: 0;
    height: auto;
    min-height: 0;
    background: radial-gradient(ellipse 85% 70% at 50% 50%, rgba(0,0,0,{{ scrim_op_f | times: 0.85 }}), rgba(0,0,0,0) 70%);
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__caption {
    position: relative;
    z-index: 2;
    min-height: {{ min_h }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ cap_justify }};
    align-items: {% if section.settings.caption_align == 'left' %}flex-start{% elsif section.settings.caption_align == 'right' %}flex-end{% else %}center{% endif %};
    text-align: {% if section.settings.caption_align == 'left' %}left{% elsif section.settings.caption_align == 'right' %}right{% else %}center{% endif %};
    padding: 2rem 1.5rem;
    color: {{ text_color }};
    text-shadow: 0 1px 2px rgba(0,0,0,0.85);
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--text-bottom .ak-campaign-portrait__caption {
    padding-bottom: 2.5rem;
  }
  #shopify-section-{{ id }}.ak-campaign-portrait-section--text-top .ak-campaign-portrait__caption {
    padding-top: 2.5rem;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-portrait__caption {
      min-height: {{ section.settings.portrait_min_height_mobile | default: min_h }}px;
      padding: 1.5rem 1rem;
    }
    #shopify-section-{{ id }}.ak-campaign-portrait-section--text-bottom .ak-campaign-portrait__caption {
      padding-bottom: 2rem;
    }
    #shopify-section-{{ id }}.ak-campaign-portrait-section--text-top .ak-campaign-portrait__caption {
      padding-top: 2rem;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__name {
    font-family: {{ name_font_stack }};
    font-size: clamp(1.5rem, 5vw, {{ name_sz }}px);
    font-weight: {{ section.settings.name_font_weight | default: '400' }};
    line-height: 1.15;
    margin: 0 0 0.25em;
    color: {{ text_color }};
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__role {
    font-family: {{ role_font_stack }};
    font-size: {{ role_sz }}px;
    font-weight: {{ section.settings.role_font_weight | default: '400' }};
    line-height: 1.3;
    margin: 0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ text_color }};
    opacity: 0.95;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__video-link-wrap {
    margin: 0.75rem 0 0;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__video-text-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    font-weight: 600;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__video-text-link:focus-visible {
    outline: 3px solid {{ text_color }};
    outline-offset: 2px;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__card-link:focus-visible {
    outline: 3px solid {{ text_color }};
    outline-offset: -3px;
  }
  #shopify-section-{{ id }} .ak-campaign-portrait__card-link:focus-visible .ak-campaign-portrait__name,
  #shopify-section-{{ id }} .ak-campaign-portrait__card-link:focus-visible .ak-campaign-portrait__role {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-portrait__name {
      font-size: clamp(1.5rem, 5vw, {{ name_sz_m }}px);
    }
    #shopify-section-{{ id }} .ak-campaign-portrait__role {
      font-size: {{ role_sz_m }}px;
    }
  }
{% endstyle %}

<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-campaign-portrait-section ak-campaign-portrait-section--text-{{ cap_v }} {% if layout_desktop == 'two_columns' %}ak-campaign-portrait-section--two-columns{% endif %}{% if portrait_natural_height %} ak-campaign-portrait-section--natural-height{% endif %} {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {% if section.settings.section_aria_label != blank %}
    aria-label="{{ section.settings.section_aria_label | escape }}"
  {% else %}
    aria-label="Campaign portraits"
  {% endif %}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-campaign-portrait__grid columns one-whole">
    <ul class="ak-campaign-portrait__list ak-campaign-portrait__list--{{ layout_desktop | replace: '_', '-' }}">
      {% for block in section.blocks %}
        {% if block.type == 'portrait' %}
          {% assign nm = block.settings.name %}
          {% assign rl = block.settings.role %}
          {% assign lnk = block.settings.link_url %}
          {% assign hl = block.settings.heading_level | default: 'h3' %}
          {% assign img_alt = block.settings.image_alt | default: nm | default: 'Model portrait' %}
          {% assign portrait_video_source_count = 0 %}
          {% if block.settings.video != blank %}
            {% assign portrait_video_source_count = block.settings.video.sources | size %}
          {% endif %}
          {% assign media_is_video = false %}
          {% if block.settings.media_type == 'video' and portrait_video_source_count > 0 %}
            {% assign media_is_video = true %}
          {% endif %}
          {% assign card_as_link = false %}
          {% if lnk != blank and media_is_video == false %}
            {% assign card_as_link = true %}
          {% endif %}

          <li class="ak-campaign-portrait__item" {{ block.shopify_attributes }}>
            {% if card_as_link %}
              <a
                href="{{ lnk }}"
                class="ak-campaign-portrait__card ak-campaign-portrait__card-link"
                {% if block.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                {% if nm != blank %}
                  aria-labelledby="ak-portrait-name-{{ block.id }}"
                  {% if rl != blank %}aria-describedby="ak-portrait-role-{{ block.id }}"{% endif %}
                {% elsif rl != blank %}
                  aria-label="{{ rl | escape }}"
                {% else %}
                  aria-label="{{ img_alt | escape }}"
                {% endif %}
              >
                <div class="ak-campaign-portrait__media" aria-hidden="true">
                  {% render 'ak-campaign-portrait-media', block: block, img_alt: img_alt, media_is_video: media_is_video %}
                </div>
                <div class="ak-campaign-portrait__scrim" aria-hidden="true"></div>
                <div class="ak-campaign-portrait__caption">
                  {% if nm != blank %}
                    {% if hl == 'h2' %}
                      <h2 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h2>
                    {% elsif hl == 'h4' %}
                      <h4 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h4>
                    {% else %}
                      <h3 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h3>
                    {% endif %}
                  {% endif %}
                  {% if rl != blank %}
                    <p class="ak-campaign-portrait__role" {% if nm != blank %}id="ak-portrait-role-{{ block.id }}"{% endif %}>{{ rl }}</p>
                  {% endif %}
                </div>
              </a>
            {% else %}
              <div class="ak-campaign-portrait__card">
                <div class="ak-campaign-portrait__media"{% unless media_is_video %} aria-hidden="true"{% endunless %}>
                  {% render 'ak-campaign-portrait-media', block: block, img_alt: img_alt, media_is_video: media_is_video %}
                </div>
                <div class="ak-campaign-portrait__scrim" aria-hidden="true"></div>
                <div class="ak-campaign-portrait__caption">
                  {% if nm != blank %}
                    {% if hl == 'h2' %}
                      <h2 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h2>
                    {% elsif hl == 'h4' %}
                      <h4 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h4>
                    {% else %}
                      <h3 class="ak-campaign-portrait__name" id="ak-portrait-name-{{ block.id }}">{{ nm }}</h3>
                    {% endif %}
                  {% endif %}
                  {% if rl != blank %}
                    <p class="ak-campaign-portrait__role" {% if nm != blank %}id="ak-portrait-role-{{ block.id }}"{% endif %}>{{ rl }}</p>
                  {% endif %}
                  {% if media_is_video and lnk != blank %}
                    <p class="ak-campaign-portrait__video-link-wrap">
                      <a
                        href="{{ lnk }}"
                        class="ak-campaign-portrait__video-text-link"
                        {% if block.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                      >{% if block.settings.link_title != blank %}{{ block.settings.link_title }}{% else %}Learn more{% endif %}</a>
                    </p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
    </div>
  </div>
</section>

{% assign portrait_section_autoplay = false %}
{% for block in section.blocks %}
  {% if block.type == 'portrait' %}
    {% assign _ap_vc = 0 %}
    {% if block.settings.video != blank %}
      {% assign _ap_vc = block.settings.video.sources | size %}
    {% endif %}
    {% if block.settings.media_type == 'video' and _ap_vc > 0 and block.settings.video_autoplay %}
      {% assign portrait_section_autoplay = true %}
      {% break %}
    {% endif %}
  {% endif %}
{% endfor %}
{% if portrait_section_autoplay %}
  <script>
    (function () {
      var root = document.getElementById('shopify-section-{{ id }}');
      if (!root) return;

      function playVisiblePortraitAutoplay() {
        var videos = root.querySelectorAll('.ak-campaign-portrait__video[data-ak-portrait-autoplay]');
        if (!videos.length) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          videos.forEach(function (v) {
            v.removeAttribute('autoplay');
          });
          return;
        }

        videos.forEach(function (video) {
          var shell = video.closest('.ak-campaign-portrait__video-shell');
          if (!shell || window.getComputedStyle(shell).display === 'none') return;
          video.muted = true;
          var playPromise = video.play();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(function () {});
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', playVisiblePortraitAutoplay);
      } else {
        playVisiblePortraitAutoplay();
      }

      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(playVisiblePortraitAutoplay, 200);
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "AK Campaign portrait",
  "class": "ak-campaign-portrait-section",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "paragraph",
      "content": "Add one block per full-bleed portrait. Figma uses two in a row in the scroll. Optional link wraps the whole portrait (one focus stop)."
    },
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": false,
      "info": "Off = edge-to-edge like other campaign full-bleed strips."
    },
    {
      "type": "select",
      "id": "layout_desktop",
      "label": "Desktop layout",
      "default": "two_columns",
      "info": "Two columns on large screens; one column stacked on mobile.",
      "options": [
        { "value": "two_columns", "label": "Two columns" },
        { "value": "stack", "label": "Stacked (full width each)" }
      ]
    },
    {
      "type": "select",
      "id": "caption_align",
      "label": "Name & role horizontal alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "caption_vertical",
