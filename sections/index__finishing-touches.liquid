{% comment %}
  AK Homepage 2026 – Finishing Touches
  Product carousel: title + individually selected products (blocks). Each block = one product.
  Uses theme's slider markup/JS so carousel behavior matches Featured collection.
{% endcomment %}

{% assign id = section.id %}
{% assign title = section.settings.title %}
{% assign products_per_row = section.settings.products_per | default: 4 | plus: 0 %}
{% assign align_height = section.settings.align_height %}
{% assign height = section.settings.collection_height | default: 320 | plus: 0 %}
{% assign width = section.settings.width | default: 'wide' %}
{% assign show_gutter = section.settings.show_gutter %}
{% assign padding_top = section.settings.padding_top | default: 40 | plus: 0 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 40 | plus: 0 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign heading_alignment = section.settings.heading_alignment | default: 'center' %}
{% assign heading_font_size = section.settings.heading_font_size | default: 24 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '400' %}
{% assign heading_underline = section.settings.heading_underline %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}

{% assign product_source = section.settings.product_source | default: 'blocks' %}
{% assign product_limit_setting = section.settings.products_limit | default: 12 | plus: 0 %}
{% assign collection_ref = section.settings.collection %}
{% assign products_count = 0 %}

{% if product_source == 'collection' and collection_ref != blank and collections[collection_ref] != blank %}
  {% assign collection_size = collections[collection_ref].products.size | plus: 0 %}
  {% assign products_count = product_limit_setting %}
  {% if collection_size < product_limit_setting %}
    {% assign products_count = collection_size %}
  {% endif %}
  {% assign product_limit = products_count %}
{% else %}
  {% assign block_product_count = 0 %}
  {% for block in section.blocks %}
    {% if block.type == 'product' and block.settings.product != blank %}
      {% assign block_product_count = block_product_count | plus: 1 %}
    {% endif %}
  {% endfor %}
  {% assign product_limit = product_limit_setting %}
  {% if block_product_count < product_limit_setting %}
    {% assign product_limit = block_product_count %}
  {% endif %}
  {% assign products_count = product_limit %}
{% endif %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}width: 100%;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading-wrap {
    width: 100%;
    flex: 0 0 100%;
    display: block;
    box-sizing: border-box;
    min-height: 1px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading {
    margin: 0 0 1.5rem;
    font-family: {{ font_stack }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    text-align: {{ heading_alignment }};
    text-transform: none;
    display: block;
    width: 100%;
    box-sizing: border-box;
    {% if heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
  }
  #shopify-section-{{ id }} .ak-finishing-touches__sr-status.is-sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  #shopify-section-{{ id }} .flickity-prev-next-button:focus-visible,
  #shopify-section-{{ id }} .ak-ft__product-link:focus-visible,
  #shopify-section-{{ id }} .more_color:focus-visible,
  #shopify-section-{{ id }} .flickity-page-dots .dot:focus-visible {
    outline: 2px solid currentColor; outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading:focus-visible {
    outline: 2px solid currentColor; outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-ft__product-link { text-decoration: none; color: inherit; display: block; }
  #shopify-section-{{ id }} .flickity-page-dots .dot { min-width: 24px; min-height: 24px; }
  /* Nav under slider: wrap + flex layout */
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap {
    width: 100%;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-enabled {
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-viewport {
    order: 1;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav {
    order: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button {
    position: static;
    top: auto;
    left: auto;
    right: auto;
    transform: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-page-dots {
    position: static;
    margin: 0;
    display: flex;
  }
  #shopify-section-{{ id }} .flickity-prev-next-button[aria-disabled="true"] {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .slider-gallery {
    min-height: 200px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-viewport {
    min-height: 200px;
  }
  /* Mobile: arrows only (hide dots), smaller arrow buttons (touch target ≥ 24px). !important overrides theme global .flickity-page-dots { display: block !important } on medium-down. */
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-page-dots {
      display: none !important;
    }
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button {
      display: flex !important;
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button .flickity-button-icon {
      width: 14px;
      height: 14px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }
  }
{% endstyle %}

{% assign section_aria_label = section.settings.section_aria_label %}
<section class="section is-width-{{ width }} ak-finishing-touches-section {% if show_gutter %}has-gutter-enabled{% else %}has-no-side-gutter has-background{% endif %}" id="shopify-section-{{ id }}" {% if title != blank %}aria-labelledby="finishing-heading-{{ id }}"{% elsif section_aria_label != blank %}aria-label="{{ section_aria_label | escape }}"{% else %}aria-label="Finishing touches"{% endif %}>
  {% if title != blank %}
    <div class="container ak-finishing-touches__heading-wrap">
      <h2 class="ak-finishing-touches__heading" id="finishing-heading-{{ id }}" tabindex="0">{{ title }}</h2>
    </div>
  {% endif %}
  <div class="container">
    <div class="one-whole column has-column-padding-bottom featured-collection layout--slider is-justify-center is-flex is-flex-wrap is-flex-row">
      {% if products_count > 0 %}
        <div class="ak-finishing-touches__carousel-wrap">
        <div class="slider-gallery {% if show_gutter == false %}has-no-side-gutter{% endif %} products-slider products-length-{{ products_count }} transparentBackground--{{ settings.slideshow_button_style }}"
             data-products-per-slide="{{ products_per_row }}"
             data-products-limit="{{ products_count }}"
             data-products-available="{{ products_count }}"
             role="region"
             aria-roledescription="carousel"
             aria-label="{{ title | default: 'Finishing touches' | escape }} product carousel"
             >
          {% if product_source == 'collection' and collection_ref != blank and collections[collection_ref] != blank %}
            {% for product in collections[collection_ref].products limit: product_limit %}
              {% assign hover_enabled = settings.thumbnail_hover_enabled %}
              {% if product.featured_media.preview_image.alt != blank %}
                {% assign alt_text = product.featured_media.preview_image.alt %}
              {% else %}
                {% assign alt_text = product.title %}
              {% endif %}
              <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if product.media[1] != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}">
                <a href="{{ product.url }}" class="ak-ft__product-link" aria-label="{{ product.title | escape }}">
                  <div class="product-wrap">
                    <div class="product-image__wrapper">
                      <div class="image__container product__imageContainer">
                        {% if settings.stickers_enabled %}
                          {% include 'product-thumbnail__sticker' %}
                        {% endif %}
                        {% include 'image-element', image: product.featured_media.preview_image, alt: alt_text, object_fit: align_height, max_height: height %}
                        {% if product.media[1] != blank and settings.show_secondary_image %}
                          {% include 'image-element', image: product.media[1], alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible' %}
                        {% endif %}
                      </div>
                      {% if hover_enabled or settings.enable_quickshop %}
                        <div class="thumbnail-overlay__container">
                          {% if hover_enabled %}
                            <div class="quick-shop__info animated fadeInDown">
                              <div class="thumbnail-overlay">
                                <div class="info text-align-{{ settings.thumbnail_text_alignment }}">
                                  {% include 'product-thumbnail__product-info' %}
                                </div>
                              </div>
                            </div>
                          {% endif %}
                          {% if settings.enable_quickshop %}
                            {% include 'product-thumbnail__quick-shop-button' %}
                          {% endif %}
                          {% if hover_enabled and settings.enable_shopify_collection_badges and settings.enable_shopify_review_comments %}
                            <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>
                    {% if hover_enabled == false %}
                      <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                        {% include 'product-thumbnail__product-info' %}
                      </div>
                    {% endif %}
                  </div>
                </a>
                {% include 'product-thumbnail__swatch' %}
              </div>
            {% endfor %}
          {% else %}
            {% assign output_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'product' and block.settings.product != blank %}
                {% if output_index < product_limit %}
                  {% assign product = block.settings.product %}
                  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
                  {% if product.featured_media.preview_image.alt != blank %}
                    {% assign alt_text = product.featured_media.preview_image.alt %}
                  {% else %}
                    {% assign alt_text = product.title %}
                  {% endif %}
                  <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if product.media[1] != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}" {{ block.shopify_attributes }}>
                    <a href="{{ product.url }}" class="ak-ft__product-link" aria-label="{{ product.title | escape }}">
                      <div class="product-wrap">
                        <div class="product-image__wrapper">
                          <div class="image__container product__imageContainer">
                            {% if settings.stickers_enabled %}
                              {% include 'product-thumbnail__sticker' %}
                            {% endif %}
                            {% include 'image-element', image: product.featured_media.preview_image, alt: alt_text, object_fit: align_height, max_height: height %}
                            {% if product.media[1] != blank and settings.show_secondary_image %}
                              {% include 'image-element', image: product.media[1], alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible' %}
                            {% endif %}
                          </div>
                          {% if hover_enabled or settings.enable_quickshop %}
                            <div class="thumbnail-overlay__container">
                              {% if hover_enabled %}
                                <div class="quick-shop__info animated fadeInDown">
                                  <div class="thumbnail-overlay">
                                    <div class="info text-align-{{ settings.thumbnail_text_alignment }}">
                                      {% include 'product-thumbnail__product-info' %}
                                    </div>
                                  </div>
                                </div>
                              {% endif %}
                              {% if settings.enable_quickshop %}
                                {% include 'product-thumbnail__quick-shop-button' %}
                              {% endif %}
                              {% if hover_enabled and settings.enable_shopify_collection_badges and settings.enable_shopify_review_comments %}
                                <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                        {% if hover_enabled == false %}
                          <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                            {% include 'product-thumbnail__product-info' %}
                          </div>
                        {% endif %}
                      </div>
                    </a>
                    {% include 'product-thumbnail__swatch' %}
                  </div>
                  {% assign output_index = output_index | plus: 1 %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
        </div>
      {% else %}
        <p class="text-align-center" style="margin: 0;">{% if product_source == 'collection' %}Select a collection above, or switch to "Hand-picked products" and add Product blocks below.{% else %}Add products using the "Product" blocks below.{% endif %}</p>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/json" data-section-id="{{ id }}" data-section-data>
  {
    "collection_style": "slider",
    "products_per": {{ products_per_row }},
    "products_available": {{ products_count }},
    "products_limit": {{ products_count }},
    "align_height": {{ align_height | json }}
  }
</script>
<script>
(function() {
  var sectionId = '{{ id }}';
  var arrowShape = 'M95.04 46 21.68 46 48.18 22.8 42.91 16.78 4.96 50 42.91 83.22 48.18 77.2 21.68 54 95.04 54 95.04 46z';
  var carouselLabel = {{ title | default: 'Finishing touches' | json }};

  function initFinishingTouchesCarousel() {
    if (typeof jQuery === 'undefined') return;
    var $section = jQuery('#shopify-section-' + sectionId);
    if (!$section.length) return;
    var $dataEl = $section.find('[data-section-id="' + sectionId + '"][data-section-data]').first();
    if (!$dataEl.length) return;
    var data = {};
    try {
      var raw = $dataEl.data('section-data') || $dataEl.html() || $dataEl.text();
      data = typeof raw === 'object' ? raw : JSON.parse(raw);
    } catch (e) { return; }
    if (data.collection_style !== 'slider') return;
    var $gallery = $section.find('.slider-gallery');
    if (!$gallery.length) return;
    if ($gallery.hasClass('flickity-enabled')) $gallery.flickity('destroy');

    var productsPer = Math.max(1, parseInt(data.products_per, 10) || 4);
    var productsLimit = parseInt(data.products_limit, 10) || 0;
    var showNav = productsLimit > productsPer;
    var groupSize = productsLimit > 0 ? Math.min(productsPer, productsLimit) : productsPer;

    $gallery.flickity({
      lazyLoad: 2,
      freeScroll: false,
      groupCells: groupSize,
      imagesLoaded: true,
      draggable: true,
      cellAlign: 'left',
      wrapAround: false,
      contain: true,
      pageDots: showNav,
      prevNextButtons: showNav,
      initialIndex: 0,
      arrowShape: typeof window.arrowShape !== 'undefined' ? window.arrowShape : arrowShape,
      accessibility: true,
      on: {
        ready: function() {
          setTimeout(function() {
            $gallery.flickity('resize');
            bindTrackpadScroll($gallery);
          }, 500);
          moveNavBelowSlider($section);
          labelCells($gallery);
          insertLiveRegion($gallery, $section);
          setButtonLabels($section);
          updateNavState($gallery, $section);
        },
        change: function() {
          updateNavState($gallery, $section);
        }
      }
    });
  }

  function moveNavBelowSlider($section) {
    var $gallery = $section.find('.flickity-enabled');
    if (!$gallery.length) return;
    var $prev = $gallery.find('.flickity-prev-next-button.previous');
    var $next = $gallery.find('.flickity-prev-next-button.next');
    var $dots = $gallery.find('.flickity-page-dots');
    if ($prev.length || $next.length || $dots.length) {
      var $nav = jQuery('<nav class="ak-finishing-touches__nav" aria-label="Carousel navigation"></nav>');
      if ($prev.length) $nav.append($prev);
      if ($dots.length) $nav.append($dots);
      if ($next.length) $nav.append($next);
      $gallery.append($nav);
    }
  }

  function labelCells($gallery) {
    var $cells = $gallery.find('.gallery-cell');
    $cells.each(function(i) {
      var $cell = jQuery(this);
      $cell.attr('role', 'group');
      $cell.attr('aria-roledescription', 'slide');
      var productName = $cell.find('.thumbnail__caption .product-thumbnail__title, .product-thumbnail__title, .product-info__title').first().text().trim();
      $cell.attr('aria-label', productName || ('Product ' + (i + 1) + ' of ' + $cells.length));
    });
  }

  function insertLiveRegion($gallery, $section) {
    if ($section.find('.ak-finishing-touches__sr-status').length) return;
    var $live = jQuery('<div class="ak-finishing-touches__sr-status is-sr-only" aria-live="polite" aria-atomic="true"></div>');
    $gallery.before($live);
  }

  function setButtonLabels($section) {
    $section.find('.flickity-prev-next-button.previous').attr('aria-label', 'Previous products');
    $section.find('.flickity-prev-next-button.next').attr('aria-label', 'Next products');
  }

  function updateNavState($gallery, $section) {
    var flkty = $gallery.data('flickity');
    if (!flkty) return;
    var slides = flkty.slides || [];
    var idx = flkty.selectedIndex;
    var total = slides.length;
    var isFirst = idx === 0;
    var isLast = idx >= total - 1;
    var $prev = $section.find('.flickity-prev-next-button.previous');
    var $next = $section.find('.flickity-prev-next-button.next');
    $prev.attr('aria-disabled', isFirst ? 'true' : 'false');
    $next.attr('aria-disabled', isLast ? 'true' : 'false');
    var $live = $section.find('.ak-finishing-touches__sr-status');
    if ($live.length && total > 0) {
      $live.text((carouselLabel ? carouselLabel + ', ' : '') + 'Page ' + (idx + 1) + ' of ' + total);
    }
  }

  function bindTrackpadScroll($gallery) {
    var flkty = $gallery.data('flickity');
    if (!flkty) return;
    var el = $gallery[0];
    if (!el) return;
    var accumX = 0;
    var threshold = 20;
    var locked = false;
    var lockTimer;
    var resetTimer;

    function handleWheel(e) {
      if (e.ctrlKey || e.metaKey) return;

      var absX = Math.abs(e.deltaX);
      var absY = Math.abs(e.deltaY);

      if (absX <= absY) return;

      e.preventDefault();

      if (locked) return;

      accumX += e.deltaX;
      clearTimeout(resetTimer);
      resetTimer = setTimeout(function() { accumX = 0; }, 150);

      if (accumX > threshold) {
        accumX = 0;
        locked = true;
        $gallery.flickity('next');
        clearTimeout(lockTimer);
        lockTimer = setTimeout(function() { locked = false; accumX = 0; }, 350);
      } else if (accumX < -threshold) {
        accumX = 0;
        locked = true;
        $gallery.flickity('previous');
        clearTimeout(lockTimer);
        lockTimer = setTimeout(function() { locked = false; accumX = 0; }, 350);
      }
    }

    el.addEventListener('wheel', handleWheel, { passive: false });

    var viewport = $gallery.find('.flickity-viewport')[0];
    if (viewport && viewport !== el) {
      viewport.addEventListener('wheel', handleWheel, { passive: false });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(initFinishingTouchesCarousel, 100); });
  } else {
    setTimeout(initFinishingTouchesCarousel, 100);
  }
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === sectionId) setTimeout(initFinishingTouchesCarousel, 150);
  });
})();
</script>

{% schema %}
{
  "name": "AK Finishing Touches",
  "class": "ak-finishing-touches-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "FINISHING TOUCHES",
      "info": "Section title shown above the product carousel."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Heading font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product source",
      "default": "blocks",
      "options": [
        { "value": "blocks", "label": "Hand-picked products" },
        { "value": "collection", "label": "From collection" }
      ],
      "info": "Hand-picked: use Product blocks below. From collection: choose a collection and limit."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when Product source is \"From collection\". Products use this collection's sort order. Set the collection to Best selling in Admin to show top sellers first."
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Product limit",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 12,
      "info": "Maximum number of products in the carousel. With Hand-picked products this caps how many blocks are shown; with From collection it limits how many are taken from the collection."
    },
    {
