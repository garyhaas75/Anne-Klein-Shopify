{% comment %}
  AK Homepage 2026 – Finishing Touches
  Product carousel/grid: blocks can be a product tile, or override-image-only (cleared product, e.g. coming soon).
  Uses theme's slider markup/JS so carousel behavior matches Featured collection.
{% endcomment %}

{% assign id = section.id %}
{% assign title = section.settings.title %}
{% assign products_per_row = section.settings.products_per | default: 4 | plus: 0 %}
{% assign products_per_row_mobile = section.settings.products_per_mobile | default: 2 | plus: 0 %}
{% if products_per_row_mobile < 1 %}{% assign products_per_row_mobile = 2 %}{% endif %}
{% assign layout_style = section.settings.layout_style | default: 'carousel' %}
{% assign grid_gap = section.settings.grid_gap | default: 16 | plus: 0 %}
{% assign grid_gap_mobile = section.settings.grid_gap_mobile | default: 0 | plus: 0 %}
{% if grid_gap_mobile < 1 %}{% assign grid_gap_mobile = grid_gap %}{% endif %}
{% assign show_title = section.settings.show_title %}
{% if section.settings.show_title == nil %}{% assign show_title = true %}{% endif %}
{% assign show_price = section.settings.show_price %}
{% if section.settings.show_price == nil %}{% assign show_price = true %}{% endif %}
{% assign show_more_colors = section.settings.show_more_colors %}
{% if section.settings.show_more_colors == nil %}{% assign show_more_colors = true %}{% endif %}
{% assign show_stickers = section.settings.show_stickers %}
{% if section.settings.show_stickers == nil %}{% assign show_stickers = true %}{% endif %}
{% assign align_height = section.settings.align_height %}
{% assign height = section.settings.collection_height | default: 320 | plus: 0 %}
{% assign width = section.settings.width | default: 'wide' %}
{% assign show_gutter = section.settings.show_gutter %}
{% assign padding_top = section.settings.padding_top | default: 40 | plus: 0 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 40 | plus: 0 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign heading_alignment = section.settings.heading_alignment | default: 'center' %}
{% assign heading_font_size = section.settings.heading_font_size | default: 24 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '400' %}
{% assign heading_underline = section.settings.heading_underline %}
{% assign heading_font_size_mobile = section.settings.heading_font_size_mobile | default: 0 %}
{% assign heading_alignment_mobile = section.settings.heading_alignment_mobile | default: '' %}
{% if section.settings.font_family == 'amiri' %}
  {% render 'ak-campaign-fonts' %}
{% endif %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% when 'amiri' %}{% assign font_stack = 'Amiri, Georgia, serif' %}
  {% when 'helvetica' %}{% assign font_stack = '"Helvetica Neue", Helvetica, Arial, sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}

{% assign product_source = section.settings.product_source | default: 'blocks' %}
{% assign product_limit_setting = section.settings.products_limit | default: 12 | plus: 0 %}
{% comment %}
  Collection picker returns a collection object. Resolve through collections[handle] when possible.
  If Product source is From collection but that collection has 0 products, we fall back to hand-picked Product blocks so the section does not render empty while blocks exist.
{% endcomment %}
{% assign ft_collection = section.settings.collection %}
{% if ft_collection != blank %}
  {% assign _ft_col_handle = ft_collection.handle | default: ft_collection %}
  {% if collections[_ft_col_handle] != blank %}
    {% assign ft_collection = collections[_ft_col_handle] %}
  {% endif %}
{% endif %}

{% assign use_collection_loop = false %}
{% assign collection_size = 0 %}
{% if product_source == 'collection' and ft_collection != blank %}
  {% assign collection_size = ft_collection.products_count | plus: 0 %}
  {% if collection_size > 0 %}
    {% assign use_collection_loop = true %}
  {% endif %}
{% endif %}

{% assign products_count = 0 %}
{% assign product_limit = product_limit_setting %}

{% if use_collection_loop %}
  {% assign products_count = product_limit_setting %}
  {% if collection_size < product_limit_setting %}
    {% assign products_count = collection_size %}
  {% endif %}
  {% assign product_limit = products_count %}
{% else %}
  {% assign block_product_count = 0 %}
  {% for block in section.blocks %}
    {% if block.type == 'product' %}
      {% if block.settings.product != blank %}
        {% assign block_product_count = block_product_count | plus: 1 %}
      {% elsif block.settings.override_image != blank or block.settings.override_image_mobile != blank %}
        {% assign block_product_count = block_product_count | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% assign product_limit = product_limit_setting %}
  {% if block_product_count < product_limit_setting %}
    {% assign product_limit = block_product_count %}
  {% endif %}
  {% assign products_count = product_limit %}
{% endif %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}width: 100%;{% endif %}
    max-width: 100vw;
    overflow: hidden;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading-wrap {
    width: 100%;
    flex: 0 0 100%;
    display: block;
    box-sizing: border-box;
    min-height: 1px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading {
    margin: 0 0 1.5rem;
    font-family: {{ font_stack }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    text-align: {{ heading_alignment }};
    text-transform: none;
    display: block;
    width: 100%;
    box-sizing: border-box;
    {% if heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-finishing-touches__heading {
      {% if heading_font_size_mobile > 0 %}font-size: {{ heading_font_size_mobile }}px;{% else %}font-size: {{ heading_font_size | times: 0.75 | round }}px;{% endif %}
      {% if heading_alignment_mobile != '' %}text-align: {{ heading_alignment_mobile }};{% endif %}
    }
  }
  #shopify-section-{{ id }} .ak-finishing-touches__sr-status.is-sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  #shopify-section-{{ id }} .flickity-prev-next-button:focus-visible,
  #shopify-section-{{ id }} .ak-ft__product-link:focus-visible,
  #shopify-section-{{ id }} .more_color:focus-visible,
  #shopify-section-{{ id }} .flickity-page-dots .dot:focus-visible {
    outline: 2px solid currentColor; outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__heading:focus-visible {
    outline: 2px solid currentColor; outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-ft__product-link { text-decoration: none; color: inherit; display: block; }
  #shopify-section-{{ id }} .ak-ft__image-only-tile { display: block; color: inherit; }
  #shopify-section-{{ id }} .ak-ft-img-responsive__desktop,
  #shopify-section-{{ id }} .ak-ft-img-responsive__mobile {
    width: 100%;
  }
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-ft-img-responsive__mobile {
      display: none !important;
    }
    #shopify-section-{{ id }} .ak-ft-img-responsive__desktop {
      display: block;
    }
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-ft-img-responsive__desktop {
      display: none !important;
    }
    #shopify-section-{{ id }} .ak-ft-img-responsive__mobile {
      display: block;
    }
  }
  #shopify-section-{{ id }} .flickity-page-dots .dot { min-width: 24px; min-height: 24px; }
  /* Nav under slider: wrap + flex layout */
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap {
    width: 100%;
    min-width: 0;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-enabled {
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-viewport {
    order: 1;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav {
    order: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button {
    position: static;
    top: auto;
    left: auto;
    right: auto;
    transform: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-page-dots {
    position: static;
    margin: 0;
    display: flex;
  }
  #shopify-section-{{ id }} .flickity-prev-next-button[aria-disabled="true"] {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .slider-gallery {
    min-height: 200px;
  }
  #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .flickity-viewport {
    min-height: 200px;
  }
  /* Desktop: native horizontal scroll — browser trackpad inertia (Flickity uses transforms; wheel JS cannot match this). */
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }}.ak-ft--native-desktop .ak-finishing-touches__carousel-wrap .slider-gallery {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: stretch;
      width: 100%;
      min-height: 200px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
      scroll-snap-type: x proximity;
      touch-action: pan-x pinch-zoom;
      scrollbar-gutter: stable;
    }
    #shopify-section-{{ id }}.ak-ft--native-desktop .ak-finishing-touches__carousel-wrap .slider-gallery .gallery-cell {
      scroll-snap-align: start;
      flex: 0 0 auto;
      box-sizing: border-box;
    }
  }
  @media only screen and (min-width: 799px) and (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }}.ak-ft--native-desktop .ak-finishing-touches__carousel-wrap .slider-gallery {
      scroll-behavior: auto;
    }
  }
  /* If init JS never runs (e.g. bad config parse), still show a horizontal product row on desktop. */
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }}:not(.ak-ft--native-desktop) .ak-finishing-touches__carousel-wrap .slider-gallery:not(.flickity-enabled) {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: stretch;
      width: 100%;
      min-height: 200px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }
    #shopify-section-{{ id }}:not(.ak-ft--native-desktop) .ak-finishing-touches__carousel-wrap .slider-gallery:not(.flickity-enabled) .gallery-cell {
      flex: 0 0 auto;
      min-width: 0;
      box-sizing: border-box;
    }
  }
  /* Show / hide product info inside this section only (does not affect other sections). */
  {% unless show_title %}
  #shopify-section-{{ id }} .product-thumbnail__title,
  #shopify-section-{{ id }} .product-thumbnail__vendor {
    display: none !important;
  }
  {% endunless %}
  {% unless show_price %}
  #shopify-section-{{ id }} .product-thumbnail__price,
  #shopify-section-{{ id }} .product-thumbnail__was-price {
    display: none !important;
  }
  {% endunless %}
  {% unless show_more_colors %}
  #shopify-section-{{ id }} .thumbnail-swatch,
  #shopify-section-{{ id }} .more_color {
    display: none !important;
  }
  {% endunless %}
  {% unless show_stickers %}
  #shopify-section-{{ id }} .sticker-holder,
  #shopify-section-{{ id }} .thumbnail-sticker {
    display: none !important;
  }
  {% endunless %}

  /* Static grid layout (no carousel, no horizontal scroll). */
  #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list {
    display: grid;
    grid-template-columns: repeat({{ products_per_row }}, minmax(0, 1fr));
    gap: {{ grid_gap }}px;
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list .gallery-cell {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    float: none;
  }
  #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list .gallery-cell .product-wrap,
  #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list .gallery-cell .product-image__wrapper,
  #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list .gallery-cell .image__container {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }}.ak-ft--grid .ak-finishing-touches__grid-list {
      grid-template-columns: repeat({{ products_per_row_mobile }}, minmax(0, 1fr));
      gap: {{ grid_gap_mobile }}px;
    }
  }

  /* Mobile: arrows only (hide dots), smaller arrow buttons (touch target ≥ 24px). !important overrides theme global .flickity-page-dots { display: block !important } on medium-down. */
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-page-dots {
      display: none !important;
    }
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button {
      display: flex !important;
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }
    #shopify-section-{{ id }} .ak-finishing-touches__carousel-wrap .ak-finishing-touches__nav .flickity-prev-next-button .flickity-button-icon {
      width: 14px;
      height: 14px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }
  }
{% endstyle %}

{% assign section_aria_label = section.settings.section_aria_label %}
<section class="section is-width-{{ width }} ak-finishing-touches-section {% if layout_style == 'grid' %}ak-ft--grid{% endif %} {% if show_gutter %}has-gutter-enabled{% else %}has-no-side-gutter has-background{% endif %}" id="shopify-section-{{ id }}" {% if title != blank %}aria-labelledby="finishing-heading-{{ id }}"{% elsif section_aria_label != blank %}aria-label="{{ section_aria_label | escape }}"{% else %}aria-label="Finishing touches"{% endif %}>
  {% if title != blank %}
    <div class="container ak-finishing-touches__heading-wrap">
      <h2 class="ak-finishing-touches__heading" id="finishing-heading-{{ id }}" tabindex="0">{{ title }}</h2>
    </div>
  {% endif %}
  <div class="container">
    {% comment %} No layout--slider: global jsFeaturedCollection would init a second Flickity here. Desktop uses native overflow-x scroll for real trackpad behavior. {% endcomment %}
    <div class="one-whole column has-column-padding-bottom featured-collection ak-ft-carousel-host is-justify-center is-flex is-flex-wrap is-flex-row">
      {% if products_count > 0 %}
        {% if layout_style == 'grid' %}
        <div class="ak-finishing-touches__grid-list" role="list" aria-label="{{ title | default: 'Finishing touches' | escape }} product grid">
        {% else %}
        <div class="ak-finishing-touches__carousel-wrap">
        {% comment %} data-mobile-columns must match gallery-cell medium-down--one-half (2 cols ≤798px). {% endcomment %}
        <div class="slider-gallery {% if show_gutter == false %}has-no-side-gutter{% endif %} products-slider products-length-{{ products_count }} transparentBackground--{{ settings.slideshow_button_style }}"
             data-products-per-slide="{{ products_per_row }}"
             data-products-limit="{{ products_count }}"
             data-products-available="{{ products_count }}"
             data-mobile-columns="{{ products_per_row_mobile }}"
             role="region"
             aria-roledescription="carousel"
             aria-label="{{ title | default: 'Finishing touches' | escape }} product carousel"
             >
        {% endif %}
          {% if use_collection_loop %}
            {% for product in ft_collection.products limit: product_limit %}
              {% assign hover_enabled = settings.thumbnail_hover_enabled %}
              {% if product.featured_media != blank and product.featured_media.preview_image.alt != blank %}
                {% assign alt_text = product.featured_media.preview_image.alt %}
              {% else %}
                {% assign alt_text = product.title %}
              {% endif %}
              <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if product.media[1] != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}">
                <a href="{{ product.url }}" class="ak-ft__product-link" aria-label="{{ product.title | escape }}">
                  <div class="product-wrap">
                    <div class="product-image__wrapper">
                      <div class="image__container product__imageContainer">
                        {% if settings.stickers_enabled %}
                          {% include 'product-thumbnail__sticker' %}
                        {% endif %}
                        {% if product.featured_media != blank %}
                          {% include 'image-element', image: product.featured_media.preview_image, alt: alt_text, object_fit: align_height, max_height: height %}
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                        {% if product.media[1] != blank and settings.show_secondary_image %}
                          {% include 'image-element', image: product.media[1], alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible' %}
                        {% endif %}
                      </div>
                      {% if hover_enabled or settings.enable_quickshop %}
                        <div class="thumbnail-overlay__container">
                          {% if hover_enabled %}
                            <div class="quick-shop__info animated fadeInDown">
                              <div class="thumbnail-overlay">
                                <div class="info text-align-{{ settings.thumbnail_text_alignment }}">
                                  {% include 'product-thumbnail__product-info' %}
                                </div>
                              </div>
                            </div>
                          {% endif %}
                          {% if settings.enable_quickshop %}
                            {% include 'product-thumbnail__quick-shop-button' %}
                          {% endif %}
                          {% if hover_enabled and settings.enable_shopify_collection_badges and settings.enable_shopify_review_comments %}
                            <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>
                    {% if hover_enabled == false %}
                      <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                        {% include 'product-thumbnail__product-info' %}
                      </div>
                    {% endif %}
                  </div>
                </a>
                {% include 'product-thumbnail__swatch' %}
              </div>
            {% endfor %}
          {% else %}
            {% assign output_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'product' and block.settings.product != blank %}
                {% if output_index < product_limit %}
                  {% assign product = block.settings.product %}
                  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
                  {% assign override_image = block.settings.override_image %}
                  {% assign override_image_mobile = block.settings.override_image_mobile %}
                  {% assign override_image_hover = block.settings.override_image_hover %}
                  {% assign override_image_hover_mobile = block.settings.override_image_hover_mobile %}
                  {% assign override_alt = block.settings.image_alt | strip %}
                  {% if override_image != blank %}
                    {% assign primary_desktop = override_image %}
                  {% elsif product.featured_media != blank %}
                    {% assign primary_desktop = product.featured_media.preview_image %}
                  {% else %}
                    {% assign primary_desktop = blank %}
                  {% endif %}
                  {% if override_image_mobile != blank %}
                    {% assign primary_mobile_img = override_image_mobile %}
                  {% else %}
                    {% assign primary_mobile_img = primary_desktop %}
                  {% endif %}
                  {% if override_alt != blank %}
                    {% assign alt_text = override_alt %}
                  {% elsif primary_desktop != blank and primary_desktop.alt != blank %}
                    {% assign alt_text = primary_desktop.alt %}
                  {% else %}
                    {% assign alt_text = product.title %}
                  {% endif %}
                  {% if override_image_hover != blank %}
                    {% assign hover_desktop = override_image_hover %}
                  {% elsif override_image == blank and product.media[1] != blank %}
                    {% assign hover_desktop = product.media[1] %}
                  {% else %}
                    {% assign hover_desktop = blank %}
                  {% endif %}
                  {% if override_image_hover_mobile != blank %}
                    {% assign hover_mobile_img = override_image_hover_mobile %}
                  {% else %}
                    {% assign hover_mobile_img = hover_desktop %}
                  {% endif %}
                  <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column has-thumbnail-sticker {% if hover_desktop != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %}" {{ block.shopify_attributes }}>
                    <a href="{{ product.url }}" class="ak-ft__product-link" aria-label="{{ product.title | escape }}">
                      <div class="product-wrap">
                        <div class="product-image__wrapper">
                          <div class="image__container product__imageContainer">
                            {% if settings.stickers_enabled %}
                              {% include 'product-thumbnail__sticker' %}
                            {% endif %}
                            {% if primary_desktop != blank %}
                              {% render 'ak-finishing-touches-override-img', desktop_img: primary_desktop, mobile_img: primary_mobile_img, alt: alt_text, object_fit: align_height, max_height: height %}
                            {% else %}
                              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {% endif %}
                            {% if hover_desktop != blank and settings.show_secondary_image %}
                              {% render 'ak-finishing-touches-override-img', desktop_img: hover_desktop, mobile_img: hover_mobile_img, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', secondary_pair: true %}
                            {% endif %}
                          </div>
                          {% if hover_enabled or settings.enable_quickshop %}
                            <div class="thumbnail-overlay__container">
                              {% if hover_enabled %}
                                <div class="quick-shop__info animated fadeInDown">
                                  <div class="thumbnail-overlay">
                                    <div class="info text-align-{{ settings.thumbnail_text_alignment }}">
                                      {% include 'product-thumbnail__product-info' %}
                                    </div>
                                  </div>
                                </div>
                              {% endif %}
                              {% if settings.enable_quickshop %}
                                {% include 'product-thumbnail__quick-shop-button' %}
                              {% endif %}
                              {% if hover_enabled and settings.enable_shopify_collection_badges and settings.enable_shopify_review_comments %}
                                <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                        {% if hover_enabled == false %}
                          <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                            {% include 'product-thumbnail__product-info' %}
                          </div>
                        {% endif %}
                      </div>
                    </a>
                    {% include 'product-thumbnail__swatch' %}
                  </div>
                  {% assign output_index = output_index | plus: 1 %}
                {% endif %}
              {% elsif block.type == 'product' and block.settings.product == blank %}
                {% if block.settings.override_image != blank or block.settings.override_image_mobile != blank %}
                {% if output_index < product_limit %}
                  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
                  {% assign ft_od = block.settings.override_image %}
                  {% assign ft_om = block.settings.override_image_mobile %}
                  {% assign ft_ohd = block.settings.override_image_hover %}
                  {% assign ft_ohm = block.settings.override_image_hover_mobile %}
                  {% if ft_od != blank %}
                    {% assign primary_desktop = ft_od %}
                  {% elsif ft_om != blank %}
                    {% assign primary_desktop = ft_om %}
                  {% else %}
                    {% assign primary_desktop = blank %}
                  {% endif %}
                  {% if ft_om != blank %}
                    {% assign primary_mobile_img = ft_om %}
                  {% else %}
                    {% assign primary_mobile_img = primary_desktop %}
                  {% endif %}
                  {% if ft_ohd != blank %}
                    {% assign hover_desktop = ft_ohd %}
                  {% else %}
                    {% assign hover_desktop = blank %}
                  {% endif %}
                  {% if ft_ohm != blank %}
                    {% assign hover_mobile_img = ft_ohm %}
                  {% else %}
                    {% assign hover_mobile_img = hover_desktop %}
                  {% endif %}
                  {% assign tile_title = block.settings.tile_title | strip %}
                  {% assign tile_link = block.settings.tile_link %}
                  {% assign alt_text = block.settings.image_alt | strip %}
                  {% if alt_text == blank %}
                    {% if tile_title != blank %}
                      {% assign alt_text = tile_title %}
                    {% else %}
                      {% assign alt_text = 'Featured image' %}
                    {% endif %}
                  {% endif %}
                  <div class="gallery-cell thumbnail {% include 'column-width', value: products_per_row %} medium-down--one-half column {% if hover_desktop != blank and settings.show_secondary_image %}has-secondary-image-swap{% endif %} ak-ft--image-only" {{ block.shopify_attributes }}>
                    {% if tile_link != blank %}
                      <a href="{{ tile_link }}" class="ak-ft__product-link" aria-label="{% if tile_title != blank %}{{ tile_title | escape }}{% else %}{{ alt_text | escape }}{% endif %}">
                    {% else %}
                      <div class="ak-ft__image-only-tile" role="group" {% if tile_title != blank %}aria-label="{{ tile_title | escape }}"{% elsif alt_text != blank %}aria-label="{{ alt_text | escape }}"{% endif %}>
                    {% endif %}
                      <div class="product-wrap">
                        <div class="product-image__wrapper">
                          <div class="image__container product__imageContainer">
                            {% if primary_desktop != blank %}
                              {% render 'ak-finishing-touches-override-img', desktop_img: primary_desktop, mobile_img: primary_mobile_img, alt: alt_text, object_fit: align_height, max_height: height %}
                            {% endif %}
                            {% if hover_desktop != blank and settings.show_secondary_image %}
                              {% render 'ak-finishing-touches-override-img', desktop_img: hover_desktop, mobile_img: hover_mobile_img, alt: '', object_fit: align_height, max_height: height, additional_classes: 'lazypreload secondary swap--visible', secondary_pair: true %}
                            {% endif %}
                          </div>
                        </div>
                        {% if hover_enabled == false and show_title and tile_title != blank %}
                          <div class="thumbnail__caption text-align-{{ settings.thumbnail_text_alignment }}">
                            <span class="product-thumbnail__title">{{ tile_title | escape }}</span>
                          </div>
                        {% endif %}
                      </div>
                    {% if tile_link != blank %}
                      </a>
                    {% else %}
                      </div>
                    {% endif %}
                  </div>
                  {% assign output_index = output_index | plus: 1 %}
                {% endif %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% if layout_style == 'grid' %}
        </div>
        {% else %}
        </div>
        </div>
        {% endif %}
      {% else %}
        <p class="text-align-center" style="margin: 0;">{% if product_source == 'collection' and ft_collection == blank %}Choose a collection, or set Product source to Hand-picked products and add Product blocks.{% else %}Nothing to display. Add a product or override image to each Product block (Hand-picked), or choose a collection that contains products — when the collection is empty, Product blocks below are used automatically.{% endif %}</p>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/json" data-section-id="{{ id }}" class="ak-ft__section-json">
  {
    "collection_style": "slider",
    "products_per": {{ products_per_row }},
    "products_available": {{ products_count }},
    "products_limit": {{ products_count }},
    "align_height": {{ align_height | json }}
  }
</script>
<script>
(function() {
  var sectionId = '{{ id }}';
  var arrowShape = 'M95.04 46 21.68 46 48.18 22.8 42.91 16.78 4.96 50 42.91 83.22 48.18 77.2 21.68 54 95.04 54 95.04 46z';
  var carouselLabel = {{ title | default: 'Finishing touches' | json }};
  var MOBILE_MQ = window.matchMedia('(max-width: 798px)');

  /** Config JSON must be read from script text only — jQuery .data() on data-section-data (boolean attr) breaks JSON.parse. */
  function readFinishingTouchesSectionData($section) {
    var $dataEl = $section.find('script.ak-ft__section-json[type="application/json"][data-section-id="' + sectionId + '"]').first();
    if (!$dataEl.length) return null;
    try {
      var el = $dataEl[0];
      var raw = (el && el.textContent ? el.textContent : ($dataEl.html() || '')).trim();
      if (!raw) return null;
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function getMobileColumns($gallery) {
    var n = parseInt($gallery.attr('data-mobile-columns'), 10);
    return !isNaN(n) && n > 0 ? n : 2;
  }

  function getEffectiveGroupSize(productsPer, productsLimit, isMobile, mobileColumns) {
    var perRow = isMobile ? mobileColumns : productsPer;
    var cap = productsLimit > 0 ? Math.min(perRow, productsLimit) : perRow;
    return Math.max(1, cap);
  }

  function teardownNativeCarousel($section, $gallery) {
    var n = $gallery.data('akFtNative');
    if (n && typeof n.teardown === 'function') {
      n.teardown();
    }
    $gallery.removeData('akFtNative');
    $section.removeClass('ak-ft--native-desktop');
  }

  function initNativeDesktopCarousel($section, $gallery, opts) {
    var groupSize = opts.groupSize;
    var showNav = opts.showNav;
    var scroller = $gallery[0];
    var $cells = $gallery.find('.gallery-cell');
    var totalCells = $cells.length;
    var reducedMotionMq = window.matchMedia('(prefers-reduced-motion: reduce)');

    $section.addClass('ak-ft--native-desktop');
    labelCells($gallery);
    insertLiveRegion($gallery, $section);

    var resumeRaw = $gallery.data('akFtResumeCellIndex');
    $gallery.removeData('akFtResumeCellIndex');
    if (resumeRaw != null && resumeRaw !== '') {
      var rIdx = parseInt(resumeRaw, 10);
      if (!isNaN(rIdx) && rIdx > 0 && rIdx < totalCells) {
        requestAnimationFrame(function() {
          var el = $cells.get(rIdx);
          if (el) el.scrollIntoView({ inline: 'start', block: 'nearest', behavior: reducedMotionMq.matches ? 'auto' : 'smooth' });
        });
      }
    }

    function scrollBehavior() {
      return reducedMotionMq.matches ? 'auto' : 'smooth';
    }

    function horizontalScrollAmount() {
      return Math.max(120, Math.floor(scroller.clientWidth * 0.82));
    }

    var $wrap = $gallery.closest('.ak-finishing-touches__carousel-wrap');
    var $nav;
    var $prev;
    var $next;
    var $dotsWrap;

    if (showNav) {
      var prevSvg = '<svg class="flickity-button-icon" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path fill="currentColor" d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>';
      var nextSvg = '<svg class="flickity-button-icon" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>';
      $nav = jQuery('<nav class="ak-finishing-touches__nav" aria-label="Carousel navigation"></nav>');
      $prev = jQuery('<button type="button" class="flickity-button flickity-prev-next-button previous"></button>').html(prevSvg);
      $next = jQuery('<button type="button" class="flickity-button flickity-prev-next-button next"></button>').html(nextSvg);
      $prev.attr('aria-label', 'Previous products');
      $next.attr('aria-label', 'Next products');
      $dotsWrap = jQuery('<div class="flickity-page-dots" role="tablist"></div>');
      var numPages = Math.max(1, Math.ceil(totalCells / groupSize));
      for (var p = 0; p < numPages; p++) {
        var $dot = jQuery('<button type="button" class="dot" role="tab"></button>');
        $dot.attr('aria-label', 'Go to page ' + (p + 1) + ' of ' + numPages);
        $dotsWrap.append($dot);
      }
      $nav.append($prev, $dotsWrap, $next);
      $wrap.append($nav);
    }

    function updateNativeNav() {
      if (!showNav) return;
      var maxS = scroller.scrollWidth - scroller.clientWidth;
      var atStart = scroller.scrollLeft <= 2;
      var atEnd = maxS <= 2 || scroller.scrollLeft >= maxS - 2;
      $prev.attr('aria-disabled', atStart ? 'true' : 'false');
      $next.attr('aria-disabled', atEnd ? 'true' : 'false');
      var numPages = Math.max(1, Math.ceil(totalCells / groupSize));
      var progress = maxS > 0 ? scroller.scrollLeft / maxS : 0;
      var activePage = numPages <= 1 ? 0 : Math.min(numPages - 1, Math.round(progress * (numPages - 1)));
      $dotsWrap.find('.dot').each(function(i) {
        var on = i === activePage;
        var $d = jQuery(this);
        $d.attr('aria-selected', on ? 'true' : 'false');
        $d.attr('tabindex', on ? '0' : '-1');
        if (on) {
          $d.attr('aria-current', 'true');
        } else {
          $d.removeAttr('aria-current');
        }
        $d.toggleClass('is-selected', on);
      });
      var $live = $section.find('.ak-finishing-touches__sr-status');
      if ($live.length) {
        $live.text((carouselLabel ? carouselLabel + ', ' : '') + 'Page ' + (activePage + 1) + ' of ' + numPages);
      }
    }

    var scrollTick;
    function onScroll() {
      if (scrollTick) return;
      scrollTick = requestAnimationFrame(function() {
        scrollTick = null;
        updateNativeNav();
      });
    }

    if (showNav) {
      $prev.on('click.akftnative', function() {
        scroller.scrollBy({ left: -horizontalScrollAmount(), behavior: scrollBehavior() });
      });
      $next.on('click.akftnative', function() {
        scroller.scrollBy({ left: horizontalScrollAmount(), behavior: scrollBehavior() });
      });
      $dotsWrap.find('.dot').each(function(pageIdx) {
        jQuery(this).on('click.akftnative', function() {
          var cellIdx = pageIdx * groupSize;
          if (cellIdx >= totalCells) cellIdx = Math.max(0, totalCells - 1);
          var target = $cells.get(cellIdx);
          if (target) target.scrollIntoView({ inline: 'start', block: 'nearest', behavior: scrollBehavior() });
        });
      });
    }

    scroller.addEventListener('scroll', onScroll, { passive: true });

    $gallery.data('akFtNative', {
      teardown: function() {
        scroller.removeEventListener('scroll', onScroll);
        if (showNav) {
          $prev.off('.akftnative');
          $next.off('.akftnative');
          $dotsWrap.find('.dot').off('.akftnative');
        }
      }
    });

    setTimeout(function() {
      updateNativeNav();
    }, 50);
  }

  function initFinishingTouchesCarousel() {
    if (typeof jQuery === 'undefined') return;
    var $section = jQuery('#shopify-section-' + sectionId);
    if (!$section.length) return;
    var data = readFinishingTouchesSectionData($section);
    if (!data) return;
    if (data.collection_style !== 'slider') return;
    var $gallery = $section.find('.slider-gallery');
    if (!$gallery.length) return;

    teardownNativeCarousel($section, $gallery);
    if ($gallery.hasClass('flickity-enabled')) {
      $gallery.flickity('destroy');
    }
    $section.find('.ak-finishing-touches__nav').remove();

    var productsPer = Math.max(1, parseInt(data.products_per, 10) || 4);
    var productsLimit = parseInt(data.products_limit, 10) || 0;
    var mobileColumns = getMobileColumns($gallery);
    var isMobile = MOBILE_MQ.matches;
    var groupSize = getEffectiveGroupSize(productsPer, productsLimit, isMobile, mobileColumns);
    var showNav = productsLimit > groupSize;

    if (!isMobile) {
      initNativeDesktopCarousel($section, $gallery, { groupSize: groupSize, showNav: showNav });
      return;
    }

    var resumeRaw = $gallery.data('akFtResumeCellIndex');
    var initialIndex = 0;
    if (resumeRaw != null && resumeRaw !== '') {
      var cellIdx = parseInt(resumeRaw, 10);
      if (!isNaN(cellIdx) && cellIdx >= 0) {
        initialIndex = Math.max(0, Math.floor(cellIdx / groupSize));
      }
      $gallery.removeData('akFtResumeCellIndex');
    }

    $gallery.flickity({
      lazyLoad: 2,
      freeScroll: false,
      groupCells: groupSize,
      imagesLoaded: true,
      draggable: true,
      cellAlign: 'left',
      wrapAround: false,
      contain: true,
      pageDots: showNav,
      prevNextButtons: showNav,
      initialIndex: initialIndex,
      arrowShape: typeof window.arrowShape !== 'undefined' ? window.arrowShape : arrowShape,
      accessibility: true,
      on: {
        ready: function() {
          setTimeout(function() {
            $gallery.flickity('resize');
          }, 500);
          moveNavBelowSlider($section);
          labelCells($gallery);
          insertLiveRegion($gallery, $section);
          setButtonLabels($section);
          updateNavState($gallery, $section);
        },
        change: function() {
          updateNavState($gallery, $section);
        }
      }
    });
  }

  function onFinishingTouchesViewportChange() {
    if (typeof jQuery === 'undefined') return;
    var $section = jQuery('#shopify-section-' + sectionId);
    if (!$section.length) return;
    var $gallery = $section.find('.slider-gallery');
    if (!$gallery.length) return;
    var data = readFinishingTouchesSectionData($section);
    if (!data || data.collection_style !== 'slider') return;

    var isMobile = MOBILE_MQ.matches;
    var hasFlickity = $gallery.hasClass('flickity-enabled');
    var hasNative = $section.hasClass('ak-ft--native-desktop');

    var shouldReinit = false;
    if (isMobile && hasNative) shouldReinit = true;
    else if (!isMobile && hasFlickity) shouldReinit = true;
    else if (isMobile && hasFlickity) {
      var productsPer = Math.max(1, parseInt(data.products_per, 10) || 4);
      var productsLimit = parseInt(data.products_limit, 10) || 0;
      var mobileColumns = getMobileColumns($gallery);
      var gNow = getEffectiveGroupSize(productsPer, productsLimit, true, mobileColumns);
      var gPrev = getEffectiveGroupSize(productsPer, productsLimit, false, mobileColumns);
      if (gNow !== gPrev) shouldReinit = true;
    }

    if (!shouldReinit) return;

    if (hasFlickity) {
      var flkty = $gallery.data('flickity');
      var cellIndex = 0;
      if (flkty && flkty.selectedSlide && flkty.selectedSlide.cells && flkty.selectedSlide.cells[0]) {
        var elCell = flkty.selectedSlide.cells[0].element;
        var idx = $gallery.find('.gallery-cell').index(elCell);
        if (idx >= 0) cellIndex = idx;
      }
      $gallery.data('akFtResumeCellIndex', cellIndex);
    } else if (hasNative) {
      var sc = $gallery[0];
      var sl = sc ? sc.scrollLeft : 0;
      var best = 0;
      $gallery.find('.gallery-cell').each(function(i) {
        if (this.offsetLeft <= sl + 8) best = i;
      });
      $gallery.data('akFtResumeCellIndex', best);
    }

    initFinishingTouchesCarousel();
  }

  function moveNavBelowSlider($section) {
    var $gallery = $section.find('.flickity-enabled');
    if (!$gallery.length) return;
    var $prev = $gallery.find('.flickity-prev-next-button.previous');
    var $next = $gallery.find('.flickity-prev-next-button.next');
    var $dots = $gallery.find('.flickity-page-dots');
    if ($prev.length || $next.length || $dots.length) {
      var $nav = jQuery('<nav class="ak-finishing-touches__nav" aria-label="Carousel navigation"></nav>');
      if ($prev.length) $nav.append($prev);
      if ($dots.length) $nav.append($dots);
      if ($next.length) $nav.append($next);
      $gallery.append($nav);
    }
  }

  function labelCells($gallery) {
    var $cells = $gallery.find('.gallery-cell');
    $cells.each(function(i) {
      var $cell = jQuery(this);
      $cell.attr('role', 'group');
      $cell.attr('aria-roledescription', 'slide');
      var productName = $cell.find('.thumbnail__caption .product-thumbnail__title, .product-thumbnail__title, .product-info__title').first().text().trim();
      $cell.attr('aria-label', productName || ('Product ' + (i + 1) + ' of ' + $cells.length));
    });
  }

  function insertLiveRegion($gallery, $section) {
    if ($section.find('.ak-finishing-touches__sr-status').length) return;
    var $live = jQuery('<div class="ak-finishing-touches__sr-status is-sr-only" aria-live="polite" aria-atomic="true"></div>');
    $gallery.before($live);
  }

  function setButtonLabels($section) {
    $section.find('.flickity-prev-next-button.previous').attr('aria-label', 'Previous products');
    $section.find('.flickity-prev-next-button.next').attr('aria-label', 'Next products');
  }

  function updateNavState($gallery, $section) {
    var flkty = $gallery.data('flickity');
    if (!flkty) return;
    var slides = flkty.slides || [];
    var idx = flkty.selectedIndex;
    var total = slides.length;
    var isFirst = idx === 0;
    var isLast = idx >= total - 1;
    var $prev = $section.find('.flickity-prev-next-button.previous');
    var $next = $section.find('.flickity-prev-next-button.next');
    $prev.attr('aria-disabled', isFirst ? 'true' : 'false');
    $next.attr('aria-disabled', isLast ? 'true' : 'false');
    var $live = $section.find('.ak-finishing-touches__sr-status');
    if ($live.length && total > 0) {
      $live.text((carouselLabel ? carouselLabel + ', ' : '') + 'Page ' + (idx + 1) + ' of ' + total);
    }
  }

  if (MOBILE_MQ.addEventListener) {
    MOBILE_MQ.addEventListener('change', onFinishingTouchesViewportChange);
  } else if (MOBILE_MQ.addListener) {
    MOBILE_MQ.addListener(onFinishingTouchesViewportChange);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(initFinishingTouchesCarousel, 100); });
  } else {
    setTimeout(initFinishingTouchesCarousel, 100);
  }
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === sectionId) setTimeout(initFinishingTouchesCarousel, 150);
  });
})();
</script>

{% schema %}
{
  "name": "AK Finishing Touches",
  "class": "ak-finishing-touches-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "FINISHING TOUCHES",
      "info": "Section title shown above the product carousel."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "Heading alignment (mobile)",
      "default": "",
      "options": [
        { "value": "", "label": "Same as desktop" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Heading font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "helvetica", "label": "Helvetica Neue" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 0,
      "info": "0 = auto-scale from desktop (~75%)."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "header",
      "content": "Product card display"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show product title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_more_colors",
      "label": "Show \"+ More Colors\"",
      "default": true,
      "info": "Hides the color-count link below each product when off."
    },
    {
      "type": "checkbox",
      "id": "show_stickers",
      "label": "Show product tags / stickers",
      "default": true,
      "info": "Best seller, New, Sale, Coming Soon, Pre-order, AK Sport / Jeans, etc."
    },
    {
      "type": "header",
      "content": "Layout style"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "default": "carousel",
      "options": [
        { "value": "carousel", "label": "Carousel (scrolls)" },
        { "value": "grid", "label": "Static grid (no scroll)" }
      ],
      "info": "Carousel shows arrows/dots and scrolls horizontally. Static grid shows ALL products in a fixed columns × rows grid with no scrolling."
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product source",
      "default": "blocks",
      "options": [
        { "value": "blocks", "label": "Hand-picked products" },
        { "value": "collection", "label": "From collection" }
      ],
      "info": "Hand-picked: Product blocks below drive the carousel. From collection: uses that collection’s products when it has at least one; if the collection is empty, Product blocks are used instead so the section is not blank."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when Product source is \"From collection\". Products use this collection's sort order. Set the collection to Best selling in Admin to show top sellers first."
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Product limit",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 12,
      "info": "Maximum number of products in the carousel. With Hand-picked products this caps how many blocks are shown; with From collection it limits how many are taken from the collection."
    },
    {
      "type": "range",
      "id": "products_per",
      "label": "Products per row (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "Carousel: products visible at once. Static grid: columns on desktop (≥799px)."
    },
    {
      "type": "range",
      "id": "products_per_mobile",
      "label": "Products per row (mobile)",
      "min": 1,
