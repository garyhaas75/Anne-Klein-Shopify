{% if type == 'block' %}
  {% assign object = block %}
{% else %}
  {% assign object = section %}
{% endif %}

{% assign id = object.id %}
{% comment %}Layout{% endcomment %}
{% assign width = object.settings.width %}
{% assign padding_top = object.settings.padding_top %}
{% assign padding_bottom = object.settings.padding_bottom %}
{% comment %} Advanced {% endcomment %}
{% assign css_class = object.settings.css_class %}
{% assign custom_css = object.settings.custom_css %}


{% style %}
  .section__wrapper {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' -%}
      width: 100%;
      max-width: 95%;
    {%- endif %}
  }

  .on-subcollection-page.section__wrapper {
    {% if width == 'wide' -%}
      max-width: none;
    {%- endif %}
  }

  {% if object.settings.collection_breadcrumb == false %}
    .breadcrumb__container, .collection__breadcrumb {
      display: none;
    }
  {% endif %}

  {% if object.settings.pagination_type != 'basic_pagination' %}
    .breadcrumb__page-count {
      display: none;
    }
  {% endif %}

  {% if object.settings.collection_tags == false %}
    .collection__tag-filter {
      display: none;
    }
  {% endif %}

  {% if object.settings.collection_sort == false %}
    .collection__sort-by-filter {
      display: none;
    }
  {% endif %}

  {% include 'css-loop', css: custom_css, id: id %}
{% endstyle %}


<div
    id="template-collection"
        class="shopify-section collection-page"
        data-check-for-order="true"
>
    {% render 'stylitics-gallery-widget', tag: collection.metafields.stylitics.tag %}

    {% comment %} Collection banner {% endcomment %}
    {% if section.settings.show_banner %}

        {% comment %}Assign object as block or section{% endcomment %}
        {% if type == 'block' %}
            {% assign object = block %}
        {% else %}
            {% assign object = section %}
        {% endif %}

        {% assign id = section.id %}

        {% comment %}Layout{% endcomment %}
        {% assign heading_alignment = object.settings.heading_alignment %}
        {% assign vertical_spacing = object.settings.vertical_spacing %}
        {% assign width = object.settings.width %}
        {% assign padding_top = object.settings.padding_top %}
        {% assign padding_bottom = object.settings.padding_bottom %}
        {% assign animation = object.settings.animation | default: 'none' %}
        {% comment %} Advanced {% endcomment %}
        {% assign css_class = object.settings.css_class %}
        {% assign custom_css = object.settings.custom_css %}

        {% style %}

            #shopify-section-{{ id }} {
            padding-top: {{ padding_top }}px;
            padding-bottom: {{ padding_bottom }}px;
            {% if width == 'wide' -%}
                width: 100%;
            {%- endif %}
            }

            {% include 'css-loop', css: section_css, id: id %}
            {% include 'css-loop', css: custom_css, id: id %}
        {% endstyle %}

        {% include 'banner', type: 'collection', subtitle: section.settings.subtitle %}

    {% endif %}


    {% if collection.metafields.banner.video[0] %}
        <div>
            <video
                    autoplay
                    playsinline
                    muted
                    loop
                    {% if collection.metafields.banner.video_placeholder[0] %}
                        poster="{{ collection.metafields.banner.video_placeholder[0].src }}"
                    {% endif %}
            >
                <source src="{{ collection.metafields.banner.video[0].src }}" type="video/mp4">
            </video>
        </div>
    {% elsif collection.metafields.banner.image_desktop[0] %}
        <div>
        {% if collection.metafields.banner.link != blank %}<a
                    href="{{ collection.metafields.banner.link }}">{% endif %}
                <img src="{{ collection.metafields.banner.image_desktop[0].src }}"
                     class="desktop_only" style="width: 100%;">
                {% if collection.metafields.banner.image_mobile[0] %}
                    <img src="{{ collection.metafields.banner.image_mobile[0].src }}"
                         class="mobile_only" style="width: 100%;">
                {% else %}
                    <img src="{{ collection.metafields.banner.image_desktop[0].src }}"
                         class="desktop_only" style="width: 100%;">
                {% endif %}
                {% if collection.metafields.banner.link != blank %}</a>{% endif %}
        </div>
    {% endif %}

    <section
            class="
      section__wrapper
      section
    "
    >
        <div class="container {% if settings.heading_divider_style == 'long' %}has-heading-divider-below {% endif %}">
            {% if section.settings.collection_breadcrumb == true %}
                <div class="collection__breadcrumb two-fifths medium-down--one-whole column has-padding-bottom">
                    {% comment %} Collection breadcrumb {% endcomment %}
                    <div class="breadcrumb__container">
                        {% include 'breadcrumb', type: 'collection' %}
                    </div>
                </div>
            {% endif %}

            <div class="collection__spacer three-fifths column hide-when-banner-enabled"></div>
            <div class="one-half medium-down--one-whole column has-no-side-gutter hide-when-banner-enabled collection-title">
                {% comment %} Collection title {% endcomment %}
                {% comment %} {% include 'heading', title: collection.title, heading_tag: 'h1', context: 'collection', text_alignment: 'left' %}  {% endcomment %}
                <div
                        class="
            heading-wrapper--collection
            heading-wrapper
            heading-wrapper--{{ settings.heading_divider_style }}
            one-whole column
            is-flex
            is-flex-column
            is-align-left
            text-align-left
          "
                >
                    <h1 class="collection__title title">
                        {{ collection.title }}
                    </h1>
                </div>
            </div>
            <div class="collection__filters one-half medium-down--one-whole column">
                {% comment %} Collection filters {% endcomment %}
                {% comment %} {% include 'collection__filters' %} {% endcomment %}
                <div class="field is-grouped is-flex-wrap">
                    <div class="collection__sort-by-filter select">

                    </div>
                </div>
            </div>
            {% if settings.heading_divider_width != 0 and settings.heading_divider_style == 'long' %}
                <div class="heading-divider-below heading-wrapper one-whole column hide-when-banner-enabled">
                    <div
                            class="
              heading-divider
              heading-divider--{{ settings.heading_divider_style }}
            "
                            {% if settings.heading_divider_animation != 'none' %}
                                data-scroll-class="{{ settings.heading_divider_animation }}"
                            {% endif %}
                    ></div>
                </div>
            {% endif %}
        </div>

        {% if collection.metafields.alert.text.markdown != blank %}
            <div class="container collection_alert_wrapper desktop_only">
                <div
                        class="collection_alert column one-whole has-no-side-gutter"
                        style="background-color: {{ collection.metafields.alert.background_color }}"
                >
                    {{ collection.metafields.alert.text.markdown }}
                </div>
            </div>
        {% endif %}

        <div class="container collection__content">
            {% if collection.metafields.alert.text.markdown != blank %}
                <div class="container collection_alert_wrapper mobile_only">
                    <div
                            class="collection_alert column"
                            style="background-color: {{ collection.metafields.alert.background_color }}"
                    >
                        {{ collection.metafields.alert.text.markdown }}
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
</div>

{% schema %}

{
  "name": "CollectionHeaderP",
  "class": "shopify-section collection-page",
  "settings": [
    {
      "type": "checkbox",
      "id": "collection_breadcrumb",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "collection_tags",
      "label": "Show product tag filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "collection_sort",
      "label": "Show sort by filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "set_alt_as_decorative",
      "label": "Mark images as decorative",
      "info": "Sets alt text to an empty string",
      "default": true
    },
    {
      "type": "header",
      "content": "Promotional banner"
    },
    {
      "type": "checkbox",
      "id": "show_promo_banner",
      "label": "Show promotional banner",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "1800 x 800px recommended"
    },
    {
      "type": "checkbox",
      "id": "image_darken",
      "label": "Darken banner image",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_title",
      "label": "Heading",
      "default": "Special sale on now!"
    },
    {
      "type": "richtext",
      "id": "promo_text",
      "label": "Text",
      "default": "<p>Description of promotion with lots of details.</p>"
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner height",
      "default": "medium",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ]
    },
    {
      "type": "header",
      "content": "Product thumbnails"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "paragraph",
      "content": "[Learn more](https://help.outofthesandbox.com/hc/en-us/articles/360022329373)"
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS Class"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS"
    }
  ]
}

{% endschema %}
