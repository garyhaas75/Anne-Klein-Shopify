{% if section.settings.video != blank %}
{% liquid
  assign use_mobile = false
  if section.settings.video_mobile != blank
    assign use_mobile = true
  endif
  assign layout = section.settings.layout | default: 'hero'
  assign is_hero = false
  if layout == 'hero'
    assign is_hero = true
  endif
  assign heading_tag = section.settings.heading_level | default: 'h1'
  assign video_fit = section.settings.video_fit | default: 'cover'
  assign bg_color = section.settings.video_background_color | default: '#000000'
%}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% assign overlay_line1_font_weight = section.settings.overlay_line1_font_weight | default: '400' %}
{% assign overlay_heading_font_weight = section.settings.overlay_heading_font_weight | default: '700' %}
{% assign overlay_cta_font_weight = section.settings.overlay_cta_font_weight | default: '700' %}
<section
  class="ak-video ak-video--{{ layout }} relative w-full overflow-hidden"
  id="ak-video-{{ section.id }}"
  role="region"
  aria-label="{{ section.settings.title | default: 'Video' | escape }}"
  {% if section.settings.autoplay %}data-autoplay="true"{% endif %}
>
  <div class="ak-video__wrap" style="background-color: {{ bg_color }};">
    <video
      class="ak-video__player w-full block"
      {% if section.settings.autoplay %}autoplay{% endif %}
      {% if section.settings.loop %}loop{% endif %}
      muted
      playsinline
      title="{{ section.settings.title | default: 'Video' | escape }}"
      {% if section.settings.transcript != blank %}aria-describedby="ak-video-transcript-{{ section.id }}"{% endif %}
      {% if use_mobile %}data-has-mobile="true"{% endif %}
      {% if section.settings.start_card_image != blank and section.settings.autoplay != true %}poster="{{ section.settings.start_card_image | image_url: width: 1920 }}"{% endif %}
    >
      {% for source in section.settings.video.sources %}
        <source
          src="{{ source.url }}"
          type="{{ source.mime_type }}"
          data-desktop-src="{{ source.url }}"
          {% if use_mobile %}
            {% for msrc in section.settings.video_mobile.sources %}
              {% if msrc.mime_type == source.mime_type %}
                data-mobile-src="{{ msrc.url }}"
              {% endif %}
            {% endfor %}
          {% endif %}
        >
      {% endfor %}
      {% if use_mobile %}
        {% for msrc in section.settings.video_mobile.sources %}
          {% assign has_match = false %}
          {% for dsrc in section.settings.video.sources %}
            {% if dsrc.mime_type == msrc.mime_type %}
              {% assign has_match = true %}
            {% endif %}
          {% endfor %}
          {% unless has_match %}
            <source
              src="{{ msrc.url }}"
              type="{{ msrc.mime_type }}"
              data-mobile-src="{{ msrc.url }}"
            >
          {% endunless %}
        {% endfor %}
      {% endif %}
    </video>

    {% comment %} Start card: desktop and mobile variants {% endcomment %}
    {% assign start_has_desktop = false %}
    {% if section.settings.start_card_image != blank or section.settings.start_card_heading != blank or section.settings.start_card_text != blank %}
      {% assign start_has_desktop = true %}
    {% endif %}
    {% assign start_has_mobile = false %}
    {% if section.settings.start_card_image_mobile != blank or section.settings.start_card_heading_mobile != blank or section.settings.start_card_text_mobile != blank %}
      {% assign start_has_mobile = true %}
    {% endif %}
    {% if start_has_desktop or start_has_mobile %}
      {% assign start_d_image = section.settings.start_card_image | default: section.settings.start_card_image_mobile %}
      {% assign start_d_heading = section.settings.start_card_heading | default: section.settings.start_card_heading_mobile %}
      {% assign start_d_text = section.settings.start_card_text | default: section.settings.start_card_text_mobile %}
      {% assign start_m_image = section.settings.start_card_image_mobile | default: section.settings.start_card_image %}
      {% assign start_m_heading = section.settings.start_card_heading_mobile | default: section.settings.start_card_heading %}
      {% assign start_m_text = section.settings.start_card_text_mobile | default: section.settings.start_card_text %}
      <div class="ak-video__start-card" id="ak-video-start-{{ section.id }}" aria-hidden="false" role="button" tabindex="0" aria-label="Play video">
        <div class="ak-video__start-card-inner ak-video__start-card--desktop">
          {% if start_d_image != blank %}
            <div class="ak-video__start-card-bg" style="background-image: url({{ start_d_image | image_url: width: 1920 }});"></div>
          {% endif %}
          <div class="ak-video__start-card-content">
            <span class="ak-video__play-circle" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" fill="rgba(0,0,0,0.4)"/>
                <polygon points="26,20 26,44 46,32" fill="white"/>
              </svg>
            </span>
            {% if start_d_heading != blank %}
              <h2 class="ak-video__start-card-heading">{{ start_d_heading }}</h2>
            {% endif %}
            {% if start_d_text != blank %}
              <p class="ak-video__start-card-text">{{ start_d_text }}</p>
            {% endif %}
          </div>
        </div>
        <div class="ak-video__start-card-inner ak-video__start-card--mobile">
          {% if start_m_image != blank %}
            <div class="ak-video__start-card-bg" style="background-image: url({{ start_m_image | image_url: width: 1200 }});"></div>
          {% endif %}
          <div class="ak-video__start-card-content">
            <span class="ak-video__play-circle" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" fill="rgba(0,0,0,0.4)"/>
                <polygon points="26,20 26,44 46,32" fill="white"/>
              </svg>
            </span>
            {% if start_m_heading != blank %}
              <h2 class="ak-video__start-card-heading">{{ start_m_heading }}</h2>
            {% endif %}
            {% if start_m_text != blank %}
              <p class="ak-video__start-card-text">{{ start_m_text }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% comment %} Logo overlay: uploaded image, size/placement/padding (desktop + mobile, mobile can be off) {% endcomment %}
    {% if is_hero and section.settings.logo_image != blank %}
      <div
        class="ak-video__logo-overlay ak-video__logo-overlay--desktop {% unless section.settings.show_logo_overlay_mobile %}ak-video__logo-overlay--hide-mobile{% endunless %}"
        aria-hidden="true"
        style="
          --logo-padding-top-d: {{ section.settings.logo_padding_top_desktop | default: 20 }}px;
          --logo-padding-right-d: {{ section.settings.logo_padding_right_desktop | default: 20 }}px;
          --logo-padding-bottom-d: {{ section.settings.logo_padding_bottom_desktop | default: 20 }}px;
          --logo-padding-left-d: {{ section.settings.logo_padding_left_desktop | default: 20 }}px;
          --logo-size-d: {{ section.settings.logo_size_desktop | default: 180 }}px;
          --logo-padding-top-m: {{ section.settings.logo_padding_top_mobile | default: 16 }}px;
          --logo-padding-right-m: {{ section.settings.logo_padding_right_mobile | default: 16 }}px;
          --logo-padding-bottom-m: {{ section.settings.logo_padding_bottom_mobile | default: 16 }}px;
          --logo-padding-left-m: {{ section.settings.logo_padding_left_mobile | default: 16 }}px;
          --logo-size-m: {{ section.settings.logo_size_mobile | default: 120 }}px;
        "
      >
        <img
          src="{{ section.settings.logo_image | image_url: width: 800 }}"
          alt=""
          role="presentation"
          width="{{ section.settings.logo_size_desktop | default: 180 }}"
          height=""
          class="ak-video__logo-overlay-img"
          loading="lazy"
          decoding="async"
        >
      </div>
    {% endif %}

    {% comment %} Overlay: Hero = three-line (subheading, heading, CTA) or single line; Feature = bottom hashtag {% endcomment %}
    {% if is_hero %}
      {% assign has_line1 = false %}
      {% if section.settings.overlay_subheading != blank %}
        {% assign has_line1 = true %}
      {% endif %}
      {% assign has_heading = false %}
      {% if section.settings.overlay_heading != blank or section.settings.overlay_text != blank %}
        {% assign has_heading = true %}
      {% endif %}
      {% assign has_cta = false %}
      {% if section.settings.overlay_cta != blank %}
        {% assign has_cta = true %}
      {% endif %}
      {% if has_line1 or has_heading or has_cta %}
        {% assign ov_pos = section.settings.overlay_vertical_position | default: 'middle' %}
        <div class="ak-video__overlay ak-video__overlay--{{ ov_pos }} ak-video__overlay--stack" style="padding-top: {{ section.settings.overlay_padding_top | default: 0 }}px; padding-bottom: {{ section.settings.overlay_padding_bottom | default: 0 }}px;">
          <div class="ak-video__overlay-inner">
            {% if has_line1 %}
              <p class="ak-video__overlay-line1" style="font-size: {{ section.settings.overlay_subheading_font_size | default: 16 }}px; color: {{ section.settings.text_color | default: '#ffffff' }}; {% if section.settings.overlay_subheading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}">{{ section.settings.overlay_subheading }}</p>
            {% endif %}
            {% if has_heading %}
              <{{ heading_tag }} class="ak-video__title ak-video__overlay-heading" style="font-size: {{ section.settings.overlay_heading_font_size | default: 48 }}px; color: {{ section.settings.text_color | default: '#ffffff' }}; {% if section.settings.overlay_heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}">{{ section.settings.overlay_heading | default: section.settings.overlay_text }}</{{ heading_tag }}>
            {% endif %}
            {% if has_cta %}
              <p class="ak-video__overlay-cta" style="font-size: {{ section.settings.overlay_cta_font_size | default: 14 }}px; color: {{ section.settings.text_color | default: '#ffffff' }}; {% if section.settings.overlay_cta_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}">{{ section.settings.overlay_cta }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% elsif section.settings.overlay_text != blank %}
      <div class="ak-video__overlay ak-video__overlay--bottom">
        <p class="ak-video__hashtag" style="color: {{ section.settings.text_color | default: '#ffffff' }};">{{ section.settings.overlay_text }}</p>
      </div>
    {% endif %}

    {% comment %} End card: desktop and mobile variants {% endcomment %}
    {% assign end_has_desktop = false %}
    {% if section.settings.end_card_image != blank or section.settings.end_card_heading != blank or section.settings.end_card_button_label != blank %}
      {% assign end_has_desktop = true %}
    {% endif %}
    {% assign end_has_mobile = false %}
    {% if section.settings.end_card_image_mobile != blank or section.settings.end_card_heading_mobile != blank or section.settings.end_card_button_label_mobile != blank %}
      {% assign end_has_mobile = true %}
    {% endif %}
    {% if end_has_desktop or end_has_mobile %}
      {% assign end_d_image = section.settings.end_card_image | default: section.settings.end_card_image_mobile %}
      {% assign end_d_heading = section.settings.end_card_heading | default: section.settings.end_card_heading_mobile %}
      {% assign end_d_btn = section.settings.end_card_button_label | default: section.settings.end_card_button_label_mobile %}
      {% assign end_m_image = section.settings.end_card_image_mobile | default: section.settings.end_card_image %}
      {% assign end_m_heading = section.settings.end_card_heading_mobile | default: section.settings.end_card_heading %}
      {% assign end_m_btn = section.settings.end_card_button_label_mobile | default: section.settings.end_card_button_label %}
      <div class="ak-video__end-card" id="ak-video-end-{{ section.id }}" aria-hidden="true" hidden>
        <div class="ak-video__end-card-inner ak-video__end-card--desktop">
          {% if end_d_image != blank %}
            <div class="ak-video__end-card-bg" style="background-image: url({{ end_d_image | image_url: width: 1920 }});"></div>
          {% endif %}
          <div class="ak-video__end-card-content">
            {% if end_d_heading != blank %}
              <h2 class="ak-video__end-card-heading">{{ end_d_heading }}</h2>
            {% endif %}
            {% if end_d_btn != blank %}
              <button type="button" class="ak-video__replay" aria-label="{{ end_d_btn | escape }}">
                {{ end_d_btn }}
              </button>
            {% endif %}
          </div>
        </div>
        <div class="ak-video__end-card-inner ak-video__end-card--mobile">
          {% if end_m_image != blank %}
            <div class="ak-video__end-card-bg" style="background-image: url({{ end_m_image | image_url: width: 1200 }});"></div>
          {% endif %}
          <div class="ak-video__end-card-content">
            {% if end_m_heading != blank %}
              <h2 class="ak-video__end-card-heading">{{ end_m_heading }}</h2>
            {% endif %}
            {% if end_m_btn != blank %}
              <button type="button" class="ak-video__replay" aria-label="{{ end_m_btn | escape }}">
                {{ end_m_btn }}
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% comment %} Mobile: tap overlay to dismiss controls (sits over video, below controls) {% endcomment %}
    <div class="ak-video__dismiss-overlay" id="ak-video-dismiss-{{ section.id }}" aria-hidden="true" tabindex="-1"></div>
    {% comment %} Controls: pause/play, mute (WCAG 2.2: 44px min, focus-visible) {% endcomment %}
    <div class="ak-video__controls">
      <button type="button" class="ak-video__pause" aria-label="Pause video" aria-pressed="false">
        <span class="ak-video__pause-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
        </span>
        <span class="ak-video__play-icon" aria-hidden="true" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7L8 5z"/></svg>
        </span>
      </button>
      <button type="button" class="ak-video__mute" aria-label="Unmute">
        <span class="ak-video__mute-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15" class="ak-video__mute-x"></line>
            <line x1="17" y1="9" x2="23" y2="15" class="ak-video__mute-x"></line>
          </svg>
        </span>
      </button>
    </div>

    {% if section.settings.transcript != blank %}
      <div id="ak-video-transcript-{{ section.id }}" class="ak-video__transcript">
        <details class="ak-video__transcript-details">
          <summary class="ak-video__transcript-summary">Transcript</summary>
          <div class="ak-video__transcript-body">{{ section.settings.transcript | newline_to_br }}</div>
        </details>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #ak-video-{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: 0;
    margin-top: 0;
    margin-bottom: 0;
    box-sizing: border-box;
    isolation: isolate;
    z-index: 0;
    {% if section.settings.section_max_width != blank and section.settings.section_max_width > 0 %}
    max-width: {{ section.settings.section_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    {% endif %}
    {% if is_hero %}
    height: 100vh;
    max-height: 100vh;
    {% else %}
    height: 60vh;
    min-height: 400px;
    {% endif %}
    {% if section.settings.section_max_height != blank and section.settings.section_max_height > 0 %}
    max-height: {{ section.settings.section_max_height }}px;
    {% endif %}
  }
  #ak-video-{{ section.id }} .ak-video__wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #ak-video-{{ section.id }} .ak-video__player {
    display: block;
    vertical-align: bottom;
    object-fit: {{ video_fit }};
    width: 100%;
    height: 100%;
    min-height: 100%;
    background-color: {{ bg_color }};
    {% if section.settings.video_max_width != blank and section.settings.video_max_width > 0 %}
    max-width: {{ section.settings.video_max_width }}px;
    {% endif %}
    {% if section.settings.video_max_height != blank and section.settings.video_max_height > 0 %}
    max-height: {{ section.settings.video_max_height }}px;
    min-height: 0;
    {% endif %}
  }
  {% comment %} When fit is cover and no max-height, extend video past container to remove black line; wrap overflow clips. {% endcomment %}
  {% if video_fit == 'cover' %}
  #ak-video-{{ section.id }} .ak-video__wrap .ak-video__player {
    min-height: calc(100% + 10px);
    margin-bottom: -6px;
  }
  {% endif %}
  {% if video_fit == 'cover' and section.settings.video_max_height != blank and section.settings.video_max_height > 0 %}
  #ak-video-{{ section.id }} .ak-video__wrap .ak-video__player {
    margin-bottom: 0;
  }
  {% endif %}
  #ak-video-{{ section.id }} .ak-video__start-card,
  #ak-video-{{ section.id }} .ak-video__end-card {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  #ak-video-{{ section.id }} .ak-video__end-card[hidden],
  #ak-video-{{ section.id }} .ak-video__start-card[hidden] {
    display: none !important;
  }
  #ak-video-{{ section.id }} .ak-video__start-card:not([hidden]),
  #ak-video-{{ section.id }} .ak-video__end-card:not([hidden]) {
    pointer-events: auto;
  }
  #ak-video-{{ section.id }} .ak-video__start-card {
    cursor: pointer;
  }
  #ak-video-{{ section.id }} .ak-video__start-card:focus-visible {
    outline: 3px solid #4A90D9;
    outline-offset: 2px;
  }
  #ak-video-{{ section.id }} .ak-video__start-card-inner,
  #ak-video-{{ section.id }} .ak-video__end-card-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  #ak-video-{{ section.id }} .ak-video__start-card-inner .ak-video__start-card-content,
  #ak-video-{{ section.id }} .ak-video__end-card-inner .ak-video__end-card-content {
    pointer-events: auto;
  }
  #ak-video-{{ section.id }} .ak-video__start-card--mobile,
  #ak-video-{{ section.id }} .ak-video__end-card--mobile {
    display: none;
  }
  @media (max-width: 768px) {
    #ak-video-{{ section.id }} .ak-video__start-card--desktop,
    #ak-video-{{ section.id }} .ak-video__end-card--desktop {
      display: none;
    }
    #ak-video-{{ section.id }} .ak-video__start-card--mobile,
    #ak-video-{{ section.id }} .ak-video__end-card--mobile {
      display: flex;
    }
  }
  #ak-video-{{ section.id }} .ak-video__start-card-bg,
  #ak-video-{{ section.id }} .ak-video__end-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  #ak-video-{{ section.id }} .ak-video__start-card-content,
  #ak-video-{{ section.id }} .ak-video__end-card-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 8px;
  }
  #ak-video-{{ section.id }} .ak-video__play-circle {
    display: block;
    margin: 0 auto 1rem;
    line-height: 0;
  }
  #ak-video-{{ section.id }} .ak-video__start-card-heading,
  #ak-video-{{ section.id }} .ak-video__end-card-heading {
    font-family: {{ font_stack }};
    font-weight: {{ overlay_heading_font_weight }};
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }
  #ak-video-{{ section.id }} .ak-video__start-card-text {
    font-family: {{ font_stack }};
    font-weight: {{ overlay_line1_font_weight }};
    margin: 0;
    font-size: 1rem;
  }
  #ak-video-{{ section.id }} .ak-video__replay {
    min-width: 44px;
    min-height: 44px;
    padding: 0.5rem 1rem;
    font-size: 1rem;
    cursor: pointer;
    background: rgba(255,255,255,0.9);
    color: #000;
    border: 2px solid transparent;
    border-radius: 4px;
    transition: background 0.2s, border-color 0.2s, outline 0.15s;
  }
  #ak-video-{{ section.id }} .ak-video__replay:hover {
    background: #fff;
  }
  #ak-video-{{ section.id }} .ak-video__replay:focus-visible {
    outline: 3px solid #4A90D9;
    outline-offset: 2px;
  }
  #ak-video-{{ section.id }} .ak-video__logo-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }
  #ak-video-{{ section.id }} .ak-video__logo-overlay-svg {
    width: 100%;
    height: 100%;
  }
  #ak-video-{{ section.id }} .ak-video__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }
  #ak-video-{{ section.id }} .ak-video__overlay--center,
  #ak-video-{{ section.id }} .ak-video__overlay--middle {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #ak-video-{{ section.id }} .ak-video__overlay--top {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  #ak-video-{{ section.id }} .ak-video__overlay--bottom:not(.ak-video__overlay--stack) {
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  #ak-video-{{ section.id }} .ak-video__overlay--stack.ak-video__overlay--bottom {
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  #ak-video-{{ section.id }} .ak-video__overlay--stack .ak-video__overlay-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.overlay_line_spacing | default: 12 }}px;
    text-align: center;
    padding: 0 !important;
    margin: 0 !important;
  }
  #ak-video-{{ section.id }} .ak-video__overlay-line1 {
    font-family: {{ font_stack }};
    font-weight: {{ overlay_line1_font_weight }};
    margin: 0 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding: 0 !important;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.85);
    letter-spacing: 0.05em;
    line-height: 1 !important;
  }
  #ak-video-{{ section.id }} .ak-video__overlay-cta {
    font-family: {{ font_stack }};
    font-weight: {{ overlay_cta_font_weight }};
    text-transform: uppercase;
    margin: 0 !important;
    margin-top: 0 !important;
