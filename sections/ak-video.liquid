  @media (max-width: 768px) {
    {% if section.settings.section_max_height_mobile != blank and section.settings.section_max_height_mobile > 0 %}
    #ak-video-{{ section.id }} {
      height: {{ section.settings.section_max_height_mobile }}px;
      max-height: {{ section.settings.section_max_height_mobile }}px;
    }
    {% endif %}
    /* On mobile: force controls and transcript hidden unless tap-to-show class or focus-within.
       !important overrides desktop :hover rule which has higher specificity and sticks on touch. */
    #ak-video-{{ section.id }}:not(.ak-video--controls-visible) .ak-video__controls,
    #ak-video-{{ section.id }}:not(.ak-video--controls-visible) .ak-video__transcript {
      opacity: 0 !important;
      pointer-events: none !important;
      visibility: hidden !important;
    }
    #ak-video-{{ section.id }}.ak-video--controls-visible .ak-video__controls,
    #ak-video-{{ section.id }}.ak-video--controls-visible .ak-video__transcript {
      opacity: 1 !important;
      pointer-events: auto !important;
      visibility: visible !important;
    }
    #ak-video-{{ section.id }} .ak-video__controls:focus-within,
    #ak-video-{{ section.id }} .ak-video__transcript:focus-within {
      opacity: 1 !important;
      pointer-events: auto !important;
      visibility: visible !important;
    }
    #ak-video-{{ section.id }} .ak-video__player {
      min-height: {% if is_hero %}70vh{% else %}60vh{% endif %};
      {% if section.settings.video_max_height_mobile != blank and section.settings.video_max_height_mobile > 0 %}
      max-height: {{ section.settings.video_max_height_mobile }}px;
      min-height: 0;
      {% endif %}
    }
    #ak-video-{{ section.id }} .ak-video__title {
      font-size: 2rem;
    }
    #ak-video-{{ section.id }} .ak-video__hashtag {
      font-size: 1rem;
    }
    #ak-video-{{ section.id }} .ak-video__dismiss-overlay {
      display: none;
    }
    @media (max-width: 768px) {
      #ak-video-{{ section.id }} .ak-video__dismiss-overlay {
        display: block;
        position: absolute;
        inset: 0;
        z-index: 5;
        pointer-events: none;
        width: 0;
        height: 0;
        overflow: hidden;
      }
      #ak-video-{{ section.id }}.ak-video--controls-visible .ak-video__dismiss-overlay {
        width: 100%;
        height: 100%;
        inset: 0;
        pointer-events: auto;
      }
    }
    #ak-video-{{ section.id }} .ak-video__transcript {
      max-width: 85%;
      max-height: 45vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      bottom: 1rem;
      right: 1rem;
    }
    #ak-video-{{ section.id }} .ak-video__transcript-details[open] .ak-video__transcript-body {
      max-height: 30vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #ak-video-{{ section.id }} .ak-video__controls,
    #ak-video-{{ section.id }} .ak-video__transcript {
      opacity: 1 !important;
    }
    #ak-video-{{ section.id }} .ak-video__player {
      animation: none !important;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('ak-video-{{ section.id }}');
    if (!section) return;
    var video = section.querySelector('.ak-video__player');
    if (!video) return;
    var muteBtn = section.querySelector('.ak-video__mute');
    var pauseBtn = section.querySelector('.ak-video__pause');
    var startCard = section.querySelector('#ak-video-start-{{ section.id }}');
    var endCard = section.querySelector('#ak-video-end-{{ section.id }}');
    var dismissOverlay = section.querySelector('.ak-video__dismiss-overlay');
    var loop = {{ section.settings.loop | default: true }};
    var isMobile = window.matchMedia('(max-width: 768px)').matches;
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var wantsAutoplay = section.dataset.autoplay === 'true' && !reducedMotion;

    video.removeAttribute('controls');

    /* --- 1. Mobile source swap --- */
    var didSourceSwap = false;
    if (video.dataset.hasMobile === 'true' && isMobile) {
      video.querySelectorAll('source[data-mobile-src]').forEach(function(s) {
        s.src = s.dataset.mobileSrc;
      });
      video.load();
      didSourceSwap = true;
    }

    /* --- 2. Reduced motion --- */
    if (reducedMotion) {
      video.autoplay = false;
      video.pause();
    }

    /* --- 3. Card helpers --- */
    function show(el) {
      if (!el) return;
      el.removeAttribute('hidden');
      el.setAttribute('aria-hidden', 'false');
    }
    function hide(el) {
      if (!el) return;
      el.setAttribute('hidden', '');
      el.setAttribute('aria-hidden', 'true');
    }

    /* --- 4. Video events for cards --- */
    video.addEventListener('play', function() {
      hide(startCard);
      hide(endCard);
      updatePauseBtn();
    });
    video.addEventListener('pause', function() {
      updatePauseBtn();
    });
    video.addEventListener('ended', function() {
      if (!loop) show(endCard);
      updatePauseBtn();
    });

    /* --- 5. Start card: always visible initially, tap to play --- */
    if (startCard) {
      show(startCard);
      startCard.addEventListener('click', function() {
        video.play();
      });
      startCard.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          video.play();
        }
      });
    }

    /* --- 6. End card: replay --- */
    if (endCard) {
      hide(endCard);
      section.querySelectorAll('.ak-video__replay').forEach(function(btn) {
        btn.addEventListener('click', function() {
          video.currentTime = 0;
          video.play();
        });
      });
    }

    /* --- 7. Autoplay --- */
    if (wantsAutoplay) {
      if (!video.paused) {
        hide(startCard);
      } else {
        video.muted = true;
        if (video.readyState >= 3) {
          video.play().catch(function() {});
        } else {
          video.addEventListener('canplay', function() {
            video.muted = true;
            video.play().catch(function() {});
          }, { once: true });
        }
      }
    }

    /* --- 8. Mute button --- */
    function updateMuteBtn() {
      if (!muteBtn) return;
      muteBtn.setAttribute('aria-label', video.muted ? 'Unmute' : 'Mute');
      muteBtn.setAttribute('data-playing', video.muted ? 'false' : 'true');
      muteBtn.querySelectorAll('.ak-video__mute-x').forEach(function(line) {
        line.style.display = video.muted ? '' : 'none';
      });
    }
    if (muteBtn) {
      updateMuteBtn();
      muteBtn.addEventListener('click', function() {
        video.muted = !video.muted;
        updateMuteBtn();
      });
    }

    /* --- 9. Pause/play button --- */
    function updatePauseBtn() {
      if (!pauseBtn) return;
      var paused = video.paused;
      pauseBtn.setAttribute('aria-label', paused ? 'Play video' : 'Pause video');
      pauseBtn.setAttribute('aria-pressed', paused ? 'true' : 'false');
      var pauseIcon = pauseBtn.querySelector('.ak-video__pause-icon');
      var playIcon = pauseBtn.querySelector('.ak-video__play-icon');
      if (pauseIcon && playIcon) {
        pauseIcon.hidden = paused;
        playIcon.hidden = !paused;
      }
    }
    if (pauseBtn) {
      updatePauseBtn();
      pauseBtn.addEventListener('click', function() {
        if (video.paused) video.play(); else video.pause();
      });
    }

    /* --- 10. Mobile controls toggle --- */
    if (isMobile) {
      section.addEventListener('click', function(e) {
        if (e.target.closest('.ak-video__mute') || e.target.closest('.ak-video__pause') ||
            e.target.closest('.ak-video__transcript') || e.target.closest('.ak-video__start-card') ||
            e.target.closest('.ak-video__end-card') || e.target.closest('.ak-video__dismiss-overlay')) return;
        section.classList.toggle('ak-video--controls-visible');
      });
      if (dismissOverlay) {
        dismissOverlay.addEventListener('click', function(e) {
          e.stopPropagation();
          section.classList.remove('ak-video--controls-visible');
        });
      }
    }

    /* --- 11. ADA GlobalPause --- */
    function registerGlobalPause() {
      if (!window.ADA_GlobalPause || !window.ADA_GlobalPause.registerCustom) return;
      window.ADA_GlobalPause.registerCustom({
        pause: function() { video.pause(); },
        resume: function() { video.play(); }
      });
      if (window.ADA_GlobalPause.isPaused && window.ADA_GlobalPause.isPaused()) {
        video.pause();
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        if (window.ADA_GlobalPause) registerGlobalPause();
        else document.addEventListener('ada-global-pause:ready', registerGlobalPause);
      });
    } else {
      if (window.ADA_GlobalPause) registerGlobalPause();
      else document.addEventListener('ada-global-pause:ready', registerGlobalPause);
    }
    document.addEventListener('ada-global-pause:changed', function(e) {
      if (e.detail && e.detail.paused) { video.pause(); }
      else { video.play(); }
    });
  })();
</script>

{% else %}
<section class="ak-video ak-video--empty" id="ak-video-{{ section.id }}" style="min-height: 400px; display: flex; align-items: center; justify-content: center; background: #000;">
  <p class="ak-video__placeholder" style="color: #fff; font-size: 1.25rem; opacity: 0.5;">Upload a video in the section settings</p>
</section>
{% endif %}

