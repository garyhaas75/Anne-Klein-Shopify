{% comment %}
  AK Campaign landing – intro: stacked or desktop split (image | text). Mobile is always stacked.
  WCAG 2.2 AA: landmark, heading level, focus-visible, alt text.
{% endcomment %}

{% assign id = section.id %}
{% assign layout_desktop = section.settings.layout_desktop | default: 'split' %}
{% assign split_img_fit = section.settings.split_image_object_fit | default: 'cover' %}
{% assign split_img_pos = section.settings.split_image_object_position | default: 'center' %}
{% assign image = section.settings.image %}
{% assign mobile_image = section.settings.mobile_image | default: image %}
{% assign eyebrow = section.settings.eyebrow %}
{% assign heading = section.settings.heading %}
{% assign link_url = section.settings.link_url %}
{% assign text_color = section.settings.text_color | default: '#000000' %}
{% assign bg_color = section.settings.text_background_color | default: '#ffffff' %}
{% assign padding_top = section.settings.padding_top | default: 0 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 40 %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign copy_padding_top = section.settings.copy_padding_top | default: 48 %}
{% assign copy_padding_top_mobile = section.settings.copy_padding_top_mobile | default: copy_padding_top %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign heading_level = section.settings.heading_level | default: 'h2' %}
{% assign show_divider = section.settings.show_divider %}
{% assign divider_height = section.settings.divider_height | default: 250 %}
{% assign divider_width = section.settings.divider_width | default: 1 %}
{% assign divider_color = section.settings.divider_color | default: '#000000' %}
{% assign divider_height_mobile = section.settings.divider_height_mobile | default: 250 %}
{% assign divider_width_mobile = section.settings.divider_width_mobile | default: 1 %}
{% assign divider_color_mobile = section.settings.divider_color_mobile | default: '#000000' %}
{% assign img_alt = image.alt | default: heading | default: eyebrow | default: 'Campaign' %}
{% assign mobile_img_alt = mobile_image.alt | default: heading | default: eyebrow | default: 'Campaign' %}

{% capture eyebrow_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.eyebrow_font_family %}{% endcapture %}
{% assign eyebrow_font_stack = eyebrow_font_stack | strip %}
{% capture heading_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.heading_font_family %}{% endcapture %}
{% assign heading_font_stack = heading_font_stack | strip %}

{% assign eyebrow_size = section.settings.eyebrow_font_size | default: 24 %}
{% assign eyebrow_size_mobile = section.settings.eyebrow_font_size_mobile | default: 0 | plus: 0 %}
{% if eyebrow_size_mobile < 1 %}
  {% assign eyebrow_size_mobile = eyebrow_size %}
{% endif %}
{% assign eyebrow_weight = section.settings.eyebrow_font_weight | default: '400' %}
{% assign heading_size = section.settings.heading_font_size | default: 72 %}
{% assign heading_size_mobile = section.settings.heading_font_size_mobile | default: 0 | plus: 0 %}
{% if heading_size_mobile < 1 %}
  {% assign heading_size_mobile = heading_size %}
{% endif %}
{% assign heading_weight = section.settings.heading_font_weight | default: '400' %}
{% assign split_image_pct = section.settings.split_image_width | default: 50 %}
{% assign text_rule_align = section.settings.text_rule_alignment | default: 'center' %}
{% case text_rule_align %}
  {% when 'left' %}
    {% assign tra_css_text = 'left' %}
    {% assign tra_css_justify = 'flex-start' %}
    {% assign tra_css_items = 'flex-start' %}
  {% when 'right' %}
    {% assign tra_css_text = 'right' %}
    {% assign tra_css_justify = 'flex-end' %}
    {% assign tra_css_items = 'flex-end' %}
  {% else %}
    {% assign tra_css_text = 'center' %}
    {% assign tra_css_justify = 'center' %}
    {% assign tra_css_items = 'center' %}
{% endcase %}

{% capture section_aria %}
  {% if heading != blank %}
    aria-labelledby="ak-campaign-intro-heading-{{ id }}"
  {% elsif section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Campaign introduction"
  {% endif %}
{% endcapture %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__media img,
  #shopify-section-{{ id }} .ak-campaign-intro__media .placeholder-svg {
    width: 100%;
    height: auto;
    display: block;
    vertical-align: middle;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-intro__media img,
    #shopify-section-{{ id }} .ak-campaign-intro__media .placeholder-svg {
      height: auto !important;
      min-height: 0 !important;
      object-fit: initial !important;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__media .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-intro__media .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-campaign-intro__media .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__copy {
    background-color: {{ bg_color }};
    color: {{ text_color }};
    padding: {{ copy_padding_top }}px 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: {{ tra_css_items }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-intro__copy {
      padding-top: {{ copy_padding_top_mobile }}px;
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__body {
    display: flex;
    flex-direction: column;
    align-items: {{ tra_css_items }};
    width: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__text-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    max-width: min(36rem, 100%);
  }
  #shopify-section-{{ id }} .ak-campaign-intro__titles {
    text-align: {{ tra_css_text }};
    width: max-content;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__divider-slot {
    display: flex;
    justify-content: {{ tra_css_justify }};
    width: 100%;
    margin: 1.25rem 0 0;
    flex-shrink: 0;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__divider {
    width: {{ divider_width }}px;
    height: {{ divider_height }}px;
    background-color: {{ divider_color }};
    border: none;
    padding: 0;
    margin: 0;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-intro__divider {
      width: {{ divider_width_mobile }}px;
      height: {{ divider_height_mobile }}px;
      background-color: {{ divider_color_mobile }};
    }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__eyebrow {
    font-family: {{ eyebrow_font_stack }};
    font-size: {{ eyebrow_size }}px;
    font-weight: {{ eyebrow_weight }};
    line-height: 1.2;
    margin: 0 0 0.35em;
    color: {{ text_color }};
    {% if section.settings.eyebrow_uppercase %}text-transform: uppercase; letter-spacing: 0.12em;{% endif %}
    {% if section.settings.eyebrow_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
  }
  #shopify-section-{{ id }} .ak-campaign-intro__heading {
    font-family: {{ heading_font_stack }};
    font-size: clamp(2.25rem, 8vw, {{ heading_size }}px);
    font-weight: {{ heading_weight }};
    line-height: 1.1;
    margin: 0;
    color: {{ text_color }};
    {% if section.settings.heading_underline %}text-decoration: underline; text-underline-offset: 0.15em;{% endif %}
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-campaign-intro__eyebrow {
      font-size: {{ eyebrow_size_mobile }}px;
    }
    #shopify-section-{{ id }} .ak-campaign-intro__heading {
      font-size: clamp(2.25rem, 8vw, {{ heading_size_mobile }}px);
    }
  }
  #shopify-section-{{ id }} .ak-campaign-intro__heading:focus-visible,
  #shopify-section-{{ id }} .ak-campaign-intro__eyebrow:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__link {
    text-decoration: none;
    color: inherit;
    display: block;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__link:hover .ak-campaign-intro__heading,
  #shopify-section-{{ id }} .ak-campaign-intro__link:hover .ak-campaign-intro__eyebrow {
    opacity: 0.88;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-campaign-intro__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__inner {
      flex-direction: row;
      align-items: stretch;
      min-height: min(88vh, 920px);
    }
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__media {
      flex: 0 0 {{ split_image_pct }}%;
      max-width: {{ split_image_pct }}%;
      position: relative;
      overflow: hidden;
      align-self: stretch;
    }
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__media img,
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__media .placeholder-svg {
      height: 100%;
      min-height: min(88vh, 920px);
      width: 100%;
      object-fit: {{ split_img_fit }};
      object-position: {{ split_img_pos }};
    }
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__copy {
      flex: 1 1 auto;
      min-width: 0;
      justify-content: center;
      padding: 2rem clamp(1.5rem, 4vw, 4rem);
    }
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__body {
      flex-direction: column;
      max-width: none;
      width: 100%;
    }
    #shopify-section-{{ id }} .ak-campaign-intro--split .ak-campaign-intro__text-stack {
      max-width: 100%;
    }
  }
{% endstyle %}

<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-campaign-intro-section ak-campaign-intro--{{ layout_desktop }} {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {{ section_aria }}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-campaign-intro columns one-whole">
      <div class="ak-campaign-intro__inner">
        <div class="ak-campaign-intro__media">
        {% if image != blank %}
          {% include 'image-element', image: image, alt: img_alt, stretch_width: true, additional_classes: 'is-hidden-mobile-only' %}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg is-hidden-mobile-only' }}
        {% endif %}
        {% if mobile_image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: mobile_image, alt: mobile_img_alt, stretch_width: true %}
          </div>
        {% elsif image != blank %}
          <div class="is-hidden-desktop-only">
            {% include 'image-element', image: image, alt: img_alt, stretch_width: true %}
          </div>
        {% else %}
          <div class="is-hidden-desktop-only">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
        </div>

        <div class="ak-campaign-intro__copy">
        {% if link_url != blank %}
          <a href="{{ link_url }}" class="ak-campaign-intro__link" aria-label="{{ heading | default: eyebrow | default: 'Campaign' | escape }}">
        {% endif %}
        <div class="ak-campaign-intro__body">
          <div class="ak-campaign-intro__text-stack">
            <div class="ak-campaign-intro__titles">
              {% if eyebrow != blank %}
                <p class="ak-campaign-intro__eyebrow">{{ eyebrow }}</p>
              {% endif %}
              {% if heading != blank %}
                {% if heading_level == 'h1' %}
                  <h1 class="ak-campaign-intro__heading" id="ak-campaign-intro-heading-{{ id }}">{{ heading }}</h1>
                {% elsif heading_level == 'h3' %}
                  <h3 class="ak-campaign-intro__heading" id="ak-campaign-intro-heading-{{ id }}">{{ heading }}</h3>
                {% else %}
                  <h2 class="ak-campaign-intro__heading" id="ak-campaign-intro-heading-{{ id }}">{{ heading }}</h2>
                {% endif %}
              {% endif %}
            </div>
            {% if show_divider %}
              <div class="ak-campaign-intro__divider-slot" aria-hidden="true">
                <hr class="ak-campaign-intro__divider" />
              </div>
            {% endif %}
          </div>
        </div>
        {% if link_url != blank %}
          </a>
        {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Campaign intro",
  "class": "ak-campaign-intro-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Campaign intro: image + text. Desktop can be split (side by side) or stacked; mobile is always stacked. Add Rich text or other sections below for page body (campaign template has no default Page section)."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Add alt text in the media library; heading or eyebrow is used as fallback."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Falls back to desktop image if blank."
    },
    {
      "type": "header",
      "content": "Desktop split — image crop"
    },
    {
      "type": "select",
      "id": "split_image_object_fit",
      "label": "Image fit",
      "default": "cover",
      "info": "Only when desktop layout is split. Stacked layout uses natural image height.",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "select",
      "id": "split_image_object_position",
      "label": "Image focal point",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link (optional)",
      "info": "If set, eyebrow + heading become one linked block. Leave blank for text only."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "INTRODUCING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Invisible Thread"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "info": "Use only one h1 per page. h2 is safe when the page title is already h1.",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "Background (below image)",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Vertical rule"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show vertical rule",
      "default": true,
      "info": "Below the eyebrow and heading. Position matches “Text & vertical rule alignment.”"
    },
    {
      "type": "paragraph",
      "content": "Desktop (799px and wider)"
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Rule height",
      "min": 80,
      "max": 400,
      "step": 10,
      "default": 250,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Rule width",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Rule color",
      "default": "#000000"
    },
    {
      "type": "paragraph",
      "content": "Mobile (798px and below)"
    },
    {
      "type": "range",
      "id": "divider_height_mobile",
      "label": "Rule height (mobile)",
      "min": 80,
      "max": 400,
      "step": 10,
      "default": 250,
      "unit": "px",
      "info": "Independent from desktop. Match Figma mobile frame."
    },
    {
      "type": "range",
      "id": "divider_width_mobile",
      "label": "Rule width (mobile)",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "divider_color_mobile",
      "label": "Rule color (mobile)",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "paragraph",
      "content": "Match Figma: sans eyebrow + Amiri heading (defaults below)."
    },
    {
      "type": "select",
      "id": "eyebrow_font_family",
      "label": "Eyebrow font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font",
      "default": "amiri",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Eyebrow font size (desktop)",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_mobile",
      "label": "Eyebrow font size (mobile)",
      "min": 0,
      "max": 36,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop. Applied at ≤798px."
    },
    {
      "type": "select",
      "id": "eyebrow_font_weight",
      "label": "Eyebrow font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "Eyebrow uppercase + letter-spacing",
      "default": true,
      "info": "Typical for small caps labels (e.g. INTRODUCING)."
    },
    {
      "type": "checkbox",
      "id": "eyebrow_underline",
      "label": "Eyebrow underline",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size (desktop max)",
      "min": 32,
      "max": 120,
      "step": 2,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile max)",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop max. Caps the clamp at ≤798px."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_rule_alignment",
      "label": "Text & vertical rule alignment",
      "default": "center",
      "info": "Aligns eyebrow, heading, and rule together in the text area (left, center, or right).",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "layout_desktop",
      "label": "Desktop layout",
      "default": "split",
      "info": "Split = image left, text right (Figma desktop). Stacked = image above text on all breakpoints.",
      "options": [
        { "value": "split", "label": "Split (image left, text right)" },
        { "value": "stacked", "label": "Stacked (image above text)" }
      ]
    },
    {
      "type": "range",
      "id": "split_image_width",
      "label": "Split layout: image column width",
      "min": 35,
      "max": 65,
      "step": 1,
      "default": 50,
      "unit": "%",
      "info": "Desktop only when Split is selected."
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": false
    },
    {
      "type": "range",
      "id": "copy_padding_top",
      "label": "Space above text (below image)",
      "min": 0,
