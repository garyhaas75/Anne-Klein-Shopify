<div class="row">
  {% for block in section.blocks %}
    {% case block.type %}
      
      {% when 'one-image' %}
        <div class="column column-full">
          {% if block.settings.link !=  blank %}<a href="{{ block.settings.link }}">{% endif %}
            {% include 'image-element', image: block.settings.image, alt: block.settings.image.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile, alt: block.settings.image_mobile.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link !=  blank %}</a>{% endif %}
        </div>
      
      {% when 'two-images' %}
        <div class="column column-half">
          {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{% endif %}
            {% include 'image-element', image: block.settings.image, alt: block.settings.image.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile, alt: block.settings.image_mobile.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link != blank %}</a>{% endif %}
        </div>
        <div class="column column-half">
          {% if block.settings.link_2 !=  blank %}<a href="{{ block.settings.link_2 }}">{% endif %}
            {% include 'image-element', image: block.settings.image_2, alt: block.settings.image_2.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile_2, alt: block.settings.image_mobile_2.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link_2 !=  blank %}</a>{% endif %}
        </div>

      {% when 'three-images' %}
        <div class="column column-half">
          {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{% endif %}
            {% include 'image-element', image: block.settings.image, alt: block.settings.image.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile, alt: block.settings.image_mobile.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link != blank %}</a>{% endif %}
        </div>
        <div class="column column-half">
          {% if block.settings.link_2 != blank %}<a href="{{ block.settings.link_2 }}">{% endif %}
            {% include 'image-element', image: block.settings.image_2, alt: block.settings.image_2.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile_2, alt: block.settings.image_mobile_2.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link_2 != blank %}</a>{% endif %}
        </div>
        <div class="column column-third">
          {% if block.settings.link_3 != blank %}<a href="{{ block.settings.link_3 }}">{% endif %}
            {% include 'image-element', image: block.settings.image_3, alt: block.settings.image_3.alt, stretch_width: true, additional_classes: 'desktop_only' %}
            {% include 'image-element', image: block.settings.image_mobile_3, alt: block.settings.image_mobile_3.alt, stretch_width: true, additional_classes: 'mobile_only' %}
          {% if block.settings.link_3 != blank %}</a>{% endif %}
        </div>
  
    {% endcase %}
  {% endfor %}
</div>

<style>
  .row {
    display: flex;
    flex-wrap: wrap;
  }
  .column.column-full {
    flex: 100%;
  }
  
  .column.column-half {
    flex: 50%;
  }

  .column.column-third {
    flex: 33.333%;
  }
  
  .column img {
    vertical-align: middle;
  }
  
</style>

