{% comment %}
  AK Homepage 2026 – Shop New Arrivals
  Heading + 4 category tiles (image, label, link)
  WCAG 2.2 AA: focus styles, conditional heading link (no #), section label. B2/B4: system font + schema size/spacing. C3: aspect-ratio fallback.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign heading_link = section.settings.heading_link %}
{% assign heading_color = section.settings.heading_color %}
{% assign heading_font_size = section.settings.heading_font_size | default: 18 %}
{% assign heading_font_weight = section.settings.heading_font_weight | default: '700' %}
{% assign heading_letter_spacing = section.settings.heading_letter_spacing | default: 2 %}
{% assign heading_underline = section.settings.heading_underline %}
{% assign heading_alignment = section.settings.heading_alignment | default: 'center' %}
{% assign bg_color = section.settings.background_color %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign padding_top_mobile = section.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = section.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign container_padding = section.settings.container_padding | default: 0 %}
{% assign grid_gap = section.settings.grid_gap | default: 24 %}
{% assign section_aria_label = section.settings.section_aria_label %}
{% assign label_font_weight = section.settings.label_font_weight | default: '700' %}
{% assign label_font_size = section.settings.label_font_size | default: 18 %}
{% assign label_icon_size = section.settings.label_icon_size | default: 0 %}
{% assign label_icon_size_mobile = section.settings.label_icon_size_mobile | default: 0 %}
{% if label_icon_size == 0 %}
  {% assign icon_size_px = label_font_size %}
{% else %}
  {% assign icon_size_px = label_icon_size %}
{% endif %}
{% if label_icon_size_mobile == 0 %}
  {% assign icon_size_mobile_px = icon_size_px %}
{% else %}
  {% assign icon_size_mobile_px = label_icon_size_mobile %}
{% endif %}
{% assign label_icon_style = section.settings.label_icon_style | default: 'arrow' %}
{% assign label_icon_svg = section.settings.label_icon_svg %}
{% assign label_icon_style_mobile = section.settings.label_icon_style_mobile | default: 'arrow' %}
{% assign label_icon_svg_mobile = section.settings.label_icon_svg_mobile %}
{% assign label_icon_image = section.settings.label_icon_image %}
{% assign label_icon_image_mobile = section.settings.label_icon_image_mobile %}
{% assign tile_aspect_ratio = section.settings.tile_aspect_ratio | default: '3_4' %}
{% assign section_max_width = section.settings.section_max_width | default: 1400 %}
{% case section.settings.font_family %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}

{% capture section_aria %}
  {% if heading != blank %}
    aria-labelledby="new-arrivals-heading-{{ id }}"
  {% elsif section_aria_label != blank %}
    aria-label="{{ section_aria_label | escape }}"
  {% else %}
    aria-label="Shop new arrivals"
  {% endif %}
{% endcapture %}

{% if heading_letter_spacing == 0 %}
  {% assign heading_ls_str = '0' %}
{% elsif heading_letter_spacing >= 10 %}
  {% assign heading_ls_str = heading_letter_spacing | append: '' | prepend: '0.' %}
{% else %}
  {% assign heading_ls_str = heading_letter_spacing | append: '' | prepend: '0.0' %}
{% endif %}

{% if tile_aspect_ratio == '1_1' %}
  {% assign tile_pb = '100%' %}
{% elsif tile_aspect_ratio == '4_5' %}
  {% assign tile_pb = '125%' %}
{% elsif tile_aspect_ratio == '2_3' %}
  {% assign tile_pb = '150%' %}
{% else %}
  {% assign tile_pb = '133.33%' %}
{% endif %}

{% style %}
  #shopify-section-{{ id }} .ak-new-arrivals {
    display: block;
    width: 100%;
    max-width: none;
    margin: 0 auto;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    background-color: {{ bg_color }};
    box-sizing: border-box;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-new-arrivals {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  #shopify-section-{{ id }} .ak-new-arrivals__inner {
    display: block;
    max-width: {{ section_max_width }}px;
    width: 100%;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__title {
    display: block;
    width: 100%;
    box-sizing: border-box;
    font-family: {{ font_stack }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    text-align: {{ heading_alignment }};
    margin: 0 0 1.5rem;
    color: {{ heading_color }};
    letter-spacing: {% if heading_letter_spacing == 0 %}0{% else %}{{ heading_ls_str }}em{% endif %};
    {% if heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
  }
  #shopify-section-{{ id }} .ak-new-arrivals__title-link { color: inherit; text-decoration: {% if heading_underline %}underline{% else %}none{% endif %}; }
  #shopify-section-{{ id }} .ak-new-arrivals__title-link:hover,
  #shopify-section-{{ id }} .ak-new-arrivals__title-link:focus-visible { opacity: 0.8; }
  #shopify-section-{{ id }} .ak-new-arrivals__title-link {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__title-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ grid_gap }}px;
    padding: {{ container_padding }}px;
    width: 100%;
    box-sizing: border-box;
    list-style: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-link:hover .ak-new-arrivals__tile-label,
  #shopify-section-{{ id }} .ak-new-arrivals__tile-link:focus-visible .ak-new-arrivals__tile-label { text-decoration: underline; }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-media {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ tile_pb }};
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-media .image-element__wrap {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    max-height: none !important;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-media img,
  #shopify-section-{{ id }} .ak-new-arrivals__tile-media .placeholder-svg {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    max-height: none !important;
    object-fit: cover !important;
    display: block !important;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-label-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-label {
    font-family: {{ font_stack }};
    font-size: {{ label_font_size }}px;
    font-weight: {{ label_font_weight }};
    color: #000;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-icon svg {
    width: {{ icon_size_px }}px !important;
    height: {{ icon_size_px }}px !important;
    min-width: {{ icon_size_px }}px !important;
    min-height: {{ icon_size_px }}px !important;
    max-width: {{ icon_size_px }}px !important;
    max-height: {{ icon_size_px }}px !important;
    flex-shrink: 0;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-icon img {
    height: {{ icon_size_px }}px !important;
    width: auto !important;
    object-fit: contain !important;
    position: static !important;
    display: block;
  }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-icon--mobile { display: none; }
  #shopify-section-{{ id }} .ak-new-arrivals__tile-icon--desktop { display: inline-flex; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-new-arrivals__tile-icon--desktop { display: none; }
    #shopify-section-{{ id }} .ak-new-arrivals__tile-icon--mobile { display: inline-flex; }
    #shopify-section-{{ id }} .ak-new-arrivals__tile-icon svg {
      width: {{ icon_size_mobile_px }}px !important;
      height: {{ icon_size_mobile_px }}px !important;
      min-width: {{ icon_size_mobile_px }}px !important;
      min-height: {{ icon_size_mobile_px }}px !important;
      max-width: {{ icon_size_mobile_px }}px !important;
      max-height: {{ icon_size_mobile_px }}px !important;
    }
    #shopify-section-{{ id }} .ak-new-arrivals__tile-icon img {
      height: {{ icon_size_mobile_px }}px !important;
    }
    #shopify-section-{{ id }} .ak-new-arrivals__grid { grid-template-columns: repeat(2, 1fr); gap: {{ grid_gap | times: 0.75 | round }}px; padding: {{ container_padding | times: 0.75 | round }}px; }
  }
{% endstyle %}

<section class="ak-new-arrivals" {{ section_aria }}>
  <div class="ak-new-arrivals__inner">
    {% if heading != blank %}
      <h2 class="ak-new-arrivals__title" id="new-arrivals-heading-{{ id }}">
        {% if heading_link != blank %}
          <a href="{{ heading_link }}" class="ak-new-arrivals__title-link">{{ heading }}</a>
        {% else %}
          {{ heading }}
        {% endif %}
      </h2>
    {% endif %}
    <ul class="ak-new-arrivals__grid" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'tile' and block.settings.label != blank %}
          {% assign tile_alt = block.settings.image_alt %}
          {% if tile_alt == blank and block.settings.image != blank and block.settings.image.alt != blank %}
            {% assign tile_alt = block.settings.image.alt %}
          {% endif %}
          {% if tile_alt == blank %}
            {% assign tile_alt = '' %}
          {% endif %}
          <li class="ak-new-arrivals__tile" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="ak-new-arrivals__tile-link">
                <div class="ak-new-arrivals__tile-media">
                  {% if block.settings.image != blank %}
                    {% include 'image-element', image: block.settings.image, alt: tile_alt, stretch_width: true %}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                <span class="ak-new-arrivals__tile-label-wrap">
                  {% if label_icon_image != blank or label_icon_svg != blank or label_icon_style == 'arrow' %}
                    <span class="ak-new-arrivals__tile-icon ak-new-arrivals__tile-icon--desktop" aria-hidden="true">{% if label_icon_image != blank %}<img src="{{ label_icon_image | image_url: width: 64 }}" alt="" width="16" height="16" loading="lazy">{% elsif label_icon_svg != blank %}{{ label_icon_svg }}{% else %}<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>{% endif %}</span>
                  {% endif %}
                  {% if label_icon_image_mobile != blank or label_icon_svg_mobile != blank or label_icon_style_mobile == 'arrow' %}
                    <span class="ak-new-arrivals__tile-icon ak-new-arrivals__tile-icon--mobile" aria-hidden="true">{% if label_icon_image_mobile != blank %}<img src="{{ label_icon_image_mobile | image_url: width: 64 }}" alt="" width="16" height="16" loading="lazy">{% elsif label_icon_svg_mobile != blank %}{{ label_icon_svg_mobile }}{% else %}<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>{% endif %}</span>
                  {% endif %}
                  <span class="ak-new-arrivals__tile-label">{{ block.settings.label }}</span>
                </span>
              </a>
            {% else %}
              <div class="ak-new-arrivals__tile-link">
                <div class="ak-new-arrivals__tile-media">
                  {% if block.settings.image != blank %}
                    {% include 'image-element', image: block.settings.image, alt: tile_alt, stretch_width: true %}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                <span class="ak-new-arrivals__tile-label-wrap">
                  {% if label_icon_image != blank or label_icon_svg != blank or label_icon_style == 'arrow' %}
                    <span class="ak-new-arrivals__tile-icon ak-new-arrivals__tile-icon--desktop" aria-hidden="true">{% if label_icon_image != blank %}<img src="{{ label_icon_image | image_url: width: 64 }}" alt="" width="16" height="16" loading="lazy">{% elsif label_icon_svg != blank %}{{ label_icon_svg }}{% else %}<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>{% endif %}</span>
                  {% endif %}
                  {% if label_icon_image_mobile != blank or label_icon_svg_mobile != blank or label_icon_style_mobile == 'arrow' %}
                    <span class="ak-new-arrivals__tile-icon ak-new-arrivals__tile-icon--mobile" aria-hidden="true">{% if label_icon_image_mobile != blank %}<img src="{{ label_icon_image_mobile | image_url: width: 64 }}" alt="" width="16" height="16" loading="lazy">{% elsif label_icon_svg_mobile != blank %}{{ label_icon_svg_mobile }}{% else %}<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>{% endif %}</span>
                  {% endif %}
                  <span class="ak-new-arrivals__tile-label">{{ block.settings.label }}</span>
                </span>
              </div>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "AK Shop New Arrivals",
  "class": "ak-shop-new-arrivals-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP NEW ARRIVALS"
    },
    {
      "type": "url",
      "id": "heading_link",
      "label": "Heading link",
      "info": "Optional. If set, the heading becomes a link. Leave blank to show heading as text only."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Default font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Heading font size",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "label": "Heading letter spacing",
      "default": 2,
      "info": "0–10, as % of em (2 ≈ 0.02em)."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Tile label"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Label font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Label font weight",
      "default": "700",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "header",
      "content": "Label icon (before each label)"
    },
    {
      "type": "range",
      "id": "label_icon_size",
      "label": "Icon size (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 0,
      "info": "0 = same as label font size. Use to shorten or enlarge the arrow."
    },
    {
      "type": "range",
      "id": "label_icon_size_mobile",
      "label": "Icon size mobile (px)",
      "min": 0,
      "max": 28,
      "step": 2,
      "default": 14,
      "info": "0 = same as desktop. Set smaller (e.g. 12–14) to shorten arrows on mobile."
    },
    {
      "type": "image_picker",
      "id": "label_icon_image",
      "label": "Icon image (desktop)",
      "info": "Upload an SVG or image (e.g. arrow). Shown before each label. If set, overrides preset arrow."
    },
    {
      "type": "image_picker",
      "id": "label_icon_image_mobile",
      "label": "Icon image (mobile)",
      "info": "Optional. If blank, uses desktop icon or preset arrow."
    },
    {
      "type": "select",
      "id": "label_icon_style",
      "label": "Fallback icon (desktop)",
      "default": "arrow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow", "label": "Arrow right" }
      ],
      "info": "Used when no icon image is set."
    },
    {
      "type": "textarea",
      "id": "label_icon_svg",
      "label": "Or custom SVG code (desktop)",
      "info": "Alternative to image: paste SVG code. Used when no icon image is set."
    },
    {
      "type": "select",
      "id": "label_icon_style_mobile",
      "label": "Fallback icon (mobile)",
      "default": "arrow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "arrow", "label": "Arrow right" }
      ]
    },
    {
      "type": "textarea",
      "id": "label_icon_svg_mobile",
      "label": "Or custom SVG code (mobile)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "min": 800,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Section max width",
      "default": 1400,
      "info": "Maximum width of the tile grid container. Increase to make the section wider and tiles larger."
    },
    {
      "type": "select",
      "id": "tile_aspect_ratio",
      "label": "Tile image shape",
      "default": "3_4",
      "options": [
        { "value": "1_1", "label": "Square (1:1)" },
        { "value": "4_5", "label": "Portrait (4:5)" },
        { "value": "3_4", "label": "Portrait tall (3:4) — default" },
        { "value": "2_3", "label": "Portrait taller (2:3)" }
      ],
      "info": "Aspect ratio of tile images. Images always fill the container and scale with tile width. Increase Section max width above to make tiles larger."
    },
    {
      "type": "range",
      "id": "container_padding",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Padding around tile grid",
      "default": 0,
      "info": "Space between the section container and the tile grid."
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap between tiles",
      "default": 24
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (for screen readers)",
      "info": "Optional. Used when heading is blank. Leave blank for default."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
