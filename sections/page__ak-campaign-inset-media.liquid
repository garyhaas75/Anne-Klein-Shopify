{% comment %}
  AK Campaign — narrow centered media (e.g. 9:16-style inset). Image optional; shows placeholder until set.
  WCAG 2.2 AA: region, alt text, optional link focus-visible, min touch target on links.
{% endcomment %}

{% assign id = section.id %}
{% assign img = section.settings.image %}
{% assign mimg = section.settings.mobile_image | default: img %}
{% assign max_w = section.settings.media_max_width | default: 420 %}
{% assign ar = section.settings.aspect_ratio | default: '9 / 16' %}
{% assign fit = section.settings.image_object_fit | default: 'cover' %}
{% assign pos = section.settings.image_object_position | default: 'center' %}
{% assign letterbox = section.settings.letterbox_color | default: '#1a1a1a' %}
{% assign cap = section.settings.caption %}
{% assign heading = section.settings.heading %}
{% assign hl = section.settings.heading_level | default: 'h2' %}
{% assign lnk = section.settings.link_url %}
{% assign img_alt = section.settings.image_alt | default: img.alt | default: heading | default: 'Campaign photograph' %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom | default: 0 }}px;
    }
  }
  #shopify-section-{{ id }} .ak-inset__grid {
    width: 100%;
    flex: 1 1 100%;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-inset__inner {
    max-width: {{ max_w }}px;
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ id }} .ak-inset__heading {
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    margin: 0 0 1rem;
    font-size: clamp(1.25rem, 3vw, {{ section.settings.heading_font_size | default: 28 }}px);
    font-weight: {{ section.settings.heading_font_weight | default: '400' }};
    color: {{ section.settings.heading_color | default: '#000000' }};
  }
  #shopify-section-{{ id }} .ak-inset__frame {
    position: relative;
    width: 100%;
    background-color: {{ letterbox }};
    overflow: hidden;
  }
  {% if ar != blank and ar != 'none' %}
  #shopify-section-{{ id }} .ak-inset__frame {
    aspect-ratio: {{ ar }};
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-inset__frame .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-inset__frame .is-hidden-desktop-only {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-inset__frame .is-hidden-desktop-only .image-element__wrap {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-inset__frame img,
  #shopify-section-{{ id }} .ak-inset__frame .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: {{ fit }};
    object-position: {{ pos }};
    display: block;
  }
  {% if ar == blank or ar == 'none' %}
  #shopify-section-{{ id }} .ak-inset__frame--natural .image-element__wrap {
    position: relative;
    inset: auto;
    width: 100%;
    height: auto;
  }
  #shopify-section-{{ id }} .ak-inset__frame--natural img,
  #shopify-section-{{ id }} .ak-inset__frame--natural .placeholder-svg {
    width: 100%;
    height: auto;
    object-fit: {{ fit }};
    object-position: {{ pos }};
  }
  {% endif %}
  #shopify-section-{{ id }} .ak-inset__frame .is-hidden-desktop-only { display: none; }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-inset__frame .is-hidden-mobile-only { display: none !important; }
    #shopify-section-{{ id }} .ak-inset__frame .is-hidden-desktop-only { display: block !important; }
  }
  #shopify-section-{{ id }} .ak-inset__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ id }} .ak-inset__link:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-inset__caption {
    margin-top: 1rem;
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    font-size: {{ section.settings.caption_font_size | default: 15 }}px;
    line-height: 1.5;
    color: {{ section.settings.caption_color | default: '#333333' }};
  }
  #shopify-section-{{ id }} .ak-inset__caption a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
{% endstyle %}

<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-campaign-inset-section {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {% if section.settings.section_aria_label != blank %}
    aria-label="{{ section.settings.section_aria_label | escape }}"
  {% elsif heading != blank %}
    aria-labelledby="ak-inset-heading-{{ id }}"
  {% else %}
    aria-label="Campaign image"
  {% endif %}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-inset__grid columns one-whole">
      <div class="ak-inset__inner">
        {% if heading != blank %}
          {% if hl == 'h1' %}
            <h1 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h1>
          {% elsif hl == 'h3' %}
            <h3 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h3>
          {% else %}
            <h2 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h2>
          {% endif %}
        {% endif %}

        {% capture inset_media %}
          <div class="ak-inset__frame {% if ar == blank or ar == 'none' %}ak-inset__frame--natural{% endif %}">
            {% if img != blank %}
              {% include 'image-element', image: img, alt: img_alt, stretch_width: true, additional_classes: 'is-hidden-mobile-only' %}
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg is-hidden-mobile-only' }}
            {% endif %}
            {% if mimg != blank %}
              <div class="is-hidden-desktop-only">
                {% include 'image-element', image: mimg, alt: img_alt, stretch_width: true %}
              </div>
            {% elsif img != blank %}
              <div class="is-hidden-desktop-only">
                {% include 'image-element', image: img, alt: img_alt, stretch_width: true %}
              </div>
            {% else %}
              <div class="is-hidden-desktop-only">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
          </div>
        {% endcapture %}

        {% if lnk != blank %}
          <a
            href="{{ lnk }}"
            class="ak-inset__link"
            {% if section.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            aria-label="{{ img_alt | escape }}"
          >
            {{ inset_media }}
          </a>
        {% else %}
          {{ inset_media }}
        {% endif %}

        {% if cap != blank %}
          <div class="ak-inset__caption rte">{{ cap }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Campaign inset media",
  "class": "ak-campaign-inset-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Centered column image; default aspect 9:16. For video use AK Video."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Image (mobile)",
      "info": "Optional. Falls back to desktop image."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Describe the photo for screen readers. Media library alt is used if blank."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Image link (optional)"
    },
    {
      "type": "checkbox",
      "id": "link_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "media_max_width",
      "label": "Max width (inset column)",
      "min": 240,
      "max": 900,
      "step": 10,
      "default": 420,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "default": "9 / 16",
      "info": "Locks frame height from width. None = image natural height (still capped by max width).",
      "options": [
        { "value": "9 / 16", "label": "9:16 (tall)" },
        { "value": "4 / 5", "label": "4:5" },
        { "value": "3 / 4", "label": "3:4" },
        { "value": "2 / 3", "label": "2:3" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "none", "label": "None (natural height)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_fit",
      "label": "Image fit",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_position",
      "label": "Focal point",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "color",
      "id": "letterbox_color",
      "label": "Letterbox / placeholder background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size (max)",
      "min": 16,
      "max": 48,
      "step": 1,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ]
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (screen readers)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Padding bottom"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Padding top (mobile)"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "Padding bottom (mobile)"
    }
  ],
  "presets": [
    {
      "name": "AK Campaign inset media",
      "category": "Custom"
    }
  ]
}
{% endschema %}
