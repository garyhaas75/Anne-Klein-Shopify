{% comment %}
  AK Campaign — tall inset column (Figma-driven).
  Figma file: agnYrbiuU2Ory43nJYA4Nk | Mobile frame: 35:616 (AK_Campaign Landing Page 2026_Mobile)
  Primary ref for this band: 189:47 "AK_SS26_4_9x16_NO LOGO 1" — 666×1020px, x=66 on 798px artboard (centered inset).
  Desktop frame: 102:586 — same asset may appear in a wider composition; match width/aspect per layer if different.
  WCAG 2.2 AA: region, alt text, optional link focus-visible, min touch target on links.
{% endcomment %}

{% assign id = section.id %}
{% assign img = section.settings.image %}
{% assign mimg = section.settings.mobile_image | default: img %}
{% assign max_w = section.settings.media_max_width | default: 660 %}
{% assign max_w_m = section.settings.media_max_width_mobile | default: 660 %}
{% assign ar = section.settings.aspect_ratio | default: '111 / 170' %}
{% if ar != blank and ar != 'none' %}
  {% assign inset_ratio_locked = true %}
{% else %}
  {% assign inset_ratio_locked = false %}
{% endif %}
{% assign ar_m_raw = section.settings.aspect_ratio_mobile | default: 'inherit' %}
{% if ar_m_raw == 'inherit' or ar_m_raw == blank %}
  {% assign ar_m = ar %}
{% else %}
  {% assign ar_m = ar_m_raw %}
{% endif %}
{% if ar_m != blank and ar_m != 'none' %}
  {% assign inset_ratio_locked_mobile = true %}
{% else %}
  {% assign inset_ratio_locked_mobile = false %}
{% endif %}
{% assign fit = section.settings.image_object_fit | default: 'cover' %}
{% assign fit_m_raw = section.settings.image_object_fit_mobile | default: 'inherit' %}
{% if fit_m_raw == 'inherit' or fit_m_raw == blank %}
  {% assign fit_m = fit %}
{% else %}
  {% assign fit_m = fit_m_raw %}
{% endif %}
{% assign pos = section.settings.image_object_position | default: 'center' %}
{% assign pos_m_raw = section.settings.image_object_position_mobile | default: 'inherit' %}
{% if pos_m_raw == 'inherit' or pos_m_raw == blank %}
  {% assign pos_m = pos %}
{% else %}
  {% assign pos_m = pos_m_raw %}
{% endif %}
{% assign letterbox = section.settings.letterbox_color | default: '#1a1a1a' %}
{% assign cap = section.settings.caption %}
{% assign heading = section.settings.heading %}
{% assign hl = section.settings.heading_level | default: 'h2' %}
{% assign lnk = section.settings.link_url %}
{% assign img_alt = section.settings.image_alt | default: img.alt | default: heading | default: 'Campaign photograph' %}

{% assign inset_h_sz = section.settings.heading_font_size | default: 28 %}
{% assign inset_h_sz_m = section.settings.heading_font_size_mobile | default: 0 | plus: 0 %}
{% if inset_h_sz_m < 1 %}
  {% assign inset_h_sz_m = inset_h_sz %}
{% endif %}
{% assign inset_cap_sz = section.settings.caption_font_size | default: 15 %}
{% assign inset_cap_sz_m = section.settings.caption_font_size_mobile | default: 0 | plus: 0 %}
{% if inset_cap_sz_m < 1 %}
  {% assign inset_cap_sz_m = inset_cap_sz %}
{% endif %}
{% assign inset_cap_mt = section.settings.caption_margin_top | default: 16 %}
{% assign inset_cap_mt_m = section.settings.caption_margin_top_mobile | default: 0 | plus: 0 %}
{% if inset_cap_mt_m < 1 %}
  {% assign inset_cap_mt_m = inset_cap_mt %}
{% endif %}
{% capture inset_heading_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.heading_font_family %}{% endcapture %}
{% assign inset_heading_font_stack = inset_heading_font_stack | strip %}
{% capture inset_caption_font_stack %}{% render 'ak-campaign-font-stack', font_key: section.settings.caption_font_family %}{% endcapture %}
{% assign inset_caption_font_stack = inset_caption_font_stack | strip %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom | default: 0 }}px;
    }
  }
  #shopify-section-{{ id }} .ak-inset__grid {
    width: 100%;
    flex: 1 1 100%;
    max-width: 100%;
  }
  #shopify-section-{{ id }} .ak-inset__inner {
    max-width: {{ max_w }}px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-inset__inner {
      max-width: {{ max_w_m }}px;
    }
  }
  #shopify-section-{{ id }} .ak-inset__heading {
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    margin: 0 0 1rem;
    font-family: {{ inset_heading_font_stack }};
    font-size: clamp(1.25rem, 3vw, {{ inset_h_sz }}px);
    font-weight: {{ section.settings.heading_font_weight | default: '400' }};
    color: {{ section.settings.heading_color | default: '#000000' }};
  }
  /* Ratio frames: separate desktop vs mobile so aspect + fit can differ */
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-mobile-only,
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-desktop-only {
    position: relative;
    width: 100%;
    background-color: {{ letterbox }};
    overflow: hidden;
  }
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-mobile-only {
    aspect-ratio: {{ ar }};
  }
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-desktop-only {
    aspect-ratio: {{ ar_m }};
  }
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-mobile-only .image-element__wrap,
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-desktop-only .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-mobile-only img,
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-mobile-only .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: {{ fit }};
    object-position: {{ pos }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-desktop-only img,
  #shopify-section-{{ id }} .ak-inset__frame--ratio.is-hidden-desktop-only .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: {{ fit_m }};
    object-position: {{ pos_m }};
    display: block;
  }
  /* Natural: full column width; separate frames for mobile vs desktop focal point */
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-mobile-only,
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-desktop-only {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    overflow: visible;
  }
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-mobile-only .image-element__wrap,
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-desktop-only .image-element__wrap {
    position: static !important;
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    margin-left: auto;
    margin-right: auto;
  }
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-mobile-only img,
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-mobile-only .placeholder-svg {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    object-fit: unset;
    object-position: {{ pos }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-desktop-only img,
  #shopify-section-{{ id }} .ak-inset__frame--natural.is-hidden-desktop-only .placeholder-svg {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    object-fit: unset;
    object-position: {{ pos_m }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-inset__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ id }} .ak-inset__link:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 4px;
  }
  #shopify-section-{{ id }} .ak-inset__caption {
    margin-top: {{ inset_cap_mt }}px;
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    font-family: {{ inset_caption_font_stack }};
    font-size: {{ inset_cap_sz }}px;
    line-height: 1.5;
    color: {{ section.settings.caption_color | default: '#333333' }};
  }
  #shopify-section-{{ id }} .ak-inset__caption a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
{% endstyle %}

<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-campaign-inset-section {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {% if section.settings.section_aria_label != blank %}
    aria-label="{{ section.settings.section_aria_label | escape }}"
  {% elsif heading != blank %}
    aria-labelledby="ak-inset-heading-{{ id }}"
  {% else %}
    aria-label="Campaign image"
  {% endif %}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-inset__grid columns one-whole">
      <div class="ak-inset__inner">
        {% if heading != blank %}
          {% if hl == 'h1' %}
            <h1 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h1>
          {% elsif hl == 'h3' %}
            <h3 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h3>
          {% else %}
            <h2 class="ak-inset__heading" id="ak-inset-heading-{{ id }}">{{ heading }}</h2>
          {% endif %}
        {% endif %}

        {% capture inset_media %}
          <div class="ak-inset__frame {% if inset_ratio_locked %}ak-inset__frame--ratio{% else %}ak-inset__frame--natural{% endif %} is-hidden-mobile-only">
            {% if img != blank %}
              {% if inset_ratio_locked %}
                {% include 'image-element', image: img, alt: img_alt, stretch_width: true %}
              {% else %}
                {% include 'image-element', image: img, alt: img_alt, stretch_width: false %}
              {% endif %}
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="ak-inset__frame {% if inset_ratio_locked_mobile %}ak-inset__frame--ratio{% else %}ak-inset__frame--natural{% endif %} is-hidden-desktop-only">
            {% if mimg != blank %}
              {% if inset_ratio_locked_mobile %}
                {% include 'image-element', image: mimg, alt: img_alt, stretch_width: true %}
              {% else %}
                {% include 'image-element', image: mimg, alt: img_alt, stretch_width: false %}
              {% endif %}
            {% elsif img != blank %}
              {% if inset_ratio_locked_mobile %}
                {% include 'image-element', image: img, alt: img_alt, stretch_width: true %}
              {% else %}
                {% include 'image-element', image: img, alt: img_alt, stretch_width: false %}
              {% endif %}
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        {% endcapture %}

        {% if lnk != blank %}
          <a
            href="{{ lnk }}"
            class="ak-inset__link"
            {% if section.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            aria-label="{{ img_alt | escape }}"
          >
            {{ inset_media }}
          </a>
        {% else %}
          {{ inset_media }}
        {% endif %}

        {% if cap != blank %}
          <div class="ak-inset__caption rte">{{ cap }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AK Campaign inset media",
  "class": "ak-campaign-inset-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Matches Figma mobile inset 189:47 (666px max width, 111:170). For motion use AK Video."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Image (mobile)",
      "info": "Optional. Falls back to desktop image."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Describe the photo for screen readers. Media library alt is used if blank."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Image link (optional)"
    },
    {
      "type": "checkbox",
      "id": "link_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "media_max_width",
      "label": "Max width (inset column, desktop)",
      "min": 240,
      "max": 2240,
      "step": 20,
      "default": 660,
      "unit": "px",
      "info": "Up to ~full viewport width at max. Shopify allows at most 101 slider steps; step is 20px. Default 660 is nearest grid value to Figma 666px."
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio (desktop)",
      "default": "111 / 170",
      "info": "111:170 = fixed crop box. None = image scales to full inset column width; height follows the file (no side gutters inside the frame).",
      "options": [
        { "value": "111 / 170", "label": "Figma inset (666×1020)" },
        { "value": "9 / 16", "label": "9:16" },
        { "value": "4 / 5", "label": "4:5" },
        { "value": "3 / 4", "label": "3:4" },
        { "value": "2 / 3", "label": "2:3" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "none", "label": "None (natural height)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_fit",
      "label": "Image fit (desktop, ratio mode)",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_position",
      "label": "Focal point (desktop)",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "header",
      "content": "Layout (mobile)"
    },
    {
      "type": "range",
      "id": "media_max_width_mobile",
      "label": "Max width (inset column, mobile)",
      "min": 240,
      "max": 2240,
      "step": 20,
      "default": 660,
      "unit": "px",
      "info": "Applies below the theme mobile breakpoint. Independent from desktop max width."
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect ratio (mobile)",
      "default": "inherit",
      "info": "Use “Same as desktop” to match the desktop setting. Choose None for full-width natural height on small screens.",
      "options": [
        { "value": "inherit", "label": "Same as desktop" },
        { "value": "111 / 170", "label": "Figma inset (666×1020)" },
        { "value": "9 / 16", "label": "9:16" },
        { "value": "4 / 5", "label": "4:5" },
        { "value": "3 / 4", "label": "3:4" },
        { "value": "2 / 3", "label": "2:3" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "none", "label": "None (natural height)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_fit_mobile",
      "label": "Image fit (mobile, ratio mode)",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Same as desktop" },
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "select",
      "id": "image_object_position_mobile",
      "label": "Focal point (mobile)",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Same as desktop" },
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "center top", "label": "Center top" },
        { "value": "center bottom", "label": "Center bottom" }
      ]
    },
    {
      "type": "color",
      "id": "letterbox_color",
      "label": "Letterbox / placeholder background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
