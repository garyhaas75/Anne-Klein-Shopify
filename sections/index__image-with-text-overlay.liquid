{% comment %}
** Image with text overlay - dynamic **
- Draggable section
{% endcomment %}

{% assign extra_link_desc = section.settings.title %}

{% include 'include-image-with-text-overlay' %}

{% schema %}
{
  "name": "Image with text overlay",
  "class": "image-with-text-overlay overlaid-header-option",
  "settings": [
    {
      "type": "url",
      "id": "link",
      "label": "Link (entire container)",
      "info": "Makes the whole section clickable (image + text). When no buttons are set, the entire overlay is linked. When buttons are set, they use their own links."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Link title",
      "info": "If the slide does not have live text, please add a descriptive link title."
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": true
    },    
    {
      "type": "checkbox",
      "id": "enable_shop_similar",
      "label": "Enable Shop Similar",
      "default": false
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "1800 x 900px recommended"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "900 x 1800px recommended"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Required for ADA (WCAG). Describe the image for screen readers. If blank, the image’s media alt or the heading is used."
    },
    {
      "type": "range",
      "id": "max_height_desktop",
      "min": 0,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Max height (desktop)",
      "default": 0,
      "info": "0 = no limit. Caps the banner height on desktop."
    },
    {
      "type": "range",
      "id": "max_height_mobile",
      "min": 0,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Max height (mobile)",
      "default": 0,
      "info": "0 = no limit. Caps the banner height on mobile (viewport 798px and below)."
    },
    {
      "type": "header",
      "content": "Text overlay container"
    },
    {
      "type": "range",
      "id": "overlay_container_padding_top",
      "label": "Overlay padding top (desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "overlay_container_padding_bottom",
      "label": "Overlay padding bottom (desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "overlay_container_padding_top_mobile",
      "label": "Overlay padding top (mobile)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "overlay_container_padding_bottom_mobile",
      "label": "Overlay padding bottom (mobile)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Fonts"
    },
    {
      "type": "richtext",
      "id": "pretext",
      "label": "Preheading",
      "default": "<p>Preheading</p>"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Image with Text Overlay"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subheading",
      "default": "<p>Additional info in the subheading</p>"
    },
    {
      "type": "color",
      "id": "pretext_color",
      "label": "Preheading",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "pretext_underline",
      "label": "Preheading underline",
      "default": false
    },
    {
      "type": "select",
      "id": "preheading_font_family",
      "label": "Preheading font family",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "helvetica", "label": "Helvetica Neue" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Heading font family",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "helvetica", "label": "Helvetica Neue" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 72,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 0,
      "max": 56,
      "step": 2,
      "default": 0,
      "unit": "px",
      "info": "0 = auto-scale from desktop (~70%)."
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading font size",
      "min": 12,
      "max": 48,
      "step": 2,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size_mobile",
      "label": "Subheading font size (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px",
      "info": "0 = auto-scale from desktop (~70%)."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Heading underline",
      "default": false
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "subheading_font_family",
      "label": "Subheading font family",
      "default": "system",
      "options": [
        { "value": "system", "label": "System (default)" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "helvetica", "label": "Helvetica Neue" }
      ],
      "info": "Safe fonts that work without loading a font package."
    },
    {
      "type": "select",
      "id": "preheading_font_weight",
      "label": "Preheading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "select",
      "id": "subheading_font_weight",
      "label": "Subheading font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "subheading_underline",
      "label": "Subheading underline",
      "default": false
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "", "label": "Same as desktop" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "text_horizontal_position",
      "label": "Horizontal position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_horizontal_position_mobile",
      "label": "Horizontal position (mobile)",
      "options": [
        { "value": "", "label": "Same as desktop" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "text_vertical_position",
      "label": "Vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "text_vertical_position_mobile",
      "label": "Vertical position (mobile)",
      "options": [
        { "value": "", "label": "Same as desktop" },
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "Accessibility (contrast)"
    },
    {
      "type": "checkbox",
      "id": "text_shadow_contrast",
      "label": "Add text shadow for readability",
      "default": true,
      "info": "Recommended for text over image. Helps meet WCAG 1.4.3 (ADA). Works best with light-colored text."
    },
    {
      "type": "select",
      "id": "scrim_overlay",
      "label": "Scrim overlay",
      "default": "dark",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "dark", "label": "Dark gradient behind text" }
      ],
      "info": "Dark gradient behind the text area improves contrast when the image is busy or background opacity is low."
    },
    {
      "type": "header",
      "content": "Text background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF",
      "info": "Use higher opacity below, or enable text shadow and scrim above, to meet ADA contrast (4.5:1 for normal text)."
    },
    {
      "type": "range",
      "id": "background_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "default": 77,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 20,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Text width",
      "min": 40,
      "max": 100,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "text_width_mobile",
      "label": "Text width (mobile)",
      "min": 0,
      "max": 100,
      "default": 0,
      "unit": "%",
      "info": "0 = same as desktop. On small screens, consider 80-100%."
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1",
      "label": "Button 1 label",
      "default": "Button 1"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "label": "Button 1 style",
      "options": [
        {
          "value": "button--primary",
          "label": "Primary"
        },
        {
          "value": "button--secondary",
          "label": "Secondary"
        },
        {
          "value": "button--link-style",
          "label": "Link style"
        },
		{
          "value": "button--white",
          "label": "White Background"
        },
        {
          "value": "button--white-border",
          "label": "White Border"
        }
      ],
      "default": "button--secondary"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2",
      "label": "Button 2 label",
      "default": "Button 2"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "label": "Button 2 style",
      "options": [
        {
          "value": "button--primary",
          "label": "Primary"
        },
        {
          "value": "button--secondary",
          "label": "Secondary"
        },
        {
          "value": "button--link-style",
          "label": "Link style"
        },
		{
          "value": "button--white",
          "label": "White Background"
        },
		{
          "value": "button--white-border",
          "label": "White Border"
        }
      ],
      "default": "button--secondary"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "mobile_image_crop",
      "label": "Image cropping",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "mobile_text_below_image",
      "label": "Show text below image",
      "default": true
    },
    {
      "type": "color",
      "id": "pretext_color_mobile",
      "label": "Preheading",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "heading_color_mobile",
      "label": "Heading",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "subheading_color_mobile",
      "label": "Subheading",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wide",
      "options": [
        {
          "value": "half",
          "label": "Half"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing (desktop)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing (desktop)",
      "default": 0,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top spacing (mobile)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom spacing (mobile)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 0,
      "unit": "px",
      "info": "Keep at 0 to avoid a light bar below the image on mobile (section background showing)."
    },
    {
      "type": "header",
      "content": "Padding below each line (overlay text)"
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Spacing between text (px)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 12,
      "unit": "px",
      "info": "Default gap when per-line padding below is 0."
    },
    {
      "type": "range",
      "id": "padding_below_preheading",
      "label": "Padding below preheading (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_below_heading",
      "label": "Padding below heading (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_below_subheading",
      "label": "Padding below subheading (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Left spacing",
      "min": 0,
      "max": 80,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Right spacing",
      "default": 0,
      "min": 0,
      "max": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "label": "Left spacing (mobile)",
      "min": 0,
      "max": 40,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop."
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "label": "Right spacing (mobile)",
      "min": 0,
      "max": 40,
      "default": 0,
