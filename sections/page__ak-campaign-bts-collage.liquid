{% comment %}
  AK Campaign — "Behind the Scenes" editorial collage (center copy + absolutely positioned tiles).
  Figma file: agnYrbiuU2Ory43nJYA4Nk | Mobile frame: 35:616
  Backdrop plate: 191:89 (798×1545). Tiles approx from nodes 191:97,191:96,191:90,191:91,191:92,191:98,191:94,191:95,191:93.
  Headline 196:120, subcopy 196:119 — centered over stage.
  WCAG 2.2 AA: region, image alts, heading order, visible link focus, reduced-motion friendly layout stack on small screens.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign hl = section.settings.heading_level | default: 'h2' %}
{% assign sub = section.settings.subtext %}
{% assign backdrop = section.settings.backdrop_image %}
{% assign bg = section.settings.background_color | default: '#ffffff' %}
{% assign stage_ar_raw = section.settings.stage_aspect_ratio | strip %}
{% assign stage_ar_lc = stage_ar_raw | downcase %}
{% if stage_ar_raw == blank or stage_ar_lc == 'none' or stage_ar_lc == 'off' %}
  {% assign stage_use_aspect = false %}
{% else %}
  {% assign stage_use_aspect = true %}
{% endif %}

{% assign hf = section.settings.heading_font_family | default: 'amiri' %}
{% case hf %}
  {% when 'amiri' %}{% assign hstack = 'Amiri, Georgia, serif' %}
  {% when 'georgia' %}{% assign hstack = 'Georgia, serif' %}
  {% else %}{% assign hstack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif' %}
{% endcase %}
{% assign sf = section.settings.subtext_font_family | default: 'system' %}
{% case sf %}
  {% when 'amiri' %}{% assign sstack = 'Amiri, Georgia, serif' %}
  {% when 'georgia' %}{% assign sstack = 'Georgia, serif' %}
  {% else %}{% assign sstack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif' %}
{% endcase %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ section.settings.padding_top | default: 48 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
    background-color: {{ bg }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top | default: 40 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom | default: 40 }}px;
    }
  }
  #shopify-section-{{ id }} .ak-bts-collage__stage {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.stage_max_width | default: 100 }}%;
    margin-left: auto;
    margin-right: auto;
    background-color: {{ section.settings.stage_background_color | default: '#ffffff' }};
    overflow: hidden;
  }
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-bts-collage__stage {
      {% if stage_use_aspect %}
        aspect-ratio: {{ stage_ar_raw }};
      {% endif %}
      {% assign _mh = section.settings.stage_min_height_desktop | default: 0 | plus: 0 %}
      {% if _mh > 0 %}
        min-height: {{ _mh }}px;
      {% endif %}
      {% assign _mxh = section.settings.stage_max_height_desktop | default: 0 | plus: 0 %}
      {% if _mxh > 0 %}
        max-height: {{ _mxh }}px;
      {% endif %}
    }
  }
  #shopify-section-{{ id }} .ak-bts-collage__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-bts-collage__backdrop .image-element__wrap,
  #shopify-section-{{ id }} .ak-bts-collage__backdrop img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.backdrop_object_fit | default: 'cover' }};
    object-position: {{ section.settings.backdrop_object_position | default: 'center' }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-bts-collage__backdrop .image-element__wrap {
    position: absolute;
    inset: 0;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__text {
    position: absolute;
    left: 50%;
    top: {{ section.settings.text_vertical_position | default: 52 }}%;
    transform: translate(-50%, -50%);
    z-index: 20;
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    max-width: min(92%, {{ section.settings.text_max_width | default: 36 }}rem);
    width: 100%;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-bts-collage__text a {
    pointer-events: auto;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  #shopify-section-{{ id }} .ak-bts-collage__text a:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-bts-collage__heading {
    margin: 0 0 0.5rem;
    font-family: {{ hstack }};
    font-size: clamp(1.5rem, 4vw, {{ section.settings.heading_font_size | default: 40 }}px);
    font-weight: {{ section.settings.heading_font_weight | default: '400' }};
    line-height: 1.15;
    color: {{ section.settings.heading_color | default: '#000000' }};
  }
  #shopify-section-{{ id }} .ak-bts-collage__sub {
    margin: 0;
    font-family: {{ sstack }};
    font-size: {{ section.settings.subtext_font_size | default: 17 }}px;
    font-weight: {{ section.settings.subtext_font_weight | default: '400' }};
    line-height: 1.45;
    color: {{ section.settings.subtext_color | default: '#333333' }};
  }
  #shopify-section-{{ id }} .ak-bts-collage__sub p {
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile {
    position: absolute;
    z-index: 2;
    overflow: hidden;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner img,
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.tile_object_fit | default: 'cover' }};
    object-position: {{ section.settings.tile_object_position | default: 'center' }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-link:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 2px;
  }
  {% comment %} Preset slot % + z-index (sync base_* in snippets/ak-bts-collage-tile.liquid). p4 rear; p5–p9 over p4. {% endcomment %}
  #shopify-section-{{ id }} .ak-bts-collage__tile--p1 { left: 0%; top: 0%; width: 14.85%; height: 10.35%; z-index: 16; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p2 { left: 0%; top: 37.9%; width: 15.66%; height: 11.35%; z-index: 11; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p3 { left: 9.35%; top: 4.85%; width: 35.25%; height: 25.35%; z-index: 8; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p4 { left: 61.5%; top: 0%; width: 35.25%; height: 25.15%; z-index: 9; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p5 { left: 46.2%; top: 18.2%; width: 36.8%; height: 26.8%; z-index: 15; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p6 { left: 66.5%; top: 55.9%; width: 15.65%; height: 11.45%; z-index: 13; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p7 { left: 23.5%; top: 57.0%; width: 37.2%; height: 26.8%; z-index: 17; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p8 { left: 71.35%; top: 79.65%; width: 28.65%; height: 19.15%; z-index: 18; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p9 { left: 0%; top: 77.85%; width: 28.35%; height: 22.35%; z-index: 14; }

  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-bts-collage__stage {
      aspect-ratio: unset;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: {{ section.settings.mobile_stack_gap | default: 16 }}px;
      overflow: visible;
    }
    #shopify-section-{{ id }} .ak-bts-collage__backdrop {
      position: relative;
      inset: auto;
      order: 0;
      aspect-ratio: {{ section.settings.mobile_backdrop_aspect | default: '3 / 4' }};
      max-height: 70vh;
    }
    #shopify-section-{{ id }} .ak-bts-collage__text {
      position: relative;
      left: auto;
      top: auto;
      transform: none;
      order: 1;
      max-width: 100%;
      pointer-events: auto;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
    #shopify-section-{{ id }} .ak-bts-collage__tiles {
      order: 2;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: {{ section.settings.mobile_tile_gap | default: 8 }}px;
    }
    #shopify-section-{{ id }} .ak-bts-collage__tile {
      position: relative !important;
      left: auto !important;
      top: auto !important;
      width: 100% !important;
      height: auto !important;
      transform: none !important;
      aspect-ratio: {{ section.settings.mobile_tile_aspect | default: '3 / 4' }};
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-bts-collage__tile-link:focus-visible {
      transition: none;
    }
  }
{% endstyle %}


<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-bts-collage-section {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {% if heading != blank %}
    aria-labelledby="ak-bts-collage-h-{{ id }}"
  {% elsif section.settings.section_aria_label != blank %}
    aria-label="{{ section.settings.section_aria_label | escape }}"
  {% else %}
    aria-label="Behind the scenes"
  {% endif %}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-bts-collage__stage">
      {% if backdrop != blank %}
        <div class="ak-bts-collage__backdrop" aria-hidden="true">
          {% render 'image-element', image: backdrop, alt: '', stretch_width: true %}
        </div>
      {% endif %}

      {% if heading != blank or sub != blank %}
        <div class="ak-bts-collage__text">
          {% if heading != blank %}
            {% if hl == 'h1' %}
              <h1 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h1>
            {% elsif hl == 'h3' %}
              <h3 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h3>
            {% else %}
              <h2 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h2>
            {% endif %}
          {% endif %}
          {% if sub != blank %}
            <div class="ak-bts-collage__sub rte">{{ sub }}</div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ak-bts-collage__tiles">
        {% comment %}
          Shopify orders section.blocks to match the theme editor / JSON block_order.
          Do not re-walk block_order with id matching — mismatched ids can ignore reorder.
        {% endcomment %}
        {% assign collage_slot = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'collage_tile' %}
            {% assign collage_slot = collage_slot | plus: 1 %}
            {% render 'ak-bts-collage-tile', block: block, slot_index: collage_slot %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "AK Campaign BTS collage",
  "class": "ak-bts-collage-section",
  "tag": "section",
  "max_blocks": 18,
  "settings": [
    {
      "type": "paragraph",
      "content": "Desktop: the 1st Collage tile uses slot 1 (small top-left), 2nd → slot 2, etc. Drag blocks to swap images. Pick Slot 1–9 to pin an image. Use Nudge / Scale, optional % sliders + the checkbox on each tile. Mobile: backdrop, text, then a 2-column grid (nudge/scale skipped there)."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Behind the Scenes"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1 (one per page)" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Follow our journey on Instagram <a href=\"https://www.instagram.com/annekleinofficial/\" target=\"_blank\" rel=\"noopener noreferrer\">@AnneKleinOfficial</a></p>"
    },
    {
      "type": "header",
      "content": "Backdrop (optional)"
    },
    {
      "type": "image_picker",
      "id": "backdrop_image",
      "label": "Backdrop image",
      "info": "Decorative plate behind collage; hidden from assistive tech. Omit for flat background only."
    },
    {
      "type": "select",
      "id": "backdrop_object_fit",
      "label": "Backdrop fit",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill" }
      ]
    },
    {
      "type": "select",
      "id": "backdrop_object_position",
      "label": "Backdrop focal point",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Stage (desktop)"
    },
    {
      "type": "text",
      "id": "stage_aspect_ratio",
      "label": "Stage aspect ratio (optional)",
      "default": "none",
      "info": "Leave as none to size the desktop stage with Min / Max height only (recommended). Enter width / height (e.g. 798 / 1545) only if you want a fixed canvas ratio — that can fight with Max height. Not each tile’s ratio."
    },
    {
      "type": "range",
      "id": "stage_max_width",
      "label": "Stage max width",
      "min": 50,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%",
      "info": "Caps how wide the collage stage is within the section (not a minimum). Lower values narrow the frame."
    },
    {
      "type": "range",
      "id": "stage_min_height_desktop",
      "label": "Min height (desktop)",
      "min": 0,
      "max": 2400,
      "step": 24,
      "default": 912,
      "unit": "px",
      "info": "Floor for stage height when aspect ratio is none (tiles are positioned in %, so the stage needs height). Lower if you use a fixed aspect ratio instead. Must align with 24px steps (Shopify schema: default and JSON values must be min + n×step)."
    },
    {
      "type": "range",
      "id": "stage_max_height_desktop",
      "label": "Max height (desktop)",
      "min": 0,
      "max": 2400,
      "step": 24,
      "default": 0,
      "unit": "px",
      "info": "0 = no cap. Use with Min height (and aspect ratio none) to cap how tall the collage gets. May clip bottom tiles if the cap is low."
    },
    {
      "type": "color",
      "id": "stage_background_color",
      "label": "Stage background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Center text position"
    },
    {
      "type": "range",
      "id": "text_vertical_position",
      "label": "Text vertical position",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 52,
      "unit": "%",
      "info": "Distance from top of stage (desktop)."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Text max width",
      "min": 16,
      "max": 48,
      "step": 1,
      "default": 36,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Heading typography"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font",
      "default": "amiri",
      "options": [
        { "value": "amiri", "label": "Amiri" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "system", "label": "System" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size (max)",
      "min": 24,
      "max": 72,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Subtext typography"
    },
    {
      "type": "select",
      "id": "subtext_font_family",
      "label": "Subtext font",
      "default": "system",
      "options": [
        { "value": "amiri", "label": "Amiri" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "system", "label": "System" }
      ]
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "subtext_font_weight",
      "label": "Subtext weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ]
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Tiles (desktop)"
    },
    {
      "type": "paragraph",
      "content": "Each tile is a fixed % rectangle on the stage. Cover fills the box and crops the image (original photo shape is not fully visible). Contain keeps the whole image inside the box (may show letterboxing). Use Tile focal point with Cover to choose which part stays visible."
    },
    {
