{% comment %}
  AK Campaign — "Behind the Scenes" editorial collage (center copy + absolutely positioned tiles).
  Figma file: agnYrbiuU2Ory43nJYA4Nk
  Desktop frame: 102:586 | Stage (backdrop): 102:717 (1920×2507)
  Desktop tiles: 102:725(p1) 102:724(p2) 102:718(p3) 102:719(p4) 102:720(p5) 102:726(p6) 102:722(p7) 102:723(p8) 102:721(p9)
  Mobile frame: 35:616 | Mobile stage: 191:89 (798×1545)
  Mobile tiles: 191:97(p1) 191:96(p2) 191:90(p3) 191:91(p4) 191:92(p5) 191:98(p6) 191:94(p7) 191:95(p8) 191:93(p9)
  Headline 196:120 / 102:728, subcopy 196:119 / 102:727 — centered over stage.
  WCAG 2.2 AA: region, image alts, heading order, visible link focus, reduced-motion friendly layout stack on small screens.
{% endcomment %}

{% assign id = section.id %}
{% assign heading = section.settings.heading %}
{% assign hl = section.settings.heading_level | default: 'h2' %}
{% assign sub = section.settings.subtext %}
{% assign bg = section.settings.background_color | default: '#ffffff' %}
{% assign stage_ar_raw = section.settings.stage_aspect_ratio | strip %}
{% assign stage_ar_lc = stage_ar_raw | downcase %}
{% if stage_ar_raw == blank or stage_ar_lc == 'none' or stage_ar_lc == 'off' %}
  {% assign stage_use_aspect = false %}
{% else %}
  {% assign stage_use_aspect = true %}
{% endif %}

{% capture hstack %}{% render 'ak-campaign-font-stack', font_key: section.settings.heading_font_family %}{% endcapture %}
{% assign hstack = hstack | strip %}
{% capture sstack %}{% render 'ak-campaign-font-stack', font_key: section.settings.subtext_font_family %}{% endcapture %}
{% assign sstack = sstack | strip %}

{% assign tv_d = section.settings.text_vertical_position | default: 52 %}
{% if section.settings.text_vertical_position_match_desktop == false %}
  {% assign tv_m = section.settings.text_vertical_position_mobile | default: 52 | plus: 0 %}
{% else %}
  {% assign tv_m = tv_d %}
{% endif %}
{% assign tmw_d = section.settings.text_max_width | default: 36 %}
{% assign tmw_m = section.settings.text_max_width_mobile | default: 0 | plus: 0 %}
{% if tmw_m < 1 %}
  {% assign tmw_m = tmw_d %}
{% endif %}
{% assign heading_fs = section.settings.heading_font_size | default: 40 %}
{% assign heading_fs_m = section.settings.heading_font_size_mobile | default: 0 | plus: 0 %}
{% if heading_fs_m < 1 %}
  {% assign heading_fs_m = heading_fs %}
{% endif %}
{% assign sub_fs = section.settings.subtext_font_size | default: 17 %}
{% assign sub_fs_m = section.settings.subtext_font_size_mobile | default: 0 | plus: 0 %}
{% if sub_fs_m < 1 %}
  {% assign sub_fs_m = sub_fs %}
{% endif %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ section.settings.padding_top | default: 48 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
    background-color: {{ bg }};
  }
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: section.settings.padding_top | default: 40 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom | default: 40 }}px;
    }
  }
  #shopify-section-{{ id }} .ak-bts-collage__stage {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.stage_max_width | default: 100 }}%;
    margin-left: auto;
    margin-right: auto;
    background-color: {{ section.settings.stage_background_color | default: '#ffffff' }};
    overflow: hidden;
  }
  @media only screen and (min-width: 799px) {
    #shopify-section-{{ id }} .ak-bts-collage__stage {
      height: auto;
      {% if stage_use_aspect %}
        aspect-ratio: {{ stage_ar_raw }};
      {% endif %}
      {% assign _mh = section.settings.stage_min_height_desktop | default: 600 | plus: 0 %}
      {% if _mh < 600 %}
        {% assign _mh = 600 %}
      {% endif %}
      {% if _mh > 0 %}
        min-height: {{ _mh }}px;
      {% endif %}
      {% assign _mxh = section.settings.stage_max_height_desktop | default: 0 | plus: 0 %}
      {% if _mxh > 0 %}
        max-height: {{ _mxh }}px;
      {% endif %}
    }
  }
  #shopify-section-{{ id }} .ak-bts-collage__text {
    position: absolute;
    left: 50%;
    top: {{ tv_d }}%;
    transform: translate(-50%, -50%);
    z-index: 20;
    text-align: {{ section.settings.text_alignment | default: 'center' }};
    max-width: min(92%, {{ tmw_d }}rem);
    width: 100%;
    pointer-events: none;
  }
  #shopify-section-{{ id }} .ak-bts-collage__text a {
    pointer-events: auto;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  #shopify-section-{{ id }} .ak-bts-collage__text a:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 3px;
  }
  #shopify-section-{{ id }} .ak-bts-collage__heading {
    margin: 0 0 0.5rem;
    font-family: {{ hstack }};
    font-size: clamp(1.5rem, 4vw, {{ heading_fs }}px);
    font-weight: {{ section.settings.heading_font_weight | default: '400' }};
    line-height: 1.15;
    color: {{ section.settings.heading_color | default: '#000000' }};
  }
  #shopify-section-{{ id }} .ak-bts-collage__sub {
    margin: 0;
    font-family: {{ sstack }};
    font-size: {{ sub_fs }}px;
    font-weight: {{ section.settings.subtext_font_weight | default: '400' }};
    line-height: 1.45;
    color: {{ section.settings.subtext_color | default: '#333333' }};
  }
  #shopify-section-{{ id }} .ak-bts-collage__sub p {
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile {
    position: absolute;
    z-index: 2;
    overflow: hidden;
    box-sizing: border-box;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner .image-element__wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner img,
  #shopify-section-{{ id }} .ak-bts-collage__tile-inner .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.tile_object_fit | default: 'cover' }};
    object-position: {{ section.settings.tile_object_position | default: 'center' }};
    display: block;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ id }} .ak-bts-collage__tile-link:focus-visible {
    outline: 3px solid {{ section.settings.heading_color | default: '#000000' }};
    outline-offset: 2px;
  }
  {% comment %} Desktop slot % from Figma desktop frame 102:586, stage 102:717 (1920×2507). Sync base_* in snippets/ak-bts-collage-tile.liquid. {% endcomment %}
  #shopify-section-{{ id }} .ak-bts-collage__tile--p1 { left: 0%; top: 0%; width: 12.03%; height: 12.32%; z-index: 16; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p2 { left: 21.72%; top: 52.33%; width: 12.01%; height: 12.88%; z-index: 11; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p3 { left: 8.28%; top: 6.18%; width: 26.82%; height: 28.76%; z-index: 8; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p4 { left: 73.18%; top: 0%; width: 26.82%; height: 28.76%; z-index: 9; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p5 { left: 51.88%; top: 15.44%; width: 26.82%; height: 28.76%; z-index: 15; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p6 { left: 74.64%; top: 47.55%; width: 11.98%; height: 12.88%; z-index: 13; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p7 { left: 30.83%; top: 61.57%; width: 26.82%; height: 28.76%; z-index: 17; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p8 { left: 78.70%; top: 72.92%; width: 21.25%; height: 21.70%; z-index: 18; }
  #shopify-section-{{ id }} .ak-bts-collage__tile--p9 { left: 4.01%; top: 74.83%; width: 21.46%; height: 25.17%; z-index: 14; }

  {% comment %} Mobile: same collage layout, positions from Figma mobile frame 35:616, stage 191:89 (798×1545). {% endcomment %}
  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} .ak-bts-collage__stage {
      aspect-ratio: 798 / 1545;
      min-height: 0;
      max-height: none;
    }
    #shopify-section-{{ id }} .ak-bts-collage__text {
      top: {{ tv_m }}%;
      max-width: min(92%, {{ tmw_m }}rem);
    }
    #shopify-section-{{ id }} .ak-bts-collage__heading {
      font-size: clamp(1.25rem, 5.5vw, {{ heading_fs_m }}px);
    }
    #shopify-section-{{ id }} .ak-bts-collage__sub {
      font-size: {{ sub_fs_m }}px;
    }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p1 { left: 0%; top: 0%; width: 15.66%; height: 10.74%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p2 { left: 0%; top: 38.45%; width: 15.66%; height: 11.26%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p3 { left: 10.78%; top: 5.44%; width: 34.82%; height: 25.18%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p4 { left: 65.16%; top: 0%; width: 34.84%; height: 25.11%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p5 { left: 52.63%; top: 22.52%; width: 34.71%; height: 25.11%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p6 { left: 67.29%; top: 58.90%; width: 15.54%; height: 11.26%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p7 { left: 23.93%; top: 63.88%; width: 34.96%; height: 25.24%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p8 { left: 72.56%; top: 81.10%; width: 27.44%; height: 18.90%; }
    #shopify-section-{{ id }} .ak-bts-collage__tile--p9 { left: 0%; top: 78.12%; width: 27.82%; height: 21.88%; }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ id }} .ak-bts-collage__tile-link:focus-visible {
      transition: none;
    }
  }
{% endstyle %}


<section
  class="section is-width-{{ section.settings.width | default: 'wide' }} ak-bts-collage-section {% if section.settings.show_gutter == false %}has-no-side-gutter has-background{% else %}has-gutter-enabled{% endif %}"
  id="shopify-section-{{ id }}"
  role="region"
  {% if heading != blank %}
    aria-labelledby="ak-bts-collage-h-{{ id }}"
  {% elsif section.settings.section_aria_label != blank %}
    aria-label="{{ section.settings.section_aria_label | escape }}"
  {% else %}
    aria-label="Behind the scenes"
  {% endif %}
>
  <div class="container equal-columns--outside-trim">
    <div class="ak-bts-collage__stage">
      {% if heading != blank or sub != blank %}
        <div class="ak-bts-collage__text">
          {% if heading != blank %}
            {% if hl == 'h1' %}
              <h1 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h1>
            {% elsif hl == 'h3' %}
              <h3 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h3>
            {% else %}
              <h2 class="ak-bts-collage__heading" id="ak-bts-collage-h-{{ id }}">{{ heading }}</h2>
            {% endif %}
          {% endif %}
          {% if sub != blank %}
            <div class="ak-bts-collage__sub rte">{{ sub }}</div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ak-bts-collage__tiles">
        {% comment %}
          Shopify orders section.blocks to match the theme editor / JSON block_order.
          Do not re-walk block_order with id matching — mismatched ids can ignore reorder.
        {% endcomment %}
        {% assign collage_slot = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'collage_tile' %}
            {% assign collage_slot = collage_slot | plus: 1 %}
            {% render 'ak-bts-collage-tile', block: block, slot_index: collage_slot %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "AK Campaign BTS collage",
  "class": "ak-bts-collage-section",
  "tag": "section",
  "max_blocks": 18,
  "settings": [
    {
      "type": "paragraph",
      "content": "Desktop: the 1st Collage tile uses slot 1 (small top-left), 2nd → slot 2, etc. Drag blocks to swap images. Pick Slot 1–9 to pin an image. Use Nudge / Scale, optional % sliders + the checkbox on each tile. Mobile: text, then a 2-column grid (nudge/scale skipped there)."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Behind the Scenes"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1 (one per page)" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Follow our journey on Instagram <a href=\"https://www.instagram.com/annekleinofficial/\" target=\"_blank\" rel=\"noopener noreferrer\">@AnneKleinOfficial</a></p>"
    },
    {
      "type": "header",
      "content": "Stage (desktop)"
    },
    {
      "type": "text",
      "id": "stage_aspect_ratio",
      "label": "Stage aspect ratio (optional)",
      "default": "none",
      "info": "Leave as none to size the desktop stage with Min / Max height only (recommended). Enter width / height (e.g. 798 / 1545) only if you want a fixed canvas ratio — that can fight with Max height. Not each tile’s ratio."
    },
    {
      "type": "range",
      "id": "stage_max_width",
      "label": "Stage max width",
      "min": 50,
      "max": 100,
      "step": 1,
      "default": 100,
      "unit": "%",
      "info": "Caps how wide the collage stage is within the section (not a minimum). Lower values narrow the frame."
    },
    {
      "type": "range",
      "id": "stage_min_height_desktop",
      "label": "Min height (desktop)",
      "min": 600,
      "max": 3000,
      "step": 30,
      "default": 600,
      "unit": "px",
      "info": "Lowest selectable floor is 600px. When aspect ratio is none, this sets stage height (tiles use % of the stage). With a fixed aspect ratio, this is a floor. Keep Min ≤ Max when both are set. 30px steps (values must be min + n×step)."
    },
    {
      "type": "range",
      "id": "stage_max_height_desktop",
      "label": "Max height (desktop)",
      "min": 0,
      "max": 3000,
      "step": 30,
      "default": 0,
      "unit": "px",
      "info": "0 = no cap. Ceilings height when aspect ratio or layout would exceed this (does not make the stage taller). If Min is higher than Max, CSS treats the cap as at least Min. Tile images use Tile image fit: Cover crops; Contain keeps the full photo aspect visible (may letterbox)."
    },
    {
      "type": "color",
      "id": "stage_background_color",
      "label": "Stage background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Center text position"
    },
    {
      "type": "range",
      "id": "text_vertical_position",
      "label": "Text vertical position (desktop)",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 52,
      "unit": "%",
      "info": "Distance from top of stage (≥799px)."
    },
    {
      "type": "checkbox",
      "id": "text_vertical_position_match_desktop",
      "label": "Use same vertical position on mobile as desktop",
      "default": true
    },
    {
      "type": "range",
      "id": "text_vertical_position_mobile",
      "label": "Text vertical position (mobile)",
      "min": 0,
      "max": 95,
      "step": 1,
      "default": 52,
      "unit": "%",
      "info": "Only used when “Use same vertical position on mobile as desktop” is off. 0% = top of stage. Applied at ≤798px."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Text max width (desktop)",
      "min": 16,
      "max": 48,
      "step": 1,
      "default": 36,
      "unit": "rem"
    },
    {
      "type": "range",
      "id": "text_max_width_mobile",
      "label": "Text max width (mobile)",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 0,
      "unit": "rem",
      "info": "0 = same as desktop."
    },
    {
      "type": "header",
      "content": "Heading typography"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading font",
      "default": "amiri",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size (max, desktop)",
      "min": 24,
      "max": 72,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading size (max, mobile)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop. Caps clamp at ≤798px."
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Subtext typography"
    },
    {
      "type": "select",
      "id": "subtext_font_family",
      "label": "Subtext font",
      "default": "system",
      "options": [
        { "value": "system", "label": "System sans" },
        { "value": "amiri", "label": "Amiri" },
        { "value": "arial", "label": "Arial" },
        { "value": "georgia", "label": "Georgia" },
        { "value": "times", "label": "Times New Roman" },
        { "value": "verdana", "label": "Verdana" },
        { "value": "trebuchet", "label": "Trebuchet MS" }
      ]
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "label": "Subtext size (desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 17,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subtext_font_size_mobile",
      "label": "Subtext size (mobile)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = same as desktop."
    },
    {
      "type": "select",
      "id": "subtext_font_weight",
      "label": "Subtext weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ]
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Tiles (desktop)"
    },
    {
      "type": "paragraph",
      "content": "Each tile is a fixed % rectangle on the stage. Cover fills the box and crops the image (original photo shape is not fully visible). Contain keeps the whole image inside the box (may show letterboxing). Use Tile focal point with Cover to choose which part stays visible."
    },
    {
      "type": "select",
      "id": "tile_object_fit",
      "label": "Tile image fit",
      "default": "cover",
      "info": "Cover = fill slot, crop edges. Contain = full image visible, preserve aspect ratio within slot.",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ]
    },
    {
      "type": "select",
      "id": "tile_object_position",
      "label": "Tile focal point",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Section width",
      "default": "wide",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_gutter",
      "label": "Show gutter",
      "default": false
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section label (screen readers)",
      "info": "Used when heading is empty."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
