              "title1": "Outfit Inspiration",
              "text1": "<p>From morning to night - Anne Klein pieces are perfect for any occasion</p>",
              "button_label1": "Watch video",
              "iframe_video1": "https://vimeo.com/483646338",
              "image2": "shopify://shop_images/whd.jpg",
              "title2": "Women Who Do",
              "text2": "<p>Conversations with Reem Acra, Sasha Bikoff and many more inspiring women</p>",
              "button_label2": "Watch video",
              "iframe_video2": "https://vimeo.com/471149947",
