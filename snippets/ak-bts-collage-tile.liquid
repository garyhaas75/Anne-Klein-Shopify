{% comment %}
  slot_index = 1-based order among collage tiles (for "Follow block order" mode).
  custom = manual %; auto = map order to p1..p9; manual_box = % box override, keep slot z-index.
  Slot % below must stay in sync with sections/page__ak-campaign-bts-collage.liquid
{% endcomment %}
{% assign img = block.settings.image %}
{% if block.settings.image_alt != blank %}
  {% assign alt = block.settings.image_alt %}
{% elsif img != blank and img.alt != blank %}
  {% assign alt = img.alt %}
{% else %}
  {% assign alt = 'Behind the scenes photograph' %}
{% endif %}
{% assign raw_placement = block.settings.placement | default: 'auto' | strip %}
{% if raw_placement == blank %}
  {% assign raw_placement = 'auto' %}
{% endif %}
{% assign use_custom_tile = false %}
{% assign manual_box = block.settings.manual_box %}
{% assign tz = block.settings.tile_z_index | default: 0 | plus: 0 %}
{% if raw_placement == 'custom' %}
  {% assign use_custom_tile = true %}
  {% assign l = block.settings.custom_left | default: 0 | plus: 0 %}
  {% assign t = block.settings.custom_top | default: 0 | plus: 0 %}
  {% assign w = block.settings.custom_width | default: 25 | plus: 0 %}
  {% assign h = block.settings.custom_height | default: 25 | plus: 0 %}
  {% if tz < 1 %}
    {% assign tz = 2 %}
  {% endif %}
{% elsif raw_placement == 'auto' %}
  {% assign slot_n = slot_index %}
  {% if slot_n > 9 %}
    {% assign slot_n = 9 %}
  {% endif %}
  {% assign pl = 'p' | append: slot_n %}
{% else %}
  {% assign pl = raw_placement %}
{% endif %}

{% assign nx = block.settings.tile_nudge_x | default: 0 | plus: 0 %}
{% assign ny = block.settings.tile_nudge_y | default: 0 | plus: 0 %}
{% assign sc_pct = block.settings.tile_scale_pct | default: 100 | plus: 0 %}
{% if sc_pct < 1 %}
  {% assign sc_pct = 100 %}
{% endif %}
{% assign sc_f = sc_pct | times: 0.01 %}

{% assign base_l = 0 %}
{% assign base_t = 0 %}
{% assign base_w = 0 %}
{% assign base_h = 0 %}
{% if use_custom_tile == false %}
  {% case pl %}
    {% when 'p1' %}
      {% assign base_l = 0 %}{% assign base_t = 0 %}{% assign base_w = 12.03 %}{% assign base_h = 12.32 %}
    {% when 'p2' %}
      {% assign base_l = 21.72 %}{% assign base_t = 52.33 %}{% assign base_w = 12.01 %}{% assign base_h = 12.88 %}
    {% when 'p3' %}
      {% assign base_l = 8.28 %}{% assign base_t = 6.18 %}{% assign base_w = 26.82 %}{% assign base_h = 28.76 %}
    {% when 'p4' %}
      {% assign base_l = 73.18 %}{% assign base_t = 0 %}{% assign base_w = 26.82 %}{% assign base_h = 28.76 %}
    {% when 'p5' %}
      {% assign base_l = 51.88 %}{% assign base_t = 15.44 %}{% assign base_w = 26.82 %}{% assign base_h = 28.76 %}
    {% when 'p6' %}
      {% assign base_l = 74.64 %}{% assign base_t = 47.55 %}{% assign base_w = 11.98 %}{% assign base_h = 12.88 %}
    {% when 'p7' %}
      {% assign base_l = 30.83 %}{% assign base_t = 61.57 %}{% assign base_w = 26.82 %}{% assign base_h = 28.76 %}
    {% when 'p8' %}
      {% assign base_l = 78.70 %}{% assign base_t = 72.92 %}{% assign base_w = 21.25 %}{% assign base_h = 21.70 %}
    {% when 'p9' %}
      {% assign base_l = 4.01 %}{% assign base_t = 74.83 %}{% assign base_w = 21.46 %}{% assign base_h = 25.17 %}
  {% endcase %}
{% endif %}
{% assign manual_active = false %}
{% if manual_box and use_custom_tile == false %}
  {% assign l = block.settings.custom_left | default: 0 | plus: 0 %}
  {% assign t = block.settings.custom_top | default: 0 | plus: 0 %}
  {% assign w = block.settings.custom_width | default: 25 | plus: 0 %}
  {% assign h = block.settings.custom_height | default: 25 | plus: 0 %}
  {% unless l == 0 and t == 0 and w == 25 and h == 25 %}
    {% assign manual_active = true %}
  {% endunless %}
{% endif %}

{% assign has_tune = false %}
{% if nx != 0 or ny != 0 or sc_pct != 100 %}
  {% assign has_tune = true %}
{% endif %}

{% assign eff_l = base_l %}
{% assign eff_t = base_t %}
{% assign eff_w = base_w %}
{% assign eff_h = base_h %}
{% if use_custom_tile or manual_active %}
  {% assign eff_l = l %}
  {% assign eff_t = t %}
  {% assign eff_w = w %}
  {% assign eff_h = h %}
{% endif %}
{% if sc_pct != 100 %}
  {% assign eff_w = eff_w | times: sc_f %}
  {% assign eff_h = eff_h | times: sc_f %}
  {% if use_custom_tile or manual_active %}
    {% assign eff_l = w | minus: eff_w | times: 0.5 | plus: l %}
    {% assign eff_t = h | minus: eff_h | times: 0.5 | plus: t %}
  {% else %}
    {% assign eff_l = base_w | minus: eff_w | times: 0.5 | plus: base_l %}
    {% assign eff_t = base_h | minus: eff_h | times: 0.5 | plus: base_t %}
  {% endif %}
{% endif %}

{% assign tile_outer_style = '' %}
{% if use_custom_tile %}
  {% assign tile_outer_style = 'left: ' | append: eff_l | append: '%; top: ' | append: eff_t | append: '%; width: ' | append: eff_w | append: '%; height: ' | append: eff_h | append: '%; z-index: ' | append: tz | append: ';' %}
  {% if nx != 0 or ny != 0 %}
    {% assign tile_outer_style = tile_outer_style | append: ' transform: translate3d(' | append: nx | append: 'px, ' | append: ny | append: 'px, 0);' %}
  {% endif %}
{% elsif manual_active %}
  {% assign tile_outer_style = 'left: ' | append: eff_l | append: '%; top: ' | append: eff_t | append: '%; width: ' | append: eff_w | append: '%; height: ' | append: eff_h | append: '%;' %}
  {% if nx != 0 or ny != 0 %}
    {% assign tile_outer_style = tile_outer_style | append: ' transform: translate3d(' | append: nx | append: 'px, ' | append: ny | append: 'px, 0);' %}
  {% endif %}
  {% if tz > 0 %}
    {% assign tile_outer_style = tile_outer_style | append: ' z-index: ' | append: tz | append: ';' %}
  {% endif %}
{% elsif has_tune %}
  {% if sc_pct != 100 %}
    {% assign tile_outer_style = 'left: ' | append: eff_l | append: '%; top: ' | append: eff_t | append: '%; width: ' | append: eff_w | append: '%; height: ' | append: eff_h | append: '%;' %}
  {% endif %}
  {% if nx != 0 or ny != 0 %}
    {% assign tile_outer_style = tile_outer_style | append: ' transform: translate3d(' | append: nx | append: 'px, ' | append: ny | append: 'px, 0);' %}
  {% endif %}
  {% if tz > 0 %}
    {% assign tile_outer_style = tile_outer_style | append: ' z-index: ' | append: tz | append: ';' %}
  {% endif %}
{% elsif tz > 0 %}
  {% assign tile_outer_style = 'z-index: ' | append: tz | append: ';' %}
{% endif %}
<div
  class="ak-bts-collage__tile {% unless use_custom_tile %}ak-bts-collage__tile--{{ pl }}{% endunless %}"
  {% if tile_outer_style != blank %}style="{{ tile_outer_style | strip }}"{% endif %}
  {{ block.shopify_attributes }}
>
  <div class="ak-bts-collage__tile-inner">
    {% if block.settings.link_url != blank %}
      <a
        href="{{ block.settings.link_url }}"
        class="ak-bts-collage__tile-link"
        {% if block.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        aria-label="{{ alt | escape }}"
      >
    {% endif %}
    {% if img != blank %}
      {% render 'image-element', image: img, alt: alt, stretch_width: true %}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
    {% if block.settings.link_url != blank %}
      </a>
    {% endif %}
  </div>
</div>
