{% comment %}
  Snippet can be used in section or block
  eg. {% include 'include-image-with-text-overlay' %}
{% endcomment %}

{% comment %}Assign object as block or section{% endcomment %}
{% if type == 'block' %}
  {% assign object = block %}
{% else %}
  {% assign object = section %}
{% endif %}

{% assign id = object.id %}
{% assign image = object.settings.image %}
{% assign mobile_image = object.settings.mobile_image %}
{% assign image_alt_override = object.settings.image_alt %}
{% assign max_height_desktop = object.settings.max_height_desktop | default: 0 %}
{% assign max_height_mobile = object.settings.max_height_mobile | default: 0 %}
{% assign link = object.settings.link %}
{% assign label = object.settings.label %}
{% assign open_in_new_tab = object.settings.open_in_new_tab %}
{% comment %} Text {% endcomment %}
{% assign pretext = object.settings.pretext %}
{% assign pretext_color = object.settings.pretext_color %}
{% assign title = object.settings.title %}
{% assign title_color = object.settings.heading_color %}
{% assign heading_font_size = object.settings.heading_font_size | default: 32 %}
{% assign heading_font_weight = object.settings.heading_font_weight | default: '400' %}
{% assign preheading_font_weight = object.settings.preheading_font_weight | default: '400' %}
{% assign subheading_font_weight = object.settings.subheading_font_weight | default: '400' %}
{% assign heading_underline = object.settings.heading_underline %}
{% assign pretext_underline = object.settings.pretext_underline %}
{% assign subheading_underline = object.settings.subheading_underline %}
{% assign subtitle = object.settings.subtitle %}
{% assign subtitle_color = object.settings.subheading_color %}
{% assign text_spacing = object.settings.text_spacing | default: 12 %}
{% assign padding_below_preheading = object.settings.padding_below_preheading | default: text_spacing %}
{% assign padding_below_heading = object.settings.padding_below_heading | default: text_spacing %}
{% assign padding_below_subheading = object.settings.padding_below_subheading | default: 0 %}
{% assign text_alignment = object.settings.text_alignment %}
{% assign text_horizontal_position = object.settings.text_horizontal_position %}
{% assign text_vertical_position = object.settings.text_vertical_position %}
{% comment %} Text background {% endcomment %}
{% assign background_color =  object.settings.background_color %}
{% assign background_color_alpha = object.settings.background_opacity | divided_by: 100.00 %}
{% assign text_width =  object.settings.text_width %}
{% comment %} Buttons {% endcomment %}
{% assign button_1 = object.settings.button_1 %}
{% assign button_1_link = object.settings.button_1_link %}
{% assign button_1_style = object.settings.button_1_style %}
{% assign button_2 = object.settings.button_2 %}
{% assign button_2_link = object.settings.button_2_link %}
{% assign button_2_style = object.settings.button_2_style %}
{% if button_1 != blank and button_2 != blank %}
  {% assign buttons = true %}
{% else %}
  {% assign buttons = false %}
{% endif %}
{% assign caption_border_width = object.settings.border_width %}
{% assign caption_border_color = object.settings.border_color %}
{% comment %} Accessibility contrast (ADA) {% endcomment %}
{% assign text_shadow_contrast = object.settings.text_shadow_contrast | default: true %}
{% assign scrim_overlay = object.settings.scrim_overlay | default: 'dark' %}
{% case object.settings.preheading_font_family | default: 'system' %}
  {% when 'arial' %}{% assign preheading_font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign preheading_font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign preheading_font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign preheading_font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign preheading_font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign preheading_font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% case object.settings.font_family | default: 'system' %}
  {% when 'arial' %}{% assign font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% case object.settings.subheading_font_family | default: 'system' %}
  {% when 'arial' %}{% assign subheading_font_stack = 'Arial, Helvetica, sans-serif' %}
  {% when 'georgia' %}{% assign subheading_font_stack = 'Georgia, serif' %}
  {% when 'times' %}{% assign subheading_font_stack = '"Times New Roman", Times, serif' %}
  {% when 'verdana' %}{% assign subheading_font_stack = 'Verdana, Geneva, sans-serif' %}
  {% when 'trebuchet' %}{% assign subheading_font_stack = '"Trebuchet MS", "Lucida Grande", sans-serif' %}
  {% else %}{% assign subheading_font_stack = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif' %}
{% endcase %}
{% comment %} Mobile {% endcomment %}
{% assign mobile_text_below_media = object.settings.mobile_text_below_image %}
{% assign mobile_text_crop = object.settings.mobile_image_crop %}
{% assign mobile_headline_color = object.settings.heading_color_mobile %}
{% assign mobile_preheading_color = object.settings.pretext_color_mobile %}
{% assign mobile_subtitle_color = object.settings.subheading_color_mobile %}
{% comment %}Layout{% endcomment %}
{% assign width = object.settings.width %}
{% assign padding_top = object.settings.padding_top %}
{% assign padding_bottom = object.settings.padding_bottom %}
{% assign padding_left = object.settings.padding_left %}
{% assign padding_right = object.settings.padding_right %}
{% assign padding_top_mobile = object.settings.padding_top_mobile | default: padding_top %}
{% assign padding_bottom_mobile = object.settings.padding_bottom_mobile | default: padding_bottom %}
{% assign overlay_padding_top = object.settings.overlay_container_padding_top | default: 24 %}
{% assign overlay_padding_bottom = object.settings.overlay_container_padding_bottom | default: 24 %}
{% assign overlay_padding_top_mobile = object.settings.overlay_container_padding_top_mobile | default: overlay_padding_top %}
{% assign overlay_padding_bottom_mobile = object.settings.overlay_container_padding_bottom_mobile | default: overlay_padding_bottom %}
{% assign animation = object.settings.animation | default: 'none' %}

{% comment %}Is the color set to transparent?{% endcomment %}
{% assign heading_alpha = title_color | color_extract: 'alpha' %}
{% assign preheading_alpha = pretext_color | color_extract: 'alpha' %}
{% assign subheading_alpha = subtitle_color | color_extract: 'alpha' %}
{% assign mobile_headline_alpha = mobile_headline_color | color_extract: 'alpha' %}
{% assign mobile_preheading_alpha = mobile_preheading_color | color_extract: 'alpha' %}
{% assign mobile_subtitle_alpha = mobile_subtitle_color | color_extract: 'alpha' %}
{% assign caption_border_alpha = object.settings.border_color | color_extract: 'alpha' %}

{% comment %}Advanced{% endcomment %}
{% assign css_class = object.settings.css_class %}
{% assign custom_css = object.settings.custom_css %}

{% comment %}Section specific CSS{% endcomment %}
{% capture section_css -%}
  .caption-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    background-color: {% if background_color_alpha != 100 %}{{ background_color | color_modify: 'alpha', background_color_alpha }}{% else %}{{ background_color }}{% endif %};
    border: {{ caption_border_width }}px solid {{ caption_border_color }};
  }

  .caption-content .image-with-text-overlay__preheading {
    margin: 0 0 {{ padding_below_preheading }}px 0;
  }
  .caption-content .image-with-text-overlay__heading {
    margin: 0 0 {{ padding_below_heading }}px 0;
  }
  .caption-content .image-with-text-overlay__subheading {
    margin: 0 0 {{ padding_below_subheading }}px 0;
  }

  .caption {
    padding-top: {{ overlay_padding_top }}px !important;
    padding-bottom: {{ overlay_padding_bottom }}px !important;
  }

  .image-with-text-overlay__heading {
    font-family: {{ font_stack }};
    color: {% if heading_alpha != 0 %}{{ title_color }}{% else %}{{ settings.heading_color }}{% endif %} !important;
    font-size: {{ heading_font_size }}px !important;
    font-weight: {{ heading_font_weight }} !important;
    text-transform: none;
    {% if heading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
    {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85);{% endif %}
  }

  .image-with-text-overlay__preheading {
    font-family: {{ preheading_font_stack }};
    font-weight: {{ preheading_font_weight }};
    color: {% if preheading_alpha != 0 %}{{ pretext_color }}{% else %}{{ settings.heading_color }}{% endif %} !important;
    text-transform: none;
    {% if pretext_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
    {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85);{% endif %}
  }

  .image-with-text-overlay__subheading {
    font-family: {{ subheading_font_stack }};
    font-weight: {{ subheading_font_weight }};
    color: {% if subheading_alpha != 0 %}{{ subtitle_color }}{% else %}{{ settings.heading_color }}{% endif %} !important;
    text-transform: none;
    {% if subheading_underline %}text-decoration: underline; text-underline-offset: 0.2em;{% endif %}
    {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85);{% endif %}
  }

  {% if scrim_overlay == 'dark' %}
  .caption--scrim-dark::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55), rgba(0,0,0,0.2) 40%, transparent);
    pointer-events: none;
    z-index: 0;
  }
  .caption--scrim-dark .caption-content {
    position: relative;
    z-index: 1;
  }
  {% endif %}

  .image-with-text-overlay__banner {
    position: relative;
    overflow: hidden;
    line-height: 0;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }
  .image-with-text-overlay__banner img,
  .image-with-text-overlay__banner .image-element__wrap {
    display: block;
    vertical-align: middle;
  }
  .image-with-text-overlay__container {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }
  #shopify-section-{{ id }} .image-with-text-overlay__container {
    padding-bottom: 0 !important;
  }
  #shopify-section-{{ id }} .image-with-text-overlay__banner.columns {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }
{%- endcapture -%}

{% comment %}Section specific CSS{% endcomment %}

{% style %}
  {% include 'css-loop', css: section_css, id: id %}

  @media only screen and (min-width: 480px) {
    #shopify-section-{{ id }} .caption-content {
      width: {{ text_width }}%;
    }
  }

  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px !important;
    padding-left: {{ padding_left }}px;
    padding-right: {{ padding_right }}px;
    margin-bottom: 0 !important;
    {% if width == 'wide' %}
      width: 100%;
    {% elsif width == 'half' %}
      width: 50%;
    {% endif %}
  }

  @media only screen and (max-width: 798px) {
    #shopify-section-{{ id }} {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px !important;
    }
    #shopify-section-{{ id }} .caption {
      padding-top: {{ overlay_padding_top_mobile }}px !important;
      padding-bottom: {{ overlay_padding_bottom_mobile }}px !important;
    }
  }

  #shopify-section-{{ id }} .caption--click-through {
    pointer-events: none;
  }

  {% if max_height_desktop > 0 %}
  #shopify-section-{{ id }} .image-with-text-overlay__banner {
    height: {{ max_height_desktop }}px;
    max-height: {{ max_height_desktop }}px;
    overflow: hidden;
  }
  {% endif %}

  {% if max_height_desktop > 0 or max_height_mobile > 0 %}
  #shopify-section-{{ id }} .image-with-text-overlay__banner .image-element__wrap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }
  #shopify-section-{{ id }} .image-with-text-overlay__banner .image-element__wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ id }} .image-with-text-overlay__banner .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  {% endif %}

  @media only screen and (max-width: 798px) {
    {% if max_height_mobile > 0 %}
    #shopify-section-{{ id }} .image-with-text-overlay__banner {
      height: {{ max_height_mobile }}px;
      max-height: {{ max_height_mobile }}px;
      overflow: hidden;
    }
    {% endif %}
  }

  {% include 'css-loop', css: custom_css, id: id %}

{% endstyle %}

{% comment %} Resolve final colors for each text element {% endcomment %}
{% if heading_alpha != 0 %}
  {% assign resolved_heading_color = title_color %}
{% else %}
  {% assign resolved_heading_color = settings.heading_color %}
{% endif %}
{% if preheading_alpha != 0 %}
  {% assign resolved_preheading_color = pretext_color %}
{% else %}
  {% assign resolved_preheading_color = settings.heading_color %}
{% endif %}
{% if subheading_alpha != 0 %}
  {% assign resolved_subtitle_color = subtitle_color %}
{% else %}
  {% assign resolved_subtitle_color = settings.heading_color %}
{% endif %}

{% comment %} Compute caption inline position styles {% endcomment %}
{% if text_vertical_position == 'top' %}
  {% capture caption_pos_style %}position: absolute !important; width: 100% !important; display: block !important; text-align: {{ text_horizontal_position }} !important; pointer-events: none !important; padding: 1% !important; top: 0 !important; bottom: auto !important; -webkit-transform: none !important; -ms-transform: none !important; transform: none !important;{% endcapture %}
{% elsif text_vertical_position == 'bottom' %}
  {% capture caption_pos_style %}position: absolute !important; width: 100% !important; top: 0 !important; bottom: 0 !important; left: 0 !important; right: 0 !important; display: flex !important; flex-direction: column !important; justify-content: flex-end !important; text-align: {{ text_horizontal_position }} !important; pointer-events: none !important; padding: 1% !important; -webkit-transform: none !important; -ms-transform: none !important; transform: none !important;{% endcapture %}
{% else %}
  {% capture caption_pos_style %}position: absolute !important; width: 100% !important; display: block !important; text-align: {{ text_horizontal_position }} !important; pointer-events: none !important; padding: 1% !important; top: 50% !important; bottom: auto !important; -webkit-transform: translateY(-50%) !important; -ms-transform: translateY(-50%) !important; transform: translateY(-50%) !important;{% endcapture %}
{% endif %}

{% comment %} HTML markup {% endcomment %}
<section class="section
                {{ css_class }}
                is-width-{{ width }}
                under-overlay-menu
                {% if mobile_text_below_media == true %}
                  mobile-text--below-media
                  {% else %}
                  mobile-text--over-media
                {% endif %}
                {% if caption_border_alpha != 0 %}
                  has-border
                {% endif %}
                "
                {% if animation != "none" %}
                  data-scroll-class="{{ animation }}"
                {% endif %}
                {% if title != blank %}aria-label="{{ title | escape }}"{% elsif label != blank %}aria-label="{{ label | escape }}"{% else %}aria-label="Promotional banner"{% endif %}>
  <div class="container
              image-with-text-overlay__container
              {% if width == 'wide' or width == 'half' %}
                equal-columns--outside-trim
              {% endif %}">
    <div class="image-with-text-overlay__banner columns one-whole image-crop-{{ mobile_text_crop }}">

      {% if mobile_image != blank %}
        {% assign hide_mobile = 'is-hidden-mobile-only' %}
      {% endif %}

      {% if image != blank %}
        {% if image_alt_override != blank %}
          {% assign desktop_alt = image_alt_override %}
        {% elsif image.alt != blank %}
          {% assign desktop_alt = image.alt %}
        {% elsif title != blank %}
          {% assign desktop_alt = title %}
        {% else %}
          {% assign desktop_alt = "Promotional banner" %}
        {% endif %}
        {% include 'image-element', image: image, alt: desktop_alt, stretch_width: true, additional_classes: hide_mobile %}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}

      {% if mobile_image != blank %}
        {% if image_alt_override != blank %}
          {% assign mobile_alt = image_alt_override %}
        {% elsif mobile_image.alt != blank %}
          {% assign mobile_alt = mobile_image.alt %}
        {% elsif title != blank %}
          {% assign mobile_alt = title %}
        {% else %}
          {% assign mobile_alt = "Promotional banner" %}
        {% endif %}
        <div class="is-hidden-desktop-only">
          {% include 'image-element', image: mobile_image, alt: mobile_alt, stretch_width: true %}
        </div>
      {% endif %}

      {% if link != blank %}
        <a href="{{ link }}" {% if open_in_new_tab %}target="_blank"{% endif %} class="banner--full-link" aria-label="{% if label != blank %}{{ label | escape }}{% elsif title != blank %}{{ title | escape }}{% else %}Learn more{% endif %}"></a>
      {% endif %}

      {% assign caption_click_through = false %}
{% if link != blank and button_1 == blank and button_2 == blank %}
  {% assign caption_click_through = true %}
{% endif %}
      {% if pretext != blank or title != blank or subtitle != blank or button_1 != blank or button_2 != blank %}
        <div id="caption-pos-{{ id }}" class="caption text-align-{{ text_horizontal_position }} align-{{ text_vertical_position }}{% if caption_click_through %} caption--click-through{% endif %}{% if scrim_overlay == 'dark' %} caption--scrim-dark{% endif %}" style="{{ caption_pos_style }}">
          <div class="caption-content text-align-{{ text_alignment }}" style="pointer-events: all !important; text-align: {{ text_alignment }} !important; display: inline-block !important;">
            {% if pretext != blank %}
              <div class="image-with-text-overlay__preheading banner__subheading pretext subtitle" style="color: {{ resolved_preheading_color }} !important; {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85) !important;{% endif %}">
                {{ pretext }}
              </div>
            {% endif %}
            {% if title != blank %}
              <h2 class="image-with-text-overlay__heading banner__heading title" style="color: {{ resolved_heading_color }} !important; font-size: {{ heading_font_size }}px !important; font-weight: {{ heading_font_weight }} !important; {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85) !important;{% endif %}">
                <span>{{ title }}</span>
              </h2>
            {% endif %}
            {% if subtitle != blank %}
              <div class="image-with-text-overlay__subheading banner__subheading subtitle" style="color: {{ resolved_subtitle_color }} !important; {% if text_shadow_contrast %}text-shadow: 0 1px 2px rgba(0,0,0,0.85) !important;{% endif %}">
                {{ subtitle }}
              </div>
            {% endif %}
            {% if button_1 != blank or button_2 != blank %}
              <div class="image-with-text-overlay__buttons buttons {% unless buttons == true %}is-justify-{{ text_alignment }}{% endunless %}">

              {% if button_1 != blank %}
                {% include 'button', label: button_1, href: button_1_link, type: "link", style: button_1_style %}
              {% endif %}
              {% if button_2 != blank %}
                {% include 'button', label: button_2, href: button_2_link, type: "link", style: button_2_style %}
              {% endif %}

              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>