{% comment %}
  Finishing Touches: single resolved image per call (section picks override desktop → mobile → product).
  Theme editor: eager img so lazyload does not leave tiles blank in preview.
  @param image {Image}
  @param alt {String}
  @param object_fit {Boolean}
  @param max_height {Number}
  @param additional_classes {String} Optional
{% endcomment %}
{% liquid
  assign additional_classes = additional_classes | default: ''
  assign back_to_basics = false
  if request.design_mode
    assign back_to_basics = true
  endif
%}
{% include 'image-element', image: image, alt: alt, object_fit: object_fit, max_height: max_height, additional_classes: additional_classes, back_to_basics: back_to_basics %}
