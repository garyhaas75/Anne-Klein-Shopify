{% assign currentTitle = product.title %}
{% assign isDoubleProduct = false %}
{% assign productHandle = product.handle | append: "," %}
{% assign tagToCheck = "Overflow" %}

{% capture tags %}{{ product.tags | remove: alt_attribute }}{% endcapture %}

{% if tags contains tagToCheck %}

  {% assign isDoubleProduct = true %}

  {% paginate collections.overflow1.products by 250 %}

  {% for prod in collections.overflow1.products %}

	{% capture otherTags %}{{ prod.tags | remove: alt_attribute }}{% endcapture %}
    {% if product.handle != prod.handle %}
      {% if prod.title == currentTitle and otherTags contains tagToCheck %}
          {% assign productHandle = productHandle | append: prod.handle | append: "," %}
      {% endif %}
    {% endif %}  

  {% endfor %}

  {% endpaginate %}

